@model QLDSV_HTC.Web.Models.ClassManagementViewModel
@using QLDSV_HTC.Domain.Constants
@{
    ViewData["Title"] = "Quản lý Lớp";
    var isPGV = User.IsInRole("PGV");
    var hasFaculty = !string.IsNullOrEmpty(Model.CurrentFacultyId);

    ViewData["isPGV"] = isPGV;
    ViewData["hasFaculty"] = hasFaculty;
}

<div class="dashboard-container fade-in-up">
    @* ── Bảng danh sách lớp ── *@
    @await Html.PartialAsync("_ClassTable", Model, ViewData)
</div>


@* ══════════════════════════════════════════════════════════
MODAL: Nhập danh mục lớp / Xác nhận xóa
══════════════════════════════════════════════════════════ *@
@await Html.PartialAsync("_ClassFormModal", Model, ViewData)
<partial name="_DeleteConfirmModal" />

@section Scripts {
    <script src="~/js/form-helpers.js" asp-append-version="true"></script>
    <script>
        (function () {
            'use strict';

            const URL_ADD = '@RouteConstants.Class.AddPath';
            const URL_EDIT = '@RouteConstants.Class.EditPath';
            const URL_DELETE = '@RouteConstants.Class.DeletePath';

            let snapshotData = null;
            let selectedId = null;
            let originalId = null;

            // -- UNDO STACK STATE --
            let undoStack = [];
            let forceClose = false;

            const modal = document.getElementById('classFormModal');
            const deleteModal = document.getElementById('deleteConfirmModal');
            const fldClassId = document.getElementById('fldClassId');
            const fldClassName = document.getElementById('fldClassName');
            const fldSchoolYear = document.getElementById('fldSchoolYear');
            const fldFacultyId = document.getElementById('fldFacultyId');

            const btnThem = document.getElementById('btnFormThem');
            const btnXoa = document.getElementById('btnFormXoa');
            const btnGhi = document.getElementById('btnFormGhi');
            const btnPhucHoi = document.getElementById('btnFormPhucHoi');
            const btnHuy = document.getElementById('btnFormHuy');

            // ── Shared form helpers ──────────────────────────────────
            const helpers = createFormHelpers({
                alertEl: document.getElementById('formAlert'),
                modeLabelEl: document.getElementById('formModeLabel'),
                buttons: { them: btnThem, xoa: btnXoa, ghi: btnGhi, phucHoi: btnPhucHoi, huy: btnHuy },
                allFields: [fldClassId, fldClassName, fldSchoolYear, fldFacultyId],
                requiredFields: [fldClassId, fldClassName, fldSchoolYear, fldFacultyId],
                getSelectedId: () => selectedId,
            });

            // ── Xử lý modal xác nhận xóa ────────────────────────────
            let pendingDeleteId = null;
            let pendingDeleteName = null;

            if (deleteModal) {
                document.getElementById('btnConfirmDelete').addEventListener('click', async () => {
                    bootstrap.Modal.getInstance(deleteModal)?.hide();
                    if (pendingDeleteId) await doDelete(pendingDeleteId);
                });
            }

            function showDeleteModal(id, name) {
                pendingDeleteId = id;
                pendingDeleteName = name;
                document.getElementById('deleteTargetId').textContent = id;
                document.getElementById('deleteTargetName').textContent = name;
                bootstrap.Modal.getOrCreateInstance(deleteModal).show();
            }

            if (!modal) return;

            const btnCancelModal = modal.querySelector('.btn-cancel-modal');
            const btnSaveModal = modal.querySelector('.btn-save-modal');

            // Mở modal qua nút Thêm Lớp Mới → reset về view
            document.getElementById('btnOpenClassForm')?.addEventListener('click', resetToView);

            // Mở modal → clear stack
            modal.addEventListener('show.bs.modal', () => {
                undoStack = [];
                forceClose = false;
            });

            function getFormChanges() {
                const changes = [];
                const mode = helpers.getMode();
                if (mode === 'view') return changes;

                const idVal = fldClassId.value.trim();
                const nameVal = fldClassName.value.trim();
                const yearVal = fldSchoolYear.value.trim();
                const facultyVal = fldFacultyId.value.trim();

                if (mode === 'add') {
                    if (idVal) changes.push(`• <b>Mã lớp</b>: (Mới) → <span class="text-success fw-bold">"${escapeHtml(idVal)}"</span>`);
                    if (nameVal) changes.push(`• <b>Tên lớp</b>: (Mới) → <span class="text-success fw-bold">"${escapeHtml(nameVal)}"</span>`);
                    if (yearVal) changes.push(`• <b>Khóa học</b>: (Mới) → <span class="text-success fw-bold">"${escapeHtml(yearVal)}"</span>`);
                    if (facultyVal) changes.push(`• <b>Khoa</b>: (Mới) → <span class="text-success fw-bold">"${escapeHtml(facultyVal)}"</span>`);
                } else if (mode === 'edit' && snapshotData) {
                    const oldId = (snapshotData.classId ?? '').toString().trim();
                    const oldName = (snapshotData.className ?? '').toString().trim();
                    const oldYear = (snapshotData.schoolYear ?? '').toString().trim();
                    const oldFaculty = (snapshotData.facultyId ?? '').toString().trim();

                    if (idVal !== oldId) {
                        changes.push(`• <b>Mã lớp</b>: <span class="text-muted">"${escapeHtml(oldId)}"</span> → <span class="text-warning fw-bold">"${escapeHtml(idVal)}"</span>`);
                    }
                    if (nameVal !== oldName) {
                        changes.push(`• <b>Tên lớp</b>: <span class="text-muted">"${escapeHtml(oldName)}"</span> → <span class="text-warning fw-bold">"${escapeHtml(nameVal)}"</span>`);
                    }
                    if (yearVal !== oldYear) {
                        changes.push(`• <b>Khóa học</b>: <span class="text-muted">"${escapeHtml(oldYear)}"</span> → <span class="text-warning fw-bold">"${escapeHtml(yearVal)}"</span>`);
                    }
                    if (facultyVal !== oldFaculty) {
                        changes.push(`• <b>Khoa</b>: <span class="text-muted">"${escapeHtml(oldFaculty)}"</span> → <span class="text-warning fw-bold">"${escapeHtml(facultyVal)}"</span>`);
                    }
                }

                return changes;
            }

            function isFormDirty() {
                return getFormChanges().length > 0;
            }

            // Đóng modal → xóa stack (giữ lại thay đổi đã ghi)
            modal.addEventListener('hide.bs.modal', (e) => {
                if (forceClose) return;
                // Mặc định: giữ lại thay đổi (giống "Lưu và thoát")
                undoStack = [];
            });

            btnSaveModal?.addEventListener('click', () => {
                undoStack = [];
                forceClose = true;
                bootstrap.Modal.getInstance(modal).hide();
            });

            // "Hoàn tác tất cả và thoát" → undo rồi đóng
            btnCancelModal?.addEventListener('click', async () => {
                if (undoStack.length > 0) {
                    while (undoStack.length > 0) {
                        await executeUndo();
                    }
                }
                forceClose = true;
                bootstrap.Modal.getInstance(modal).hide();
            });

            // Reset khi đóng modal
            modal.addEventListener('hidden.bs.modal', resetToView);

            // Chọn hàng trong mini-table → chỉ block khi đang ở chế độ Thêm
            document.getElementById('miniClassBody').addEventListener('click', e => {
                if (helpers.getMode() === 'add') return; // Đang Thêm → không cho chuyển sang Sửa
                const row = e.target.closest('tr.mini-row');
                if (!row) return;
                selectMiniRow(row);
            });

            // ── Nút Thêm ─────────────────────────────────────────────
            btnThem.addEventListener('click', () => {
                deselectMiniRow();
                selectedId = null;
                snapshotData = null;
                clearFields();
                
                // Tự động điền niên khóa hiện tại (VD: 2026-2030)
                const currentYear = new Date().getFullYear();
                fldSchoolYear.value = `${currentYear}-${currentYear + 4}`;
                
                helpers.clearValidation();
                helpers.setMode('add');
                fldClassId.disabled = false;
                fldClassId.focus();
                helpers.showAlert('Nhập thông tin lớp mới rồi nhấn <b>Ghi</b> để lưu.', 'info');
            });

            // ── Nút Xóa ──────────────────────────────────────────────
            btnXoa.addEventListener('click', () => {
                if (!selectedId) return;
                showDeleteModal(selectedId, fldClassName.value);
            });

            async function saveClass() {
                if (!helpers.validateForm()) return false;

                const payload = {
                    oldClassId: originalId,
                    classId: fldClassId.value.trim(),
                    className: fldClassName.value.trim(),
                    schoolYear: fldSchoolYear.value.trim(),
                    facultyId: fldFacultyId.value.trim(),
                };

                try {
                    const res = await fetchJson(helpers.getMode() === 'add' ? URL_ADD : URL_EDIT, payload);
                    if (res.success) {
                        window.showToast(res.message, 'success');
                        if (helpers.getMode() === 'add') {
                            addRowToTables(payload);
                            undoStack.push({ action: 'delete', payload: { classId: payload.classId } });
                            resetToView();
                        } else {
                            updateRowInTables(payload, originalId);
                            if (snapshotData) {
                                undoStack.push({ 
                                    action: 'edit', 
                                    payload: { 
                                        oldClassId: payload.classId, 
                                        classId: snapshotData.classId, 
                                        className: snapshotData.className,
                                        schoolYear: snapshotData.schoolYear,
                                        facultyId: snapshotData.facultyId
                                    } 
                                });
                            }
                            snapshotData = { ...payload };
                            selectedId = payload.classId;
                            originalId = payload.classId;
                            helpers.setMode('view');
                            highlightMiniRow(selectedId);
                        }
                        return true;
                    } else {
                        helpers.showAlert(res.message, 'danger');
                        return false;
                    }
                } catch (err) {
                    helpers.showAlert('Lỗi: ' + err.message, 'danger');
                    return false;
                }
            }

            // ── Nút Ghi ──────────────────────────────────────────────
            btnGhi.addEventListener('click', async () => {
                await saveClass();
            });

            // ── Nút Phục hồi ─────────────────────────────────────────
            btnPhucHoi.addEventListener('click', async () => {
                if (undoStack.length === 0) {
                    helpers.showAlert('Không có hành động nào để phục hồi.', 'info');
                    return;
                }
                await executeUndo();
                resetToView();
                helpers.showAlert('Đã hoàn tác 1 hành động.', 'warning');
            });

            // ── Nút Hủy ──────────────────────────────────────────────
            btnHuy?.addEventListener('click', resetToView);

            // ── Sửa / Xóa nhanh từ bảng chính ───────────────────────
            document.getElementById('classTableBody').addEventListener('click', e => {
                const editBtn = e.target.closest('.btn-edit-row');
                const delBtn = e.target.closest('.btn-delete-row');

                if (editBtn) {
                    const id = editBtn.dataset.id;
                    const name = editBtn.dataset.name;
                    const year = editBtn.dataset.year;
                    const facultyId = editBtn.dataset.faculty;
                    const studentCount = parseInt(editBtn.closest('tr').dataset.studentCount || '0', 10);
                    bootstrap.Modal.getOrCreateInstance(modal).show();
                    setTimeout(() => {
                        populateFields(id, name, year, facultyId);
                        helpers.setMode('edit');
                        
                        if (studentCount > 0) {
                            btnXoa.disabled = true;
                            btnXoa.title = `Không thể xóa lớp đã có sinh viên (${studentCount} SV)`;
                        } else {
                            btnXoa.title = "Xóa (Phím tắt: Del)";
                        }

                        highlightMiniRow(id);
                        helpers.hideAlert();
                    }, 200);
                }

                if (delBtn) {
                    const id = delBtn.dataset.id;
                    const name = delBtn.dataset.name;
                    showDeleteModal(id, name);
                }
            });

            // ── Helpers ──────────────────────────────────────────────

            function resetToView() {
                selectedId = null; snapshotData = null; originalId = null;
                clearFields(); helpers.clearValidation(); helpers.hideAlert(); deselectMiniRow();
                helpers.setMode('view');
            }

            function populateFields(id, name, year, facultyId) {
                fldClassId.value = id;
                fldClassName.value = name;
                fldSchoolYear.value = year;
                fldFacultyId.value = facultyId;
                selectedId = id;
                originalId = id;
                snapshotData = { 
                    classId: id, 
                    className: name, 
                    schoolYear: year, 
                    facultyId: facultyId 
                };
            }

            function clearFields() {
                fldClassId.value = fldClassName.value = fldSchoolYear.value = '';
                fldFacultyId.value = '';
            }

            function selectMiniRow(row) {
                deselectMiniRow();
                row.classList.add('table-active', 'fw-semibold');
                populateFields(row.dataset.id, row.dataset.name, row.dataset.year, row.dataset.faculty);
                helpers.setMode('edit');
                
                const studentCount = parseInt(row.dataset.studentCount || '0', 10);
                if (studentCount > 0) {
                    btnXoa.disabled = true;
                    btnXoa.title = `Không thể xóa lớp đã có sinh viên (${studentCount} SV)`;
                } else {
                    btnXoa.disabled = false;
                    btnXoa.title = "Xóa (Phím tắt: Del)";
                }

                helpers.hideAlert();
            }

            function highlightMiniRow(id) {
                deselectMiniRow();
                const row = document.querySelector(`#miniClassBody tr[data-id="${CSS.escape(id)}"]`);
                if (row) row.classList.add('table-active', 'fw-semibold');
            }

            function deselectMiniRow() {
                document.querySelectorAll('#miniClassBody tr.table-active')
                    .forEach(r => r.classList.remove('table-active', 'fw-semibold'));
            }

            async function doDelete(id) {
                try {
                    // Save for undo before delete
                    const row = document.querySelector(`#classTableBody tr[data-id="${CSS.escape(id)}"]`);
                    const delPayload = row ? {
                        classId: row.dataset.id,
                        className: row.dataset.name,
                        schoolYear: row.dataset.year,
                        facultyId: row.dataset.faculty
                    } : null;

                    const res = await fetchJson(URL_DELETE, { classId: id });
                    if (res.success) {
                        removeRowFromTables(id);
                        // Only add to stack if we have delPayload and modal is shown
                        if (delPayload && modal.classList.contains('show')) {
                            undoStack.push({ action: 'add', payload: delPayload });
                        }
                        
                        resetToView();
                        window.showToast(res.message, 'success');
                    } else {
                        window.showToast(res.message, 'danger');
                    }
                } catch (err) { 
                    window.showToast('Lỗi: ' + err.message, 'danger'); 
                }
            }

            async function executeUndo() {
                if (undoStack.length === 0) return;
                const actionObj = undoStack.pop();
                try {
                    if (actionObj.action === 'add') {
                        await fetchJson(URL_ADD, actionObj.payload);
                        addRowToTables(actionObj.payload);
                    } else if (actionObj.action === 'edit') {
                        await fetchJson(URL_EDIT, actionObj.payload);
                        updateRowInTables(actionObj.payload, actionObj.payload.oldClassId);
                    } else if (actionObj.action === 'delete') {
                        await fetchJson(URL_DELETE, actionObj.payload);
                        removeRowFromTables(actionObj.payload.classId);
                    }
                } catch(err) {
                    window.showToast("Lỗi hoàn tác: " + err.message, "danger");
                }
            }

            // ── DOM table helpers ─────────────────────────────────────

            function addRowToTables(p) {
                const opt = fldFacultyId.querySelector(`option[value="${p.facultyId}"]`);
                const facultyName = opt ? opt.textContent : p.facultyId;
                const tbody = document.getElementById('classTableBody');
                const empty = tbody.querySelector('td[colspan]');
                if (empty) empty.closest('tr').remove();

                // Sort: KHOAHOC DESC → MAKHOA ASC → MALOP ASC
                // Invert year for DESC: use '\xff' - year so higher years sort first
                const sortKey = (yr, fac, id) => {
                    // Pad year inverted for DESC sort, then faculty + classId ASC
                    const invertedYear = String.fromCharCode(0xFFFF - parseInt(yr.replace(/[^0-9]/g, '').substring(0,4) || '0'));
                    return invertedYear + '|' + (fac || '').toLowerCase() + '|' + (id || '').toLowerCase();
                };
                const newKey = sortKey(p.schoolYear, p.facultyId, p.classId);

                // Main table: sorted insert
                const rows = [...tbody.querySelectorAll('tr[data-id]')];
                let inserted = false;
                for (const row of rows) {
                    const rowKey = sortKey(row.dataset.year || '', row.dataset.faculty || '', row.dataset.id || '');
                    if (newKey < rowKey) {
                        row.insertAdjacentHTML('beforebegin', mainRowHtml(p, facultyName, 0));
                        inserted = true;
                        break;
                    }
                }
                if (!inserted) tbody.insertAdjacentHTML('beforeend', mainRowHtml(p, facultyName, 0));

                // Mini table: sorted insert
                const miniBody = document.getElementById('miniClassBody');
                const miniRows = [...miniBody.querySelectorAll('tr[data-id]')];
                let miniInserted = false;
                for (const row of miniRows) {
                    const rowKey = sortKey(row.dataset.year || '', row.dataset.faculty || '', row.dataset.id || '');
                    if (newKey < rowKey) {
                        row.insertAdjacentHTML('beforebegin', miniRowHtml(p));
                        miniInserted = true;
                        break;
                    }
                }
                if (!miniInserted) miniBody.insertAdjacentHTML('beforeend', miniRowHtml(p));

                updateCount(1);
            }

            function updateRowInTables(p, oldId) {
                const opt = fldFacultyId.querySelector(`option[value="${p.facultyId}"]`);
                const facultyName = opt ? opt.textContent : p.facultyId;
                const main = document.querySelector(`#classTableBody tr[data-id="${CSS.escape(oldId)}"]`);
                const studentCount = main ? parseInt(main.dataset.studentCount || '0', 10) : 0;
                if (main) main.outerHTML = mainRowHtml(p, facultyName, studentCount);
                const mini = document.querySelector(`#miniClassBody  tr[data-id="${CSS.escape(oldId)}"]`);
                if (mini) {
                    p.studentCount = studentCount;
                    mini.outerHTML = miniRowHtml(p);
                }
            }

            function removeRowFromTables(id) {
                document.querySelector(`#classTableBody tr[data-id="${CSS.escape(id)}"]`)?.remove();
                document.querySelector(`#miniClassBody  tr[data-id="${CSS.escape(id)}"]`)?.remove();
                updateCount(-1);
            }

            function updateCount(delta) {
                const el = document.getElementById('visibleCount');
                if (el) el.textContent = String(parseInt(el.textContent || '0', 10) + delta);
            }

            function mainRowHtml(p, facultyName, studentCount = 0) {
                const disabledDelete = studentCount > 0 ? "disabled" : "";
                const deleteTitle = studentCount > 0 ? `Không thể xóa lớp đã có sinh viên (${studentCount} SV)` : "Xóa lớp";
                const deleteClass = studentCount > 0 ? "" : "btn-delete-row hover-scale";
                const studentBadge = studentCount > 0 
                    ? `<div class="small text-muted d-flex align-items-center gap-1 opacity-75"><i class="bi bi-person-badge"></i><span>${studentCount} sinh viên</span></div>` 
                    : `<div class="small text-muted d-flex align-items-center gap-1 opacity-50 italic"><i class="bi bi-person-x"></i><span>Chưa có sinh viên</span></div>`;
                
                return `<tr class="hover-row transition-base animate__animated animate__fadeIn" 
                             data-id="${escapeHtml(p.classId)}" data-name="${escapeHtml(p.className)}"
                             data-year="${escapeHtml(p.schoolYear)}" data-faculty="${escapeHtml(p.facultyId)}"
                             data-faculty-filter="${escapeHtml(p.facultyId)}" data-student-count="${studentCount}">
                         <td class="ps-4">
                            <span class="badge bg-primary-subtle text-primary border border-primary-subtle px-2 py-1 rounded-pill shadow-sm font-monospace tabular-nums">
                                ${escapeHtml(p.classId)}
                            </span>
                        </td>
                        <td>
                            <div class="fw-bold text-dark mb-1">${escapeHtml(p.className)}</div>
                            ${studentBadge}
                        </td>
                        <td class="text-center">
                            <span class="badge bg-light text-dark border tabular-nums rounded-pill px-3 py-1 shadow-sm">${escapeHtml(p.schoolYear)}</span>
                        </td>
                        <td class="text-center">
                            <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle px-2 py-1 rounded-3 shadow-sm">
                                <i class="bi bi-building me-1 small"></i>${escapeHtml(p.facultyId)}
                            </span>
                        </td>
                        <td class="text-end pe-4">
                            <div class="d-flex justify-content-end gap-1">
                                <button class="btn btn-sm btn-outline-primary btn-edit-row shadow-none hover-scale rounded-3" title="Sửa lớp"
                                        data-id="${escapeHtml(p.classId)}" data-name="${escapeHtml(p.className)}"
                                        data-year="${escapeHtml(p.schoolYear)}" data-faculty="${escapeHtml(p.facultyId)}">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-danger shadow-none rounded-3 ${deleteClass}" title="${deleteTitle}"
                                        data-id="${escapeHtml(p.classId)}" data-name="${escapeHtml(p.className)}" ${disabledDelete}>
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>`;
            }

            function miniRowHtml(p) {
                return `<tr class="mini-row transition-base" role="button"
                                data-id="${escapeHtml(p.classId)}" data-name="${escapeHtml(p.className)}"
                                data-year="${escapeHtml(p.schoolYear)}" data-faculty="${escapeHtml(p.facultyId)}"
                                data-student-count="${p.studentCount || 0}">
                        <td class="ps-3 fw-bold font-monospace text-primary">
                            <span class="badge bg-primary-subtle text-primary border border-primary-subtle px-2 py-1 rounded-pill">
                                ${escapeHtml(p.classId)}
                            </span>
                        </td>
                        <td class="fw-bold text-dark">${escapeHtml(p.className)}</td>
                        <td class="text-center">
                            <span class="badge bg-light text-dark border tabular-nums rounded-pill px-2">${escapeHtml(p.schoolYear)}</span>
                        </td>
                        <td class="text-center pe-3">
                            <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle px-2 rounded-pill">
                                ${escapeHtml(p.facultyId)}
                            </span>
                        </td>
                    </tr>`;
            }

            async function fetchJson(url, body) {
                const res = await fetch(url, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(body),
                });
                const json = await res.json();
                if (!res.ok && json.success !== false)
                    throw new Error(json.message ?? 'Lỗi máy chủ');
                return json;
            }

            // ── Client-side search + faculty filter ─────────────────────
            const classSearch = document.getElementById('classSearch');
            const btnClearSearch = document.getElementById('btnClearSearch');
            const facultyFilter = document.getElementById('facultyFilter');

            [classSearch, facultyFilter].forEach(el => {
                el?.addEventListener('input', applyFilters);
                el?.addEventListener('change', applyFilters);
            });

            btnClearSearch?.addEventListener('click', () => {
                if (classSearch) {
                    classSearch.value = '';
                    applyFilters();
                    classSearch.focus();
                }
            });

            classSearch?.addEventListener('keydown', (e) => {
                if (e.key === 'Escape') {
                    classSearch.value = '';
                    applyFilters();
                }
            });

            function applyFilters() {
                const q = (classSearch?.value ?? '').toLowerCase();
                const faculty = facultyFilter?.value ?? '';
                
                // Toggle clear button
                if (btnClearSearch) {
                    btnClearSearch.classList.toggle('d-none', q.length === 0);
                }

                let vis = 0;
                document.querySelectorAll('#classTableBody tr[data-id]').forEach(row => {
                    const match =
                        (!q || row.dataset.id.toLowerCase().includes(q) || (row.dataset.name ?? '').toLowerCase().includes(q)) &&
                        (!faculty || row.dataset.facultyFilter === faculty);
                    row.style.display = match ? '' : 'none';
                    if (match) vis++;
                });
                const vc = document.getElementById('visibleCount');
                if (vc) vc.textContent = String(vis);
            }

            // ── Modal Client-side search ───────────────────────────────
            const modalClassSearch = document.getElementById('modalClassSearch');
            modalClassSearch?.addEventListener('input', () => {
                const q = modalClassSearch.value.trim().toLowerCase();
                document.querySelectorAll('#miniClassBody tr.mini-row').forEach(row => {
                    const id = (row.dataset.id ?? '').toLowerCase();
                    const name = (row.dataset.name ?? '').toLowerCase();
                    const year = (row.dataset.year ?? '').toLowerCase();
                    const faculty = (row.dataset.faculty ?? '').toLowerCase();
                    const match = id.includes(q) || name.includes(q) || year.includes(q) || faculty.includes(q);
                    row.style.display = match ? '' : 'none';
                });
            });

        })();
    </script>
}
