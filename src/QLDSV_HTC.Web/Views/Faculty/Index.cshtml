@model QLDSV_HTC.Web.Models.FacultyManagementViewModel
@using QLDSV_HTC.Domain.Constants
@{
    ViewData["Title"] = "Quản lý Khoa";
    var isPGV = User.IsInRole("PGV");
    var hasFaculty = User.IsInRole("KHOA");
    var pageTitle = "Danh sách Khoa";

    ViewData["isPGV"] = isPGV;
    ViewData["hasFaculty"] = hasFaculty;
}

<div class="dashboard-container fade-in-up">

    @* ── Thanh tiêu đề + nút Thêm Khoa ── *@
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-1 fw-bold text-gray-800">@pageTitle</h1>
            <p class="text-muted mb-0 small">
                <i class="bi bi-building me-1"></i>
                Tổng: <strong>@Model.Faculties.Count()</strong> khoa
            </p>
        </div>
        @if (isPGV)
        {
            <button class="btn btn-primary shadow-sm d-flex align-items-center gap-2" id="btnOpenFacultyForm" type="button"
                data-bs-toggle="modal" data-bs-target="#facultyFormModal">
                <i class="bi bi-pencil-square"></i>
                <span>Cập nhật danh mục Khoa</span>
            </button>
        }
    </div>

    @* ── Bảng danh sách khoa ── *@
    @await Html.PartialAsync("_FacultyTable", Model, ViewData)
</div>

@* ══════════════════════════════════════════════════════════
MODAL: Nhập danh mục khoa / Xác nhận xóa
══════════════════════════════════════════════════════════ *@
@await Html.PartialAsync("_FacultyFormModal", Model, ViewData)
<partial name="_DeleteConfirmModal" />

@section Scripts {
    <script src="~/js/form-helpers.js" asp-append-version="true"></script>
    <script>
        (function () {
            'use strict';

            const URL_ADD = '@RouteConstants.Faculty.AddPath';
            const URL_EDIT = '@RouteConstants.Faculty.EditPath';
            const URL_DELETE = '@RouteConstants.Faculty.DeletePath';

            let snapshotData = null;
            let selectedId = null;
            let originalId = null;

            // Undo Stack State
            let undoStack = [];
            let forceClose = false;

            const modal = document.getElementById('facultyFormModal');
            const deleteModal = document.getElementById('deleteConfirmModal');
            const fldFacultyId = document.getElementById('fldFacultyId');
            const fldFacultyName = document.getElementById('fldFacultyName');

            const btnThem = document.getElementById('btnFormThem');
            const btnXoa = document.getElementById('btnFormXoa');
            const btnGhi = document.getElementById('btnFormGhi');
            const btnPhucHoi = document.getElementById('btnFormPhucHoi');
            const btnHuy = document.getElementById('btnFormHuy');

            // ── Shared form helpers ──────────────────────────────────
            const helpers = createFormHelpers({
                alertEl: document.getElementById('formAlert'),
                modeLabelEl: document.getElementById('formModeLabel'),
                buttons: { them: btnThem, xoa: btnXoa, ghi: btnGhi, phucHoi: btnPhucHoi, huy: btnHuy },
                allFields: [fldFacultyId, fldFacultyName],
                requiredFields: [fldFacultyId, fldFacultyName],
                getSelectedId: () => selectedId,
            });

            // ── Xử lý modal xác nhận xóa ────────────────────────────
            let pendingDeleteId = null;
            let pendingDeleteName = null;

            if (deleteModal) {
                document.getElementById('btnConfirmDelete').addEventListener('click', async () => {
                    bootstrap.Modal.getInstance(deleteModal)?.hide();
                    if (pendingDeleteId) await doDelete(pendingDeleteId);
                });
            }

            function showDeleteModal(id, name) {
                pendingDeleteId = id;
                pendingDeleteName = name;
                document.getElementById('deleteTargetId').textContent = id;
                document.getElementById('deleteTargetName').textContent = name;
                bootstrap.Modal.getOrCreateInstance(deleteModal).show();
            }

            if (!modal) return;

            const btnCancelModal = modal.querySelector('.btn-cancel-modal');
            const btnSaveModal = modal.querySelector('.btn-save-modal');

            // Mở modal qua nút Thêm Mới → reset về view
            document.getElementById('btnOpenFacultyForm')?.addEventListener('click', () => {
                resetToView();
                undoStack = [];
                forceClose = false;
            });

            // Mở modal → clear stack
            modal.addEventListener('show.bs.modal', () => {
                undoStack = [];
                forceClose = false;
            });

            // Chặn đóng modal nếu còn stack
            modal.addEventListener('hide.bs.modal', async (e) => {
                if (undoStack.length > 0 && !forceClose) {
                    e.preventDefault();
                    const isConfirmed = await window.showConfirmDialog(
                        "Xác nhận thoát",
                        "Bạn có các thao tác đã thực hiện nhưng chưa đóng phiên làm việc.<br>Nếu thoát bây giờ, bạn sẽ <b>không thể Phục hồi (Undo)</b> các thay đổi này được nữa.<br><br>Bạn vẫn muốn thoát?",
                        { confirmText: "Tiếp tục thoát", cancelText: "Ở lại", isDanger: true }
                    );
                    if (isConfirmed) {
                        forceClose = true;
                        bootstrap.Modal.getInstance(modal).hide();
                    }
                }
            });

            btnSaveModal?.addEventListener('click', async () => {
                if (undoStack.length === 0) {
                    forceClose = true;
                    bootstrap.Modal.getInstance(modal).hide();
                    return;
                }

                const message = "Các thay đổi đã được <b>Ghi</b> vào hệ thống. Tuy nhiên, nếu đóng cửa sổ này, bạn sẽ không thể dùng chức năng 'Phục hồi' (Undo) cho các thao tác vừa thực hiện.<br><br>Bạn có chắc chắn muốn thoát?";
                
                const isConfirmed = await window.showConfirmDialog(
                    "Xác nhận Thoát", message,
                    { confirmText: "Xác nhận", cancelText: "Trở lại" }
                );
                
                if (isConfirmed) {
                    undoStack = [];
                    forceClose = true;
                    bootstrap.Modal.getInstance(modal).hide();
                }
            });

            btnCancelModal?.addEventListener('click', async () => {
                if (undoStack.length === 0) {
                    forceClose = true;
                    bootstrap.Modal.getInstance(modal).hide();
                    return;
                }

                const message = "Hành động này sẽ <b>Hoàn Tác toàn bộ</b> các thay đổi bạn vừa thực hiện trong bảng vừa rồi.<br>Bạn có chắc chắn muốn xóa bỏ công sức vừa làm?";
                
                const isConfirmed = await window.showConfirmDialog(
                    "Hoàn Tác & Đóng", message,
                    { confirmText: "Xác nhận Hoàn tác", cancelText: "Giữ lại", isDanger: true }
                );

                if (isConfirmed) {
                    btnCancelModal.disabled = true;
                    while(undoStack.length > 0) {
                        await executeUndo();
                    }
                    undoStack = [];
                    forceClose = true;
                    btnCancelModal.disabled = false;
                    bootstrap.Modal.getInstance(modal).hide();
                }
            });

            // Reset khi đóng modal
            modal.addEventListener('hidden.bs.modal', resetToView);

            // Chọn hàng trong mini-table → chỉ block khi đang ở chế độ Thêm
            document.getElementById('miniFacultyBody').addEventListener('click', e => {
                if (helpers.getMode() === 'add') return;
                const row = e.target.closest('tr.mini-row');
                if (!row) return;
                selectMiniRow(row);
            });

            // ── Nút Thêm ─────────────────────────────────────────────
            btnThem.addEventListener('click', () => {
                deselectMiniRow();
                selectedId = null;
                snapshotData = null;
                clearFields();
                helpers.clearValidation();
                helpers.setMode('add');
                fldFacultyId.disabled = false;
                fldFacultyId.focus();
                helpers.showAlert('Nhập thông tin khoa mới rồi nhấn <b>Ghi</b> để lưu.', 'info');
            });

            // ── Nút Xóa ──────────────────────────────────────────────
            btnXoa.addEventListener('click', () => {
                if (!selectedId || btnXoa.disabled) return;
                showDeleteModal(selectedId, fldFacultyName.value);
            });

            // ── Nút Ghi ──────────────────────────────────────────────
            btnGhi.addEventListener('click', async () => {
                if (!helpers.validateForm()) return;

                const payload = {
                    oldFacultyId: originalId,
                    facultyId: fldFacultyId.value.trim(),
                    facultyName: fldFacultyName.value.trim(),
                };

                try {
                    const res = await fetchJson(helpers.getMode() === 'add' ? URL_ADD : URL_EDIT, payload);
                    if (res.success) {
                        window.showToast(res.message, 'success');
                        if (helpers.getMode() === 'add') {
                            addRowToTables(payload);
                            undoStack.push({ action: 'delete', payload: { facultyId: payload.facultyId } });
                        } else {
                            updateRowInTables(payload, originalId);
                            if (snapshotData) {
                                undoStack.push({ 
                                    action: 'edit', 
                                    payload: { 
                                        oldFacultyId: payload.facultyId, 
                                        facultyId: snapshotData.facultyId, 
                                        facultyName: snapshotData.facultyName
                                    } 
                                });
                            }
                        }
                        snapshotData = { ...payload };
                        selectedId = payload.facultyId;
                        originalId = payload.facultyId;
                        helpers.setMode('edit');
                        highlightMiniRow(selectedId);
                    } else {
                        helpers.showAlert(res.message, 'danger');
                    }
                } catch (err) {
                    helpers.showAlert('Lỗi: ' + err.message, 'danger');
                }
            });

            // ── Nút Phục hồi ─────────────────────────────────────────
            btnPhucHoi.addEventListener('click', async () => {
                if (undoStack.length === 0) {
                    helpers.showAlert('Không có hành động nào để phục hồi.', 'info');
                    return;
                }
                await executeUndo();
                resetToView();
                helpers.showAlert('Đã hoàn tác 1 hành động.', 'warning');
            });

            // ── Nút Hủy ──────────────────────────────────────────────
            btnHuy?.addEventListener('click', resetToView);

            // ── Sửa / Xóa nhanh từ bảng chính ───────────────────────
            document.getElementById('facultyTableBody').addEventListener('click', e => {
                const editBtn = e.target.closest('.btn-edit-row');
                const delBtn = e.target.closest('.btn-delete-row');

                if (editBtn) {
                    const ds = editBtn.dataset;
                    bootstrap.Modal.getOrCreateInstance(modal).show();
                    setTimeout(() => {
                        populateFields(ds.id, ds.name, parseInt(ds.lecturerCount || '0'));
                        helpers.setMode('edit');
                        highlightMiniRow(ds.id);
                        helpers.hideAlert();
                    }, 200);
                }

                if (delBtn && !delBtn.disabled) {
                    showDeleteModal(delBtn.dataset.id, delBtn.dataset.name);
                }
            });

            // ── Helpers ──────────────────────────────────────────────

            function resetToView() {
                selectedId = null; snapshotData = null; originalId = null;
                clearFields(); helpers.clearValidation(); helpers.hideAlert(); deselectMiniRow();
                helpers.setMode('view');
            }

            function populateFields(id, name, lecturerCount = 0) {
                fldFacultyId.value = id;
                fldFacultyName.value = name;
                selectedId = id;
                originalId = id;
                snapshotData = { 
                    facultyId: id, 
                    facultyName: name,
                    lecturerCount: lecturerCount
                };

                const canDelete = lecturerCount === 0;
                btnXoa.disabled = !canDelete;
                btnXoa.classList.toggle('opacity-50', !canDelete);
                btnXoa.title = canDelete ? "Xóa khoa đang chọn" : `Không thể xóa vì còn ${lecturerCount} GV`;
            }

            function clearFields() {
                fldFacultyId.value = fldFacultyName.value = '';
            }

            function selectMiniRow(row) {
                deselectMiniRow();
                row.classList.add('table-active', 'fw-semibold');
                populateFields(row.dataset.id, row.dataset.name, parseInt(row.dataset.lecturerCount || '0'));
                helpers.setMode('edit');
                helpers.hideAlert();
            }

            function highlightMiniRow(id) {
                deselectMiniRow();
                const row = document.querySelector(`#miniFacultyBody tr[data-id="${CSS.escape(id)}"]`);
                if (row) row.classList.add('table-active', 'fw-semibold');
            }

            function deselectMiniRow() {
                document.querySelectorAll('#miniFacultyBody tr.table-active')
                    .forEach(r => r.classList.remove('table-active', 'fw-semibold'));
            }

            async function doDelete(id) {
                try {
                    // Save for undo before delete
                    const row = document.querySelector(`#facultyTableBody tr[data-id="${CSS.escape(id)}"]`);
                    const delPayload = row ? {
                        facultyId: row.dataset.id,
                        facultyName: row.dataset.name,
                        lecturerCount: row.dataset.lecturerCount || 0
                    } : null;

                    const res = await fetchJson(URL_DELETE, { facultyId: id });
                    if (res.success) {
                        removeRowFromTables(id);
                        // Only add to stack if we have delPayload and modal is shown
                        if (delPayload && modal.classList.contains('show')) {
                            undoStack.push({ action: 'add', payload: delPayload });
                        }
                        
                        resetToView();
                        window.showToast(res.message, 'success');
                    } else {
                        window.showToast(res.message, 'danger');
                    }
                } catch (err) { 
                    window.showToast('Lỗi: ' + err.message, 'danger'); 
                }
            }

            async function executeUndo() {
                if (undoStack.length === 0) return;
                const actionObj = undoStack.pop();
                try {
                    if (actionObj.action === 'add') {
                        await fetchJson(URL_ADD, actionObj.payload);
                        addRowToTables(actionObj.payload);
                    } else if (actionObj.action === 'edit') {
                        await fetchJson(URL_EDIT, actionObj.payload);
                        updateRowInTables(actionObj.payload, actionObj.payload.oldFacultyId);
                    } else if (actionObj.action === 'delete') {
                        await fetchJson(URL_DELETE, actionObj.payload);
                        removeRowFromTables(actionObj.payload.facultyId);
                    }
                } catch(err) {
                    window.showToast("Lỗi hoàn tác: " + err.message, "danger");
                }
            }

            function addRowToTables(p) {
                const tbody = document.getElementById('facultyTableBody');
                const empty = tbody.querySelector('td[colspan]');
                if (empty) empty.closest('tr').remove();
                
                const count = p.lecturerCount !== undefined ? p.lecturerCount : 0;
                tbody.insertAdjacentHTML('beforeend', mainRowHtml(p, count));
                document.getElementById('miniFacultyBody').insertAdjacentHTML('beforeend', miniRowHtml(p));
                updateCount(1);
            }

            function updateRowInTables(p, oldId) {
                const main = document.querySelector(`#facultyTableBody tr[data-id="${CSS.escape(oldId)}"]`);
                const lecturerCount = main ? (main.dataset.lecturerCount || 0) : 0;
                if (main) main.outerHTML = mainRowHtml(p, lecturerCount);
                const mini = document.querySelector(`#miniFacultyBody tr[data-id="${CSS.escape(oldId)}"]`);
                if (mini) mini.outerHTML = miniRowHtml(p);
            }

            function removeRowFromTables(id) {
                document.querySelector(`#facultyTableBody tr[data-id="${CSS.escape(id)}"]`)?.remove();
                document.querySelector(`#miniFacultyBody tr[data-id="${CSS.escape(id)}"]`)?.remove();
                updateCount(-1);
            }

            function updateCount(delta) {
                const el = document.getElementById('visibleCount');
                if (el) el.textContent = String(parseInt(el.textContent || '0', 10) + delta);
            }

            function mainRowHtml(p, lecturerCount = 0) {
                const canDelete = lecturerCount === 0;
                const deleteTooltip = canDelete ? "Xóa khoa này" : `Không thể xóa khoa vì còn ${lecturerCount} GV`;
                
                return `<tr data-id="${escapeHtml(p.facultyId)}" data-name="${escapeHtml(p.facultyName)}" data-lecturer-count="${lecturerCount}">
                        <td class="fw-semibold font-monospace text-primary">${escapeHtml(p.facultyId)}</td>
                        <td>${escapeHtml(p.facultyName)}</td>
                        <td>
                             <span class="badge text-primary bg-secondary-subtle border-primary border px-2">${lecturerCount}</span>
                        </td>
                        <td class="text-end">
                            <button class="btn btn-sm btn-outline-primary me-1 btn-edit-row shadow-sm hover-scale" title="Sửa"
                                    data-id="${escapeHtml(p.facultyId)}" data-name="${escapeHtml(p.facultyName)}" data-lecturer-count="${lecturerCount}">
                                <i class="bi bi-pencil"></i>
                            </button>
                            <button class="btn btn-sm btn-outline-danger ${canDelete ? 'btn-delete-row hover-scale' : 'opacity-50'} shadow-sm" 
                                    title="${deleteTooltip}"
                                    data-id="${escapeHtml(p.facultyId)}" data-name="${escapeHtml(p.facultyName)}"
                                    ${canDelete ? '' : 'disabled'}>
                                <i class="bi bi-trash"></i>
                            </button>
                        </td>
                    </tr>`;
            }

            function miniRowHtml(p, lecturerCount = 0) {
                return `<tr class="mini-row transition-base" role="button"
                                data-id="${escapeHtml(p.facultyId)}" data-name="${escapeHtml(p.facultyName)}" data-lecturer-count="${lecturerCount}">
                        <td class="fw-bold font-monospace text-primary small">${escapeHtml(p.facultyId)}</td>
                        <td class="small">${escapeHtml(p.facultyName)}</td>
                    </tr>`;
            }

            async function fetchJson(url, body) {
                const res = await fetch(url, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(body),
                });
                const json = await res.json();
                if (!res.ok && json.success !== false)
                    throw new Error(json.message ?? 'Lỗi máy chủ');
                return json;
            }

            // Client-side search
            document.getElementById('facultySearch')?.addEventListener('input', () => {
                const q = (document.getElementById('facultySearch')?.value ?? '').toLowerCase();
                let vis = 0;
                document.querySelectorAll('#facultyTableBody tr[data-id]').forEach(row => {
                    const match = !q || row.dataset.id.toLowerCase().includes(q) || (row.dataset.name ?? '').toLowerCase().includes(q);
                    row.style.display = match ? '' : 'none';
                    if (match) vis++;
                });
                const vc = document.getElementById('visibleCount');
                if (vc) vc.textContent = String(vis);
            });

        })();
    </script>
}
