@{
    ViewData["Title"] = "Trang chủ";
}

<div class="homepage-container">
    <div class="welcome-hero qldsv-card glass-panel shadow-xl border-0 overflow-hidden position-relative">
        <div class="hero-bg-accent"></div>
        <div class="container-fluid py-5 position-relative z-1">
            <div class="row align-items-center">
                <div class="col-lg-8 mx-auto text-center">
                    <span class="badge badge-status badge-info mb-3">Phiên bản mới</span>
                    <h1 class="display-5 fw-bold text-gradient text-wrap-balance mb-4">
                        Khám phá cổng thông tin QLDSV_HTC
                    </h1>
                    <p class="fs-5 text-muted text-wrap-balance mb-5">
                        Trải nghiệm hệ thống quản lý điểm chuyên nghiệp, nhanh chóng và mượt mà dành riêng cho sinh viên và giảng viên học viện.
                    </p>
                    
                    <div class="d-flex flex-wrap flex-column flex-sm-row justify-content-center gap-3">
                        <a class="btn-action btn-action-primary btn-lg shadow-sm" href="@RouteConstants.Account.LoginPath">
                            <i class="bi bi-person-circle" aria-hidden="true"></i> Đăng nhập hệ thống
                        </a>
                        <a class="btn-action btn-action-secondary btn-lg" href="#quick-reports">
                            <i class="bi bi-file-earmark-bar-graph" aria-hidden="true"></i> Xem báo cáo mẫu
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Reports Section -->
    <div id="quick-reports" class="mt-5 pt-3">
        <h2 class="h4 fw-bold mb-4 text-center">Tiện ích nội bộ</h2>
        <div class="row g-4 justify-content-center">
            
            <div class="col-md-6 col-lg-5">
                <div class="qldsv-card h-100 hover-elevate transition-base border-0 shadow-sm">
                    <div class="d-flex align-items-center gap-3 mb-3">
                        <div class="stat-icon bg-blue shadow-sm">
                            <i class="bi bi-file-earmark-pdf" aria-hidden="true"></i>
                        </div>
                        <div>
                            <h3 class="h6 fw-bold mb-1">Phiếu Điểm Cá Nhân</h3>
                            <p class="text-muted small mb-0">Xuất PDF phiếu điểm của sinh viên</p>
                        </div>
                    </div>
                    <p class="text-muted small mb-4">
                        Hỗ trợ xuất phiếu điểm cho sinh viên để đánh giá quá trình học tập chi tiết và đầy đủ thông tin.
                    </p>
                    <a class="btn-action btn-action-secondary w-100 justify-content-center" href="@RouteConstants.Report.GetGradesReportPath?maSV=N15DCCN001">
                        Xuất phiếu điểm N15DCCN001
                    </a>
                </div>
            </div>

            <div class="col-md-6 col-lg-5">
                <div class="qldsv-card h-100 hover-elevate transition-base border-0 shadow-sm">
                    <div class="d-flex align-items-center gap-3 mb-3">
                        <div class="stat-icon bg-green shadow-sm">
                            <i class="bi bi-file-earmark-spreadsheet" aria-hidden="true"></i>
                        </div>
                        <div>
                            <h3 class="h6 fw-bold mb-1">Danh Sách Lớp Tín Chỉ</h3>
                            <p class="text-muted small mb-0">Xuất báo cáo dưới dạng PDF</p>
                        </div>
                    </div>
                    <p class="text-muted small mb-4">
                        Hiển thị danh sách lớp tín chỉ của khoa theo niên khóa, học kỳ tương ứng.
                    </p>
                    <a class="btn-action btn-action-accent w-100 justify-content-center" href="@RouteConstants.Report.GetCreditClassListPath?nienKhoa=2021-2022&hocKy=1&khoaName=Công Nghệ Thông Tin&maKhoa=CNTT">
                        Xuất danh sách mẫu (CNTT)
                    </a>
                </div>
            </div>

        </div>
    </div>
</div>
