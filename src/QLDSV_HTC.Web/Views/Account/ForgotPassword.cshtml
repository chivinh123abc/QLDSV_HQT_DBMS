@model QLDSV_HTC.Web.Models.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Quên mật khẩu";
}

<div class="login-page">
    <div class="container">
        <div class="row align-items-center g-0">
            <!-- Left Side: Illustration or Info and Support Card -->
            <div class="col-lg-7 d-none d-lg-block">
                <div class="login-illustration pe-lg-5">
                    <div class="icon-circle mb-4 animate__animated animate__fadeIn">
                        <i class="bi bi-mortarboard-fill"></i>
                    </div>
                    <h2 class="display-4 fw-bold text-gradient mb-3">Hệ Thống <br />Quản Lý Đào Tạo</h2>
                    <p class="fs-5 text-muted-foreground max-w-md mb-4">
                        Cổng thông tin tích hợp dành cho sinh viên và giảng viên. Quản lý điểm, thời khóa biểu và đăng
                        ký tín chỉ một cách thông minh.
                    </p>

                    <!-- Support Card for Desktop -->
                    <div id="desktop-support-card" class="support-card animate__animated animate__fadeIn animate__delay-1 max-w-md">
                        <h5 class="fw-bold text-primary mb-3 d-flex align-items-center gap-2">
                            <i class="bi bi-info-circle-fill"></i> Hỗ Trợ Trực Tiếp
                        </h5>
                        <p class="small text-muted mb-3">
                            Vui lòng liên hệ trực tiếp <strong>Phòng Giáo vụ</strong> để được hỗ trợ cấp tài khoản hoặc khôi phục mật khẩu trực tiếp:
                        </p>
                        <div class="d-flex flex-column gap-2 small">
                            <div class="d-flex align-items-start gap-2">
                                <i class="bi bi-geo-alt-fill text-primary mt-1"></i>
                                <span><strong>Địa chỉ:</strong> 97 Man Thiện, P. Hiệp Phú, TP. Thủ Đức, TP. HCM (Cơ sở 2)</span>
                            </div>
                            <div class="d-flex align-items-start gap-2">
                                <i class="bi bi-telephone-fill text-primary mt-1"></i>
                                <span><strong>Điện thoại:</strong> (028) 3829 3829</span>
                            </div>
                            <div class="d-flex align-items-start gap-2">
                                <i class="bi bi-envelope-fill text-primary mt-1"></i>
                                <span><strong>Email:</strong> <a href="mailto:phonggiaovu@ptithcm.edu.vn" class="text-decoration-none hover-primary transition-base">phonggiaovu@ptithcm.edu.vn</a></span>
                            </div>
                            <div class="d-flex align-items-start gap-2">
                                <i class="bi bi-clock-fill text-primary mt-1"></i>
                                <span><strong>Giờ làm việc:</strong> Thứ 2 - Thứ 6<br/><span class="text-muted">(Sáng: 07:30 - 11:30 | Chiều: 13:30 - 17:00)</span></span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right Side: Forgot Password Form -->
            <div class="col-lg-5">
                <div class="login-card animate__animated animate__fadeInRight">
                    <div class="card-header border-0 bg-transparent text-center mb-4">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <a href="/account/login"
                                class="text-decoration-none text-muted small d-flex align-items-center gap-1 hover-primary transition-base">
                                <i class="bi bi-arrow-left"></i> Quay lại đăng nhập
                            </a>
                        </div>
                        <h1 class="h3 fw-bold text-primary mb-2">Quên mật khẩu?</h1>
                        <p class="text-muted small">Cung cấp tài khoản để đặt lại mật khẩu của bạn</p>
                    </div>



                    @if (ViewBag.ErrorMessage != null || TempData["ErrorMessage"] != null)
                    {
                        var errMsg = ViewBag.ErrorMessage ?? TempData["ErrorMessage"];
                        <div class="alert alert-danger border-0 shadow-sm mb-4 py-3 rounded-3 d-flex align-items-center gap-2"
                            role="alert">
                            <i class="bi bi-exclamation-triangle-fill text-danger"></i>
                            <span class="small fw-medium text-danger">@errMsg</span>
                        </div>
                    }

                    @if (ViewBag.SuccessMessage != null && ViewBag.ResetSuccess is true)
                    {
                        <!-- Step 3: Success Screen -->
                        <div class="alert alert-success border-0 shadow-sm mb-4 py-4 rounded-3 d-flex flex-column align-items-center text-center gap-3"
                            role="alert">
                            <i class="bi bi-check-circle-fill text-success" style="font-size: 3rem;"></i>
                            <div>
                                <h5 class="fw-bold text-success">Đặt lại thành công!</h5>
                                <p class="small text-muted mb-0">@ViewBag.SuccessMessage</p>
                            </div>
                            <a href="/account/login" class="btn btn-action btn-action-primary px-4 py-2 mt-2 w-100">
                                Đăng nhập ngay <i class="bi bi-box-arrow-in-right ms-1"></i>
                            </a>
                        </div>
                    }
                    else
                    {
                        <form asp-action="ForgotPassword" method="post" class="login-form">
                            <input type="hidden" asp-for="Step" />

                            @if (Model.Step == 1)
                            {
                                <!-- STEP 1: Enter Student ID -->
                                <input type="hidden" name="IsStudent" value="true" />

                                <div class="mb-4">
                                    <label id="lblLoginName" for="LoginName" class="form-label small fw-bold text-muted">Mã sinh viên</label>
                                    <div class="input-group-premium">
                                        <i class="bi bi-person input-icon text-muted"></i>
                                        <input asp-for="LoginName" id="LoginName" class="form-control-premium"
                                            placeholder="Nhập mã sinh viên (VD: N23DCCN067)..." required />
                                    </div>
                                    <span asp-validation-for="LoginName" class="text-danger small mt-1 d-block"></span>
                                </div>

                                <button type="submit"
                                    class="btn btn-action btn-action-primary w-100 py-3 fw-bold shadow-lg mt-2">
                                    Gửi mã xác nhận <i class="bi bi-arrow-right ms-2"></i>
                                </button>
                            }
                            else if (Model.Step == 2)
                            {
                                <!-- STEP 2: Input OTP & New Password -->
                                <input type="hidden" asp-for="LoginName" />
                                <input type="hidden" asp-for="IsStudent" />
                                <input type="hidden" asp-for="Email" />

                                @if ((ViewBag.SuccessMessage != null || ViewBag.EmailInfo != null) && ViewBag.ErrorMessage == null && TempData["ErrorMessage"] == null)
                                {
                                    var infoMsg = ViewBag.SuccessMessage ?? ViewBag.EmailInfo;
                                    <div class="alert alert-success border-0 shadow-sm mb-4 py-3 rounded-3 d-flex align-items-start gap-2" role="alert">
                                        <i class="bi bi-envelope-check-fill text-success mt-1"></i>
                                        <span class="small fw-medium text-success">@infoMsg</span>
                                    </div>
                                }

                                @if (ViewBag.SuccessMessage != null)
                                {
                                    <script>
                                        sessionStorage.setItem("otpCooldownTarget", Date.now() + 60000);
                                    </script>
                                }

                                <div class="mb-3">
                                    <label for="Otp" class="form-label small fw-bold text-muted">Mã xác nhận (OTP)</label>
                                    <div class="input-group-premium">
                                        <i class="bi bi-shield-check input-icon text-muted"></i>
                                        <input asp-for="Otp" id="Otp" class="form-control-premium text-center fw-bold"
                                            placeholder="••••••" maxlength="6" required />
                                    </div>
                                    <span asp-validation-for="Otp" class="text-danger small mt-1 d-block"></span>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="NewPassword" class="form-label small fw-bold text-muted">Mật khẩu mới</label>
                                    <div class="input-group-premium">
                                        <i class="bi bi-lock input-icon text-muted"></i>
                                        <input asp-for="NewPassword" type="password" id="NewPassword"
                                            class="form-control-premium pe-5" placeholder="Tối thiểu 8 ký tự..." required />
                                        <button class="btn btn-link position-absolute end-0 top-50 translate-middle-y text-muted p-3 text-decoration-none"
                                            type="button" id="toggleNewPassword">
                                            <i class="bi bi-eye"></i>
                                        </button>
                                    </div>
                                    <span asp-validation-for="NewPassword" class="text-danger small mt-1 d-block"></span>
                                </div>

                                <div class="mb-4">
                                    <label asp-for="ConfirmPassword" class="form-label small fw-bold text-muted">Xác nhận mật khẩu mới</label>
                                    <div class="input-group-premium">
                                        <i class="bi bi-shield-lock input-icon text-muted"></i>
                                        <input asp-for="ConfirmPassword" type="password" id="ConfirmPassword"
                                            class="form-control-premium pe-5" placeholder="Nhập lại mật khẩu mới..." required />
                                        <button class="btn btn-link position-absolute end-0 top-50 translate-middle-y text-muted p-3 text-decoration-none"
                                            type="button" id="toggleConfirmPassword">
                                            <i class="bi bi-eye"></i>
                                        </button>
                                    </div>
                                    <span asp-validation-for="ConfirmPassword" class="text-danger small mt-1 d-block"></span>
                                </div>

                                <button type="submit"
                                    class="btn btn-action btn-action-primary w-100 py-3 fw-bold shadow-lg mt-2">
                                    Đặt lại mật khẩu <i class="bi bi-check2-circle ms-2"></i>
                                </button>
                                
                                <div class="d-flex flex-column gap-2 align-items-center mt-3">
                                    <button type="submit" name="ResendOtp" value="true" formnovalidate class="btn btn-link text-decoration-none small text-primary fw-medium p-0 hover-primary transition-base border-0 bg-transparent">
                                        <i class="bi bi-arrow-counterclockwise me-1"></i> Gửi lại mã OTP mới
                                    </button>
                                    
                                    <a href="/account/forgot-password" class="text-decoration-none text-muted small hover-primary transition-base mt-1">
                                        <i class="bi bi-person-x me-1"></i> Nhập lại mã sinh viên khác
                                    </a>
                                </div>
                            }
                        </form>
                    }
                </div>

                <!-- Support Card for Mobile -->
                <div id="mobile-support-card" class="support-card d-block d-lg-none mt-4 animate__animated animate__fadeInUp">
                    <h5 class="fw-bold text-primary mb-3 d-flex align-items-center gap-2">
                        <i class="bi bi-info-circle-fill"></i> Hỗ Trợ Trực Tiếp
                    </h5>
                    <p class="small text-muted mb-3">
                        Vui lòng liên hệ trực tiếp <strong>Phòng Giáo vụ</strong> để được hỗ trợ cấp tài khoản hoặc khôi phục mật khẩu trực tiếp:
                    </p>
                    <div class="d-flex flex-column gap-2 small">
                        <div class="d-flex align-items-start gap-2">
                            <i class="bi bi-geo-alt-fill text-primary mt-1"></i>
                            <span><strong>Địa chỉ:</strong> 97 Man Thiện, P. Hiệp Phú, TP. Thủ Đức, TP. HCM (Cơ sở 2)</span>
                        </div>
                        <div class="d-flex align-items-start gap-2">
                            <i class="bi bi-telephone-fill text-primary mt-1"></i>
                            <span><strong>Điện thoại:</strong> (028) 3829 3829</span>
                        </div>
                        <div class="d-flex align-items-start gap-2">
                            <i class="bi bi-envelope-fill text-primary mt-1"></i>
                            <span><strong>Email:</strong> <a href="mailto:phonggiaovu@ptithcm.edu.vn" class="text-decoration-none hover-primary transition-base">phonggiaovu@ptithcm.edu.vn</a></span>
                        </div>
                        <div class="d-flex align-items-start gap-2">
                            <i class="bi bi-clock-fill text-primary mt-1"></i>
                            <span><strong>Giờ làm việc:</strong> Thứ 2 - Thứ 6<br/><span class="text-muted">(Sáng: 07:30 - 11:30 | Chiều: 13:30 - 17:00)</span></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // Chỉ dành cho sinh viên

            // Password visibility toggle logic
            const toggleNewPassword = document.getElementById('toggleNewPassword');
            const newPasswordInput = document.getElementById('NewPassword');

            if (toggleNewPassword && newPasswordInput) {
                toggleNewPassword.addEventListener('click', function () {
                    const type = newPasswordInput.getAttribute('type') === 'password' ? 'text' : 'password';
                    newPasswordInput.setAttribute('type', type);
                    this.innerHTML = type === 'password' ? '<i class="bi bi-eye"></i>' : '<i class="bi bi-eye-slash"></i>';
                });
            }

            const toggleConfirmPassword = document.getElementById('toggleConfirmPassword');
            const confirmPasswordInput = document.getElementById('ConfirmPassword');

            if (toggleConfirmPassword && confirmPasswordInput) {
                toggleConfirmPassword.addEventListener('click', function () {
                    const type = confirmPasswordInput.getAttribute('type') === 'password' ? 'text' : 'password';
                    confirmPasswordInput.setAttribute('type', type);
                    this.innerHTML = type === 'password' ? '<i class="bi bi-eye"></i>' : '<i class="bi bi-eye-slash"></i>';
                });
            }

            // Cooldown Timer for Resend OTP button (1 minute)
            const resendBtn = document.querySelector('button[name="ResendOtp"]');
            if (resendBtn) {
                function startCooldown() {
                    let cooldownTarget = sessionStorage.getItem("otpCooldownTarget");
                    if (!cooldownTarget) return;

                    cooldownTarget = parseInt(cooldownTarget, 10);
                    
                    function updateTimer() {
                        const remaining = Math.ceil((cooldownTarget - Date.now()) / 1000);
                        if (remaining > 0) {
                            resendBtn.disabled = true;
                            resendBtn.innerHTML = `<i class="bi bi-hourglass-split me-1"></i> Gửi lại mã OTP mới (${remaining}s)`;
                            setTimeout(updateTimer, 1000);
                        } else {
                            resendBtn.disabled = false;
                            resendBtn.innerHTML = `<i class="bi bi-arrow-counterclockwise me-1"></i> Gửi lại mã OTP mới`;
                            sessionStorage.removeItem("otpCooldownTarget");
                        }
                    }
                    updateTimer();
                }

                // Check and run cooldown on load
                startCooldown();
            }
        });
    </script>
}
