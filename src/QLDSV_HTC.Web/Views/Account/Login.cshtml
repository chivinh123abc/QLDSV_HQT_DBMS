@model QLDSV_HTC.Models.LoginViewModel
@{
    ViewData["Title"] = "Đăng nhập";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-4">
        <div class="card shadow border-0 rounded-4">
            <div class="card-body p-5">
                <h3 class="text-center mb-4 fw-bold text-primary">Đăng Nhập</h3>
                
                @if (ViewBag.ErrorMessage != null)
                {
                    <div class="alert alert-danger fade show" role="alert">
                        @ViewBag.ErrorMessage
                    </div>
                }

                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success fade show" role="alert">
                        @TempData["SuccessMessage"]
                    </div>
                }

                <form asp-action="Login" method="post">
                    <div class="mb-3">
                        <label asp-for="Username" class="form-label fw-semibold">Tài khoản</label>
                        <input asp-for="Username" class="form-control" placeholder="Mã số sinh viên/GV" required />
                    </div>
                    <div class="mb-4">
                        <label asp-for="Password" class="form-label fw-semibold">Mật khẩu</label>
                        <input asp-for="Password" type="password" class="form-control" placeholder="••••••••" required />
                    </div>
                    
                    <button type="submit" class="btn btn-primary w-100 py-3 fw-bold rounded-pill">
                        Xác Nhận
                    </button>
                </form>
            </div>
        </div>
        <p class="text-center mt-4 text-muted small">
            &copy; 2026 Hệ thống quản lý điểm
        </p>
    </div>
</div>
