@model QLDSV_HTC.Models.LoginViewModel
@{
    ViewData["Title"] = "Đăng nhập";
}

<div class="login-page">
    <div class="container">
        <div class="row align-items-center g-0">
            <!-- Left Side: Illustration or Info -->
            <div class="col-lg-7 d-none d-lg-block">
                <div class="login-illustration pe-lg-5">
                    <div class="icon-circle mb-4 animate__animated animate__fadeIn">
                        <i class="bi bi-mortarboard-fill"></i>
                    </div>
                    <h2 class="display-4 fw-bold text-gradient mb-3">Hệ Thống <br />Quản Lý Đào Tạo</h2>
                    <p class="fs-5 text-muted-foreground max-w-md">
                        Cổng thông tin tích hợp dành cho sinh viên và giảng viên. Quản lý điểm, thời khóa biểu và đăng
                        ký tín chỉ một cách thông minh.
                    </p>
                </div>
            </div>

            <!-- Right Side: Login Form -->
            <div class="col-lg-5">
                <div class="login-card animate__animated animate__fadeInRight">
                    <div class="card-header border-0 bg-transparent text-center mb-4">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <a href="/"
                                class="text-decoration-none text-muted small d-flex align-items-center gap-1 hover-primary transition-base">
                                <i class="bi bi-arrow-left"></i> Quay lại trang chủ
                            </a>
                        </div>
                        <h1 class="h3 fw-bold text-primary mb-2">Xin chào trở lại!</h1>
                        <p class="text-muted small">Vui lòng đăng nhập để tiếp tục</p>
                    </div>

                    @if (ViewBag.ErrorMessage != null)
                    {
                        <div class="alert alert-danger border-0 shadow-sm mb-4 py-3 rounded-pill d-flex align-items-center gap-2"
                            role="alert">
                            <i class="bi bi-exclamation-triangle-fill"></i>
                            <span class="small fw-medium">@ViewBag.ErrorMessage</span>
                        </div>
                    }

                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success border-0 shadow-sm mb-4 py-3 rounded-pill d-flex align-items-center gap-2"
                            role="alert">
                            <i class="bi bi-check-circle-fill"></i>
                            <span class="small fw-medium">@TempData["SuccessMessage"]</span>
                        </div>
                    }

                    <form asp-action="Login" method="post" class="login-form">
                        <!-- Role Selection Switchers -->
                        <div class="role-switch-group mb-4">
                            <input type="radio" class="btn-check role-switch" name="IsStudent" id="roleGV" value="false"
                            @(Model.IsStudent ? "" : "checked") autocomplete="off">
                            <label class="role-switch-btn" for="roleGV">Giảng viên / Quản trị</label>

                            <input type="radio" class="btn-check role-switch" name="IsStudent" id="roleSV" value="true"
                            @(Model.IsStudent ? "checked" : "") autocomplete="off">
                            <label class="role-switch-btn" for="roleSV">Sinh viên</label>
                        </div>

                        <div class="mb-3">
                            <label id="lblLoginName" for="LoginName" class="form-label small fw-bold text-muted">Tên
                                đăng nhập</label>
                            <div class="input-group-premium">
                                <i class="bi bi-person input-icon text-muted"></i>
                                <input asp-for="LoginName" id="LoginName" class="form-control-premium"
                                    placeholder="Nhập tên đăng nhập..." required />
                            </div>
                            <span asp-validation-for="LoginName" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Password" class="form-label small fw-bold text-muted">Mật khẩu</label>
                            <div class="input-group-premium">
                                <i class="bi bi-lock input-icon text-muted"></i>
                                <input asp-for="Password" type="password" id="Password"
                                    class="form-control-premium pe-5" placeholder="••••••••" />
                                <button
                                    class="btn btn-link position-absolute end-0 top-50 translate-middle-y text-muted p-3 text-decoration-none"
                                    type="button" id="togglePassword">
                                    <i class="bi bi-eye"></i>
                                </button>
                            </div>
                            <span asp-validation-for="Password" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="rememberMe">
                                <label class="form-check-label small text-muted" for="rememberMe">Ghi nhớ đăng
                                    nhập</label>
                            </div>
                            <a href="@RouteConstants.Home.ComingSoonPath"
                                class="small text-primary text-decoration-none fw-medium">Quên mật khẩu?</a>
                        </div>

                        <button type="submit"
                            class="btn btn-action btn-action-primary w-100 py-3 fw-bold shadow-lg mt-2">
                            Đăng nhập ngay <i class="bi bi-box-arrow-in-right ms-2 font-bold"></i>
                        </button>
                    </form>

                    <div class="mt-5 pt-3 border-top text-center">
                        <p class="text-muted small mb-0">Chưa có tài khoản? <a
                                href="@RouteConstants.Home.ComingSoonPath"
                                class="text-primary fw-bold text-decoration-none">Yêu cầu cấp tài khoản</a></p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const roleSwitches = document.querySelectorAll('.role-switch');
            const lblLoginName = document.getElementById('lblLoginName');
            const inputLoginName = document.getElementById('LoginName');

            roleSwitches.forEach(radio => {
                radio.addEventListener('change', function () {
                    if (this.value === 'true') {
                        // Nếu chọn Sinh viên
                        lblLoginName.innerText = 'Mã SV';
                        inputLoginName.placeholder = 'Nhập mã sinh viên (VD: N15DCCN001)...';
                    } else {
                        // Nếu chọn Giảng viên
                        lblLoginName.innerText = 'Tên đăng nhập';
                        inputLoginName.placeholder = 'Nhập tên đăng nhập giảng viên...';
                    }
                });
            });

            // Password visibility toggle logic
            const togglePassword = document.getElementById('togglePassword');
            const passwordInput = document.getElementById('Password');

            togglePassword.addEventListener('click', function () {
                const type = passwordInput.getAttribute('type') === 'password' ? 'text' : 'password';
                passwordInput.setAttribute('type', type);

                // Thay đổi icon mắt
                if (type === 'password') {
                    this.innerHTML = '<i class="bi bi-eye"></i>';
                } else {
                    this.innerHTML = '<i class="bi bi-eye-slash"></i>';
                }
            });
        });
    </script>
}
