@model QLDSV_HTC.Web.Models.LoginViewModel
@{
    ViewData["Title"] = "Đăng nhập";
}

<div class="login-page">
    <div class="container">
        <div class="row align-items-center g-0">
            <!-- Left Side: Illustration or Info -->
            <div class="col-lg-7 d-none d-lg-block">
                <div class="login-illustration pe-lg-5">
                    <div class="icon-circle mb-4 animate__animated animate__fadeIn">
                        <i class="bi bi-mortarboard-fill"></i>
                    </div>
                    <h2 class="display-4 fw-bold text-gradient mb-3">Hệ Thống <br />Quản Lý Đào Tạo</h2>
                    <p class="fs-5 text-muted-foreground max-w-md mb-4">
                        Cổng thông tin tích hợp dành cho sinh viên và giảng viên. Quản lý điểm, thời khóa biểu và đăng
                        ký tín chỉ một cách thông minh.
                    </p>

                    <!-- Support Card for Desktop -->
                    <div id="desktop-support-card" class="support-card animate__animated animate__fadeIn animate__delay-1 max-w-md">
                        <h5 class="fw-bold text-primary mb-3 d-flex align-items-center gap-2">
                            <i class="bi bi-info-circle-fill"></i> Hỗ Trợ & Quên Mật Khẩu
                        </h5>
                        <p class="small text-muted mb-3">
                            Vui lòng liên hệ trực tiếp <strong>Phòng Giáo vụ</strong> để được hỗ trợ cấp tài khoản hoặc khôi phục mật khẩu:
                        </p>
                        <div class="d-flex flex-column gap-2 small">
                            <div class="d-flex align-items-start gap-2">
                                <i class="bi bi-geo-alt-fill text-primary mt-1"></i>
                                <span><strong>Địa chỉ:</strong> 97 Man Thiện, P. Hiệp Phú, TP. Thủ Đức, TP. HCM (Cơ sở 2)</span>
                            </div>
                            <div class="d-flex align-items-start gap-2">
                                <i class="bi bi-telephone-fill text-primary mt-1"></i>
                                <span><strong>Điện thoại:</strong> (028) 3829 3829</span>
                            </div>
                            <div class="d-flex align-items-start gap-2">
                                <i class="bi bi-envelope-fill text-primary mt-1"></i>
                                <span><strong>Email:</strong> <a href="mailto:phonggiaovu@ptithcm.edu.vn" class="text-decoration-none hover-primary transition-base">phonggiaovu@ptithcm.edu.vn</a></span>
                            </div>
                            <div class="d-flex align-items-start gap-2">
                                <i class="bi bi-clock-fill text-primary mt-1"></i>
                                <span><strong>Giờ làm việc:</strong> Thứ 2 - Thứ 6<br/><span class="text-muted">(Sáng: 07:30 - 11:30 | Chiều: 13:30 - 17:00)</span></span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right Side: Login Form -->
            <div class="col-lg-5">
                <div class="login-card animate__animated animate__fadeInRight">
                    <div class="card-header border-0 bg-transparent text-center mb-4">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <a href="/"
                                class="text-decoration-none text-muted small d-flex align-items-center gap-1 hover-primary transition-base">
                                <i class="bi bi-arrow-left"></i> Quay lại trang chủ
                            </a>
                        </div>
                        <h1 class="h3 fw-bold text-primary mb-2">Xin chào trở lại!</h1>
                        <p class="text-muted small">Vui lòng đăng nhập để tiếp tục</p>
                    </div>

                    @if (ViewBag.ErrorMessage != null || TempData["ErrorMessage"] != null)
                    {
                        var errMsg = ViewBag.ErrorMessage ?? TempData["ErrorMessage"];
                        <div class="alert alert-danger border-0 shadow-sm mb-4 py-3 rounded-pill d-flex align-items-center gap-2"
                            role="alert">
                            <i class="bi bi-exclamation-triangle-fill"></i>
                            <span class="small fw-medium">@errMsg</span>
                        </div>
                    }

                    @if (ViewBag.SuccessMessage != null || TempData["SuccessMessage"] != null)
                    {
                        var successMsg = ViewBag.SuccessMessage ?? TempData["SuccessMessage"];
                        <div class="alert alert-success border-0 shadow-sm mb-4 py-3 rounded-pill d-flex align-items-center gap-2"
                            role="alert">
                            <i class="bi bi-check-circle-fill"></i>
                            <span class="small fw-medium">@successMsg</span>
                        </div>
                    }

                    <form asp-action="Login" method="post" class="login-form">
                        <!-- Role Selection Switchers -->
                        <div class="role-switch-group mb-4">
                            <input type="radio" class="btn-check role-switch" name="IsStudent" id="roleGV" value="false"
                            @(Model.IsStudent ? "" : "checked") autocomplete="off">
                            <label class="role-switch-btn" for="roleGV">Giảng viên / Quản trị</label>

                            <input type="radio" class="btn-check role-switch" name="IsStudent" id="roleSV" value="true"
                            @(Model.IsStudent ? "checked" : "") autocomplete="off">
                            <label class="role-switch-btn" for="roleSV">Sinh viên</label>
                        </div>

                        <div class="mb-3">
                            <label id="lblLoginName" for="LoginName" class="form-label small fw-bold text-muted">Tên
                                đăng nhập</label>
                            <div class="input-group-premium">
                                <i class="bi bi-person input-icon text-muted"></i>
                                <input asp-for="LoginName" id="LoginName" class="form-control-premium"
                                    placeholder="Nhập tên đăng nhập..." required />
                            </div>
                            <span asp-validation-for="LoginName" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Password" class="form-label small fw-bold text-muted">Mật khẩu</label>
                            <div class="input-group-premium">
                                <i class="bi bi-lock input-icon text-muted"></i>
                                <input asp-for="Password" type="password" id="Password"
                                    class="form-control-premium pe-5" placeholder="••••••••" />
                                <button
                                    class="btn btn-link position-absolute end-0 top-50 translate-middle-y text-muted p-3 text-decoration-none"
                                    type="button" id="togglePassword">
                                    <i class="bi bi-eye"></i>
                                </button>
                            </div>
                            <span asp-validation-for="Password" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="rememberMe">
                                <label class="form-check-label small text-muted" for="rememberMe">Ghi nhớ đăng
                                    nhập</label>
                            </div>
                            <a href="/account/forgot-password"
                                class="small text-primary text-decoration-none fw-medium">Quên mật khẩu?</a>
                        </div>

                        <button type="submit"
                            class="btn btn-action btn-action-primary w-100 py-3 fw-bold shadow-lg mt-2">
                            Đăng nhập ngay <i class="bi bi-box-arrow-in-right ms-2 font-bold"></i>
                        </button>
                    </form>
                </div>

                <!-- Support Card for Mobile -->
                <div id="mobile-support-card" class="support-card d-block d-lg-none mt-4 animate__animated animate__fadeInUp">
                    <h5 class="fw-bold text-primary mb-3 d-flex align-items-center gap-2">
                        <i class="bi bi-info-circle-fill"></i> Hỗ Trợ & Quên Mật Khẩu
                    </h5>
                    <p class="small text-muted mb-3">
                        Vui lòng liên hệ trực tiếp <strong>Phòng Giáo vụ</strong> để được hỗ trợ cấp tài khoản hoặc khôi phục mật khẩu:
                    </p>
                    <div class="d-flex flex-column gap-2 small">
                        <div class="d-flex align-items-start gap-2">
                            <i class="bi bi-geo-alt-fill text-primary mt-1"></i>
                            <span><strong>Địa chỉ:</strong> 97 Man Thiện, P. Hiệp Phú, TP. Thủ Đức, TP. HCM (Cơ sở 2)</span>
                        </div>
                        <div class="d-flex align-items-start gap-2">
                            <i class="bi bi-telephone-fill text-primary mt-1"></i>
                            <span><strong>Điện thoại:</strong> (028) 3829 3829</span>
                        </div>
                        <div class="d-flex align-items-start gap-2">
                            <i class="bi bi-envelope-fill text-primary mt-1"></i>
                            <span><strong>Email:</strong> <a href="mailto:phonggiaovu@ptithcm.edu.vn" class="text-decoration-none hover-primary transition-base">phonggiaovu@ptithcm.edu.vn</a></span>
                        </div>
                        <div class="d-flex align-items-start gap-2">
                            <i class="bi bi-clock-fill text-primary mt-1"></i>
                            <span><strong>Giờ làm việc:</strong> Thứ 2 - Thứ 6<br/><span class="text-muted">(Sáng: 07:30 - 11:30 | Chiều: 13:30 - 17:00)</span></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const roleSwitches = document.querySelectorAll('.role-switch');
            const lblLoginName = document.getElementById('lblLoginName');
            const inputLoginName = document.getElementById('LoginName');

            function updateLoginLabels() {
                const activeRadio = document.querySelector('.role-switch:checked');
                if (activeRadio && lblLoginName && inputLoginName) {
                    if (activeRadio.value === 'true') {
                        // Nếu chọn Sinh viên
                        lblLoginName.innerText = 'Mã SV';
                        inputLoginName.placeholder = 'Nhập mã sinh viên (VD: N23DCCN067)...';
                    } else {
                        // Nếu chọn Giảng viên
                        lblLoginName.innerText = 'Tên đăng nhập';
                        inputLoginName.placeholder = 'Nhập tên đăng nhập giảng viên...';
                    }
                }
            }

            roleSwitches.forEach(radio => {
                radio.addEventListener('change', updateLoginLabels);
            });

            // Khởi tạo nhãn và placeholder ngay khi tải trang dựa trên lựa chọn mặc định
            updateLoginLabels();

            // Password visibility toggle logic
            const togglePassword = document.getElementById('togglePassword');
            const passwordInput = document.getElementById('Password');

            togglePassword.addEventListener('click', function () {
                const type = passwordInput.getAttribute('type') === 'password' ? 'text' : 'password';
                passwordInput.setAttribute('type', type);

                // Thay đổi icon mắt
                if (type === 'password') {
                    this.innerHTML = '<i class="bi bi-eye"></i>';
                } else {
                    this.innerHTML = '<i class="bi bi-eye-slash"></i>';
                }
            });

            // Quên mật khẩu chuyển hướng trực tiếp tới trang riêng biệt
        });
    </script>
}
