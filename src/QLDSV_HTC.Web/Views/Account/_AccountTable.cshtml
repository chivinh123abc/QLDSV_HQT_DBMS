@model QLDSV_HTC.Web.Models.AccountManagementViewModel
@using QLDSV_HTC.Domain.Constants
@using QLDSV_HTC.Web.Models

@{
    ViewData["Title"] = "Quản lý Tài khoản & Phân quyền";
    var isPGV = Model.CurrentUserGroup == AppConstants.Groups.PGV;

    // ── Prepare Title Section ──
    ViewData["TitleSection"] = (Func<object, Microsoft.AspNetCore.Html.IHtmlContent>)(@<text>
        <div class="d-flex align-items-center gap-2">
            <div class="bg-primary bg-opacity-10 text-primary rounded-2 p-2 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                <i class="bi bi-shield-lock-fill fs-5"></i>
            </div>
            <div>
                <h5 class="mb-0 fw-bold text-dark">Quản lý Tài khoản</h5>
                <div class="text-muted small">Quản lý người dùng và phân quyền hệ thống</div>
            </div>
        </div>
        @if (isPGV)
        {
            <button class="btn btn-primary shadow-sm d-flex align-items-center gap-2 rounded-3 hover-scale px-3 ms-auto" 
                    id="btnOpenAccountForm" type="button" data-bs-toggle="modal" data-bs-target="#accountFormModal">
                <i class="bi bi-person-plus-fill"></i>
                <span class="fw-semibold">Cập nhật danh mục Tài khoản</span>
            </button>
        }
    </text>);

    var tableModel = new GenericTableViewModel
    {
        FiltersSection = @<text>
            <div class="d-flex flex-wrap gap-3 align-items-center w-100">
                <div class="glass-search flex-grow-1" style="min-width: 300px; max-width: 450px;">
                    <i class="bi bi-search search-icon"></i>
                    <input type="text" id="accountSearch" class="search-input" 
                           placeholder="Tìm tên đăng nhập, tên user, giảng viên…">
                    <button type="button" id="clearAccountSearch" class="clear-btn d-none" title="Xóa tìm kiếm">
                        <i class="bi bi-x-circle-fill"></i>
                    </button>
                </div>
                
                <div class="ms-auto d-flex align-items-center gap-2">
                    <div class="input-group input-group-sm rounded-pill overflow-hidden border shadow-sm" style="width: 200px;">
                        <span class="input-group-text bg-white border-0 ps-3">
                            <i class="bi bi-funnel text-primary opacity-75"></i>
                        </span>
                        <select class="form-select border-0 shadow-none fw-medium" id="groupFilter">
                            <option value="">Tất cả nhóm</option>
                            <option value="PGV">Nhóm PGV</option>
                            <option value="KHOA">Nhóm KHOA</option>
                        </select>
                    </div>
                </div>
            </div>
        </text>,

        HeadSection = @<text>
            <tr class="text-uppercase small fw-bold text-muted border-bottom-0">
                <th scope="col" class="ps-4" style="width: 200px">
                    <div class="d-flex align-items-center gap-2">
                        <i class="bi bi-person-badge text-primary"></i>Tên đăng nhập
                    </div>
                </th>
                <th scope="col" style="width: 180px">
                    <div class="d-flex align-items-center gap-2">
                        <i class="bi bi-database text-primary"></i>Tên User (DB)
                    </div>
                </th>
                <th scope="col" style="width: 150px">
                    <div class="d-flex align-items-center gap-2">
                        <i class="bi bi-shield-check text-primary"></i>Nhóm quyền
                    </div>
                </th>
                <th scope="col" style="width: 140px">
                    <div class="d-flex align-items-center gap-2">
                        <i class="bi bi-hash text-primary"></i>Mã GV
                    </div>
                </th>
                <th scope="col">
                    <div class="d-flex align-items-center gap-2">
                        <i class="bi bi-person-vcard text-primary"></i>Giảng viên
                    </div>
                </th>
                <th scope="col" class="text-end pe-4" style="width: 140px">
                    <div class="d-flex align-items-center justify-content-end">
                        <i class="bi bi-lightning-charge text-primary"></i>Thao tác
                    </div>
                </th>
            </tr>
        </text>,

        BodySection = @<text>
            @if (!Model.Accounts.Any())
            {
                <tr>
                    <td colspan="6" class="text-center py-5 border-0">
                        <div class="animate__animated animate__fadeIn py-5">
                            <div class="icon-box-lg bg-light rounded-circle d-inline-flex align-items-center justify-content-center mb-3 shadow-sm">
                                <i class="bi bi-shield-slash text-body-tertiary fs-1"></i>
                            </div>
                            <h5 class="text-dark fw-bold mb-2">Chưa có tài khoản nào</h5>
                            <p class="text-muted small mx-auto" style="max-width: 320px;">
                                Hệ thống chưa ghi nhận tài khoản người dùng nào.
                            </p>
                        </div>
                    </td>
                </tr>
            }
            else
            {
                @foreach (var a in Model.Accounts)
                {
                    <tr data-login="@a.LoginName" data-user="@a.UserName" data-group="@a.GroupName"
                        data-gv-id="@(a.LecturerId ?? "")" data-gv-name="@(a.LecturerFullName ?? "")"
                        class="hover-row transition-base animate__animated animate__fadeIn">
                        <td class="ps-4">
                            <span class="fw-bold font-monospace text-primary bg-primary bg-opacity-10 px-2 py-1 rounded small border border-primary border-opacity-10 shadow-sm">
                                @a.LoginName
                            </span>
                        </td>
                        <td class="fw-medium text-dark">@a.UserName</td>
                        <td>
                            @{
                                var badgeClass = a.GroupName switch
                                {
                                    "PGV" => "bg-info-subtle text-info border-info-subtle",
                                    "KHOA" => "bg-primary-subtle text-primary border-primary-subtle",
                                    _ => "bg-secondary-subtle text-secondary border-secondary-subtle"
                                };
                            }
                            <span class="badge @badgeClass border px-3 py-1 rounded-pill shadow-xs small">@a.GroupName</span>
                        </td>
                        <td class="fw-medium font-monospace text-muted">@(a.LecturerId ?? "—")</td>
                        <td>
                            @if (!string.IsNullOrEmpty(a.LecturerFullName))
                            {
                                <div class="d-flex align-items-center gap-2">
                                    <div class="avatar-xs bg-light rounded-circle d-flex align-items-center justify-content-center border" style="width: 24px; height: 24px;">
                                        <i class="bi bi-person-fill text-muted" style="font-size: 0.75rem;"></i>
                                    </div>
                                    <span class="fw-medium">@a.LecturerFullName</span>
                                </div>
                            }
                            else
                            {
                                <span class="text-muted fst-italic small">Không liên kết</span>
                            }
                        </td>
                        <td class="text-end pe-4">
                            <div class="d-flex justify-content-end gap-1">
                                <button class="btn btn-sm btn-outline-primary btn-edit-row shadow-none hover-scale rounded-3" 
                                        title="Chỉnh sửa tài khoản"
                                        data-login="@a.LoginName" data-user="@a.UserName" data-group="@a.GroupName"
                                        data-gv-id="@(a.LecturerId ?? "")" data-gv-name="@(a.LecturerFullName ?? "")">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                @if (isPGV)
                                {
                                    <button class="btn btn-sm btn-outline-danger btn-delete-row shadow-none hover-scale rounded-3" 
                                            title="Xóa tài khoản"
                                            data-login="@a.LoginName" data-user="@a.UserName">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                }
                            </div>
                        </td>
                    </tr>
                }
            }
        </text>,

        FooterSection = @<text>
            <div class="d-flex align-items-center justify-content-between w-100 px-3 py-1">
                <div class="text-muted small d-flex align-items-center gap-2">
                    <i class="bi bi-info-circle-fill text-primary opacity-75"></i>
                    <span>
                        Hiển thị <strong id="visibleCount" class="text-primary tabular-nums">@Model.Accounts.Count()</strong>
                        / <span class="tabular-nums">@Model.Accounts.Count()</span> tài khoản người dùng
                    </span>
                </div>
                
                <div class="d-none d-md-flex align-items-center gap-2 text-muted small bg-light px-3 py-1 rounded-pill border shadow-xs">
                    <i class="bi bi-lightbulb text-warning"></i>
                    <span>Sử dụng thanh tìm kiếm hoặc lọc theo nhóm để quản lý nhanh hơn.</span>
                </div>
            </div>
        </text>
    };

    ViewData["TableId"] = "accountTable";
    ViewData["TableBodyId"] = "accountTableBody";
}

@await Html.PartialAsync("_CardTableWrapper", tableModel, ViewData)

@* ═══════════════════════════════════════════════════════
   MODAL: Nhập danh mục tài khoản / Xác nhận xóa
   (Placed outside to avoid nesting issues in _CardTableWrapper)
═══════════════════════════════════════════════════════ *@
@await Html.PartialAsync("_AccountFormModal", Model)

@section Scripts {
    <script src="~/js/form-helpers.js" asp-append-version="true"></script>
    <script>
        (function () {
            'use strict';

            const URL_ADD = '@RouteConstants.Account.AddPath';
            const URL_EDIT = '@RouteConstants.Account.EditPath';
            const URL_DELETE = '@RouteConstants.Account.DeletePath';
            const CURRENT_GROUP = '@Model.CurrentUserGroup';
            const CURRENT_LOGIN_NAME = '@Html.Raw(User.FindFirst(AppConstants.SessionKeys.Username)?.Value)';

            let snapshotData = null;
            let selectedLogin = null;
            let originalLogin = null;

            // -- UNDO STACK STATE --
            let undoStack = [];
            let forceClose = false;
            let isSubmitting = false;

            const modalEl = document.getElementById('accountFormModal');
            let accountModalInstance = null;
            if (modalEl) {
                accountModalInstance = bootstrap.Modal.getOrCreateInstance(modalEl);
            }

            const fldLecturer = document.getElementById('fldLecturer');
            const fldLecturerId = document.getElementById('fldAccLecturerId');
            const fldLoginName = document.getElementById('fldLoginName');
            const fldPassword = document.getElementById('fldPassword');
            const fldRole = document.getElementById('fldRole');

            const btnThem = document.getElementById('btnAccountFormThem');
            const btnXoa = document.getElementById('btnAccountFormXoa');
            const btnGhi = document.getElementById('btnAccountFormGhi');
            const btnPhucHoi = document.getElementById('btnAccountFormPhucHoi');
            const btnHuy = document.getElementById('btnAccountFormHuy');

            const helpers = createFormHelpers({
                alertEl: document.getElementById('accFormAlert'),
                modeLabelEl: document.getElementById('accFormModeLabel'),
                buttons: { them: btnThem, xoa: btnXoa, ghi: btnGhi, phucHoi: btnPhucHoi, huy: btnHuy },
                allFields: [fldLecturer, fldLoginName, fldPassword, fldRole],
                requiredFields: [fldLoginName, fldPassword],
                getSelectedId: () => selectedLogin,
            });

            if (!modalEl) return;

            const btnCancelModal = modalEl.querySelector('.btn-cancel-modal');
            const btnSaveModal = modalEl.querySelector('.btn-save-modal');

            // Mở modal → reset
            document.getElementById('btnOpenAccountForm')?.addEventListener('click', resetToView);

            // Mở modal → clear stack
            modalEl.addEventListener('show.bs.modal', () => {
                undoStack = [];
                forceClose = false;
            });

            // Chặn đóng modal nếu còn stack
            modalEl.addEventListener('hide.bs.modal', async (e) => {
                if (undoStack.length > 0 && !forceClose) {
                    e.preventDefault();
                    const isConfirmed = await window.showConfirmDialog(
                        "Xác nhận Thoát",
                        "Dữ liệu đã được <b>Ghi</b> vào hệ thống. Nếu đóng cửa sổ, bạn sẽ không thể dùng chức năng 'Phục hồi' (Undo) cho các thao tác vừa rồi.<br><br>Bạn có chắc chắn muốn thoát?",
                        { confirmText: "Xác nhận Thoát", cancelText: "Trở lại", isDanger: true }
                    );
                    if (isConfirmed) {
                        forceClose = true;
                        accountModalInstance.hide();
                    }
                }
            });

            btnSaveModal?.addEventListener('click', async () => {
                const message = undoStack.length > 0 
                    ? "Dữ liệu đã được <b>Ghi</b> vào hệ thống. Nếu đóng cửa sổ, bạn sẽ không thể dùng chức năng 'Phục hồi' (Undo) cho các thao tác vừa rồi.<br><br>Bạn có chắc chắn muốn thoát?"
                    : "Bạn có chắc chắn muốn đóng cửa sổ không?";
                
                const isConfirmed = await window.showConfirmDialog(
                    "Xác nhận Thoát", message,
                    { confirmText: "Xác nhận", cancelText: "Trở lại" }
                );
                
                if (isConfirmed) {
                    undoStack = [];
                    forceClose = true;
                    accountModalInstance.hide();
                }
            });

            btnCancelModal?.addEventListener('click', async () => {
                const isDanger = undoStack.length > 0;
                const message = isDanger
                    ? "Hành động này sẽ <b>Hoàn Tác toàn bộ</b> các thay đổi bạn vừa thực hiện trong phiên này.<br>Bạn có chắc chắn muốn xóa bỏ công sức vừa làm?"
                    : "Bạn chưa thực hiện thay đổi nào cần hoàn tác.<br>Đóng cửa sổ ngay bây giờ?";
                
                const isConfirmed = await window.showConfirmDialog(
                    "Hoàn Tác & Đóng", message,
                    { confirmText: isDanger ? "Xác nhận Hoàn tác" : "Đóng cửa sổ", cancelText: "Giữ lại", isDanger: isDanger }
                );

                if (isConfirmed) {
                    btnCancelModal.disabled = true;
                    while(undoStack.length > 0) {
                        await executeUndo();
                    }
                    undoStack = [];
                    forceClose = true;
                    btnCancelModal.disabled = false;
                    accountModalInstance.hide();
                }
            });

            modalEl.addEventListener('hidden.bs.modal', resetToView);

            // Chọn hàng mini-table
            document.getElementById('miniAccountBody')?.addEventListener('click', e => {
                if (helpers.getMode() === 'add') return;
                const row = e.target.closest('tr.mini-row');
                if (!row) return;
                selectMiniRow(row);
            });

            // ── Combo box chọn giảng viên → auto-fill ──
            if (fldLecturer) {
                fldLecturer.addEventListener('change', function () {
                    const opt = this.options[this.selectedIndex];
                    if (fldLecturerId) fldLecturerId.value = opt.value || '';
                    // Auto-fill login name = MAGV (suggestion)
                    if (fldLoginName && helpers.getMode() === 'add' && opt.value) {
                        fldLoginName.value = opt.value;
                    }
                });
            }

            // ── Nút Thêm ──
            btnThem.addEventListener('click', () => {
                deselectMiniRow();
                selectedLogin = null;
                snapshotData = null;
                clearFields();
                helpers.clearValidation();
                helpers.setMode('add');
                // Show add-only fields
                toggleAddFields(true);
                fldLoginName.disabled = false;
                fldLoginName.focus();
                helpers.showAlert('Nhập thông tin tài khoản mới rồi nhấn <b>Ghi</b> để lưu.', 'info');
            });

            // ── Nút Xóa ──
            btnXoa?.addEventListener('click', () => {
                if (!selectedLogin || isSubmitting) return;
                doDelete(selectedLogin);
            });

            // ── Nút Ghi ──
            btnGhi?.addEventListener('click', async () => {
                if (isSubmitting) return;
                const mode = helpers.getMode();

                let tempPassword = null;
                if (mode === 'edit' && !fldPassword.value.trim()) {
                    tempPassword = 'bypass_validation';
                    fldPassword.value = tempPassword;
                }

                let isValid = helpers.validateForm();
                if (mode === 'edit') {
                    isValid = true;
                    helpers.clearValidation();
                }

                if (tempPassword) {
                    fldPassword.value = ''; // Khôi phục lại
                }

                if (!isValid) return;

                isSubmitting = true;
                btnGhi.disabled = true;
                
                let url, payload;

                if (mode === 'add') {
                    payload = {
                        loginName: fldLoginName.value.trim(),
                        password: fldPassword.value,
                        userName: fldLecturerId?.value.trim() || fldLoginName.value.trim(),
                        role: fldRole.value,
                    };
                    url = URL_ADD;
                } else {
                    payload = {
                        oldLoginName: originalLogin,
                        newLoginName: fldLoginName.value.trim() !== snapshotData.loginName ? fldLoginName.value.trim() : null,
                        newPassword: fldPassword.value,
                        newUserName: fldLecturerId?.value.trim() !== snapshotData.userName ? fldLecturerId?.value.trim() : null,
                        newRole: fldRole.value !== snapshotData.group ? fldRole.value : null
                    };
                    url = URL_EDIT;
                }

                try {
                    const res = await fetchJson(url, payload);

                    if (res.forceLogout === true) {
                        window.showToast(res.message || "Mật khẩu của bạn đã thay đổi. Đang đăng xuất...", 'warning');
                        setTimeout(() => {
                            window.location.href = '@Url.Action("Login", "Account")';
                        }, 1500);
                        return;
                    }

                    if (res.success) {
                        window.showToast(res.message, 'success');
                        if (mode === 'add') {
                            addRowToTable(payload);
                            undoStack.push({ action: 'delete', payload: { loginName: payload.loginName } });
                            
                            snapshotData = { ...payload, group: payload.role };
                            selectedLogin = payload.loginName;
                            originalLogin = payload.loginName;
                            helpers.setMode('edit');
                            highlightMiniRow(selectedLogin);
                        } else {
                            if (res.message !== "Không có thay đổi nào được thực hiện.") {
                                const newPayload = { ...snapshotData };
                                if (payload.newLoginName) newPayload.loginName = payload.newLoginName;
                                if (payload.newUserName) newPayload.userName = payload.newUserName;
                                if (payload.newRole) newPayload.group = payload.newRole;
                                newPayload.role = newPayload.group;
                                
                                updateRowInTable(newPayload, originalLogin);
                                
                                undoStack.push({ 
                                    action: 'edit', 
                                    payload: {
                                        oldLoginName: newPayload.loginName,
                                        newLoginName: snapshotData.loginName,
                                        newPassword: '', 
                                        newUserName: snapshotData.userName,
                                        newRole: snapshotData.group
                                    } 
                                });
                                
                                snapshotData = { ...newPayload, role: newPayload.group };
                                selectedLogin = newPayload.loginName;
                                originalLogin = newPayload.loginName;
                            }
                            helpers.setMode('edit');
                            highlightMiniRow(selectedLogin);
                        }
                    } else {
                        helpers.showAlert(res.message, 'danger');
                    }
                } catch (err) {
                    helpers.showAlert('Lỗi: ' + err.message, 'danger');
                } finally {
                    isSubmitting = false;
                    btnGhi.disabled = false;
                }
            });

            // ── Nút Phục hồi ──
            btnPhucHoi?.addEventListener('click', async () => {
                if (undoStack.length === 0 || isSubmitting) {
                    helpers.showAlert('Không có hành động nào để phục hồi.', 'info');
                    return;
                }
                await executeUndo();
                resetToView();
                helpers.showAlert('Đã hoàn tác hành động vừa rồi.', 'warning');
            });

            // ── Nút Hủy ──
            btnHuy?.addEventListener('click', resetToView);

            // ── Thao tác trên bảng chính ──
            document.getElementById('accountTableBody').addEventListener('click', e => {
                const editBtn = e.target.closest('.btn-edit-row');
                const delBtn = e.target.closest('.btn-delete-row');

                if (editBtn) {
                    const ds = editBtn.dataset;
                    accountModalInstance?.show();
                    setTimeout(() => {
                        populateForEdit(ds.login, ds.user, ds.group, ds.gvId, ds.gvName);
                        helpers.setMode('edit');
                        highlightMiniRow(ds.login);
                        helpers.hideAlert();
                    }, 200);
                }

                if (delBtn) {
                    doDelete(delBtn.dataset.login);
                }
            });

            // ── Helpers ──

            function resetToView() {
                selectedLogin = null; snapshotData = null; originalLogin = null;
                clearFields(); helpers.clearValidation(); helpers.hideAlert(); deselectMiniRow();
                helpers.setMode('view');
                toggleAddFields(false);
            }

            function toggleAddFields(show) {
                const reqPasswordStar = document.getElementById('reqPasswordStar');
                fldLoginName.disabled = false;
                if(fldLecturer) fldLecturer.disabled = false;
                if(fldRole) fldRole.disabled = false;

                if (!show && helpers.getMode() === 'edit') {
                    if(reqPasswordStar) reqPasswordStar.style.display = 'none';
                    fldPassword.placeholder = "Bỏ trống nếu không muốn đổi mật khẩu";
                } else {
                    if(reqPasswordStar) reqPasswordStar.style.display = '';
                    fldPassword.placeholder = "Nhập mật khẩu";
                }
            }

            function populateForEdit(login, user, group, gvId, gvName) {
                fldLoginName.value = login;
                fldPassword.value = '';
                if (fldRole) fldRole.value = group;
                if (fldLecturerId) fldLecturerId.value = gvId || '';
                if (fldLecturer) fldLecturer.value = gvId || '';
                selectedLogin = login;
                originalLogin = login;
                snapshotData = { loginName: login, userName: user, group: group };
                
                fldLoginName.disabled = false;
                fldPassword.disabled = false;
                if (fldLecturer) fldLecturer.disabled = false;
                if (fldRole) fldRole.disabled = false;
                
                const reqPasswordStar = document.getElementById('reqPasswordStar');
                if(reqPasswordStar) reqPasswordStar.style.display = 'none';
                fldPassword.placeholder = "Bỏ trống nếu không muốn đổi mật khẩu";
            }

            function clearFields() {
                fldLoginName.value = '';
                fldPassword.value = '';
                if (fldRole) fldRole.value = '';
                if (fldLecturer) fldLecturer.value = '';
                if (fldLecturerId) fldLecturerId.value = '';
            }

            function selectMiniRow(row) {
                deselectMiniRow();
                row.classList.add('table-active', 'fw-semibold');
                const ds = row.dataset;
                populateForEdit(ds.login, ds.user, ds.group, ds.gvId, ds.gvName);
                helpers.setMode('edit');
                
                if (ds.login.toLowerCase() === CURRENT_LOGIN_NAME.toLowerCase()) {
                    fldLoginName.disabled = true;
                    if (fldRole) fldRole.disabled = true;
                    btnXoa.disabled = true;
                    btnXoa.title = "Không thể xóa chính mình";
                    helpers.showAlert(`Đang sửa tài khoản <b>${escapeHtml(ds.login)}</b> (của bạn). Bạn chỉ được đổi Mật khẩu / Giảng viên.`, 'warning');
                } else {
                    btnXoa.title = "Xóa tài khoản đang chọn";
                    helpers.showAlert(`Đang sửa tài khoản <b>${escapeHtml(ds.login)}</b>. Bỏ trống mật khẩu nếu không muốn đổi.`, 'info');
                }
            }

            function highlightMiniRow(login) {
                deselectMiniRow();
                const row = document.querySelector(`#miniAccountBody tr[data-login="${CSS.escape(login)}"]`);
                if (row) row.classList.add('table-active', 'fw-semibold');
            }

            function deselectMiniRow() {
                document.querySelectorAll('#miniAccountBody tr.table-active')
                    .forEach(r => r.classList.remove('table-active', 'fw-semibold'));
            }

            async function doDelete(login) {
                const isConfirmed = await window.showConfirmDialog(
                    "Xác nhận xóa tài khoản",
                    `Bạn có chắc chắn muốn xóa tài khoản <b>${login}</b>?<br>Thuộc tính này không thể khôi phục tự động theo Stack.`,
                    { confirmText: "Xóa", cancelText: "Hủy", isDanger: true }
                );
                
                if (!isConfirmed) return;

                isSubmitting = true;
                try {
                    const row = document.querySelector(`#accountTableBody tr[data-login="${CSS.escape(login)}"]`);
                    const delPayload = row ? {
                        loginName: row.dataset.login,
                        userName: row.dataset.gvId || row.dataset.user,
                        role: row.dataset.group
                    } : null;

                    const res = await fetchJson(URL_DELETE, { loginName: login });
                    if (res.success) {
                        removeRowFromTable(login);
                        
                        if (delPayload && modalEl.classList.contains('show')) {
                            // Cẩn thận: Tạo một password mặc định
                            delPayload.password = "123456"; 
                            undoStack.push({ action: 'add', payload: delPayload });
                        }
                        
                        resetToView();
                        window.showToast(res.message, 'success');
                    } else {
                        window.showToast(res.message, 'danger');
                    }
                } catch (err) {
                    window.showToast('Lỗi: ' + err.message, 'danger');
                } finally {
                    isSubmitting = false;
                }
            }

            async function executeUndo() {
                if (undoStack.length === 0) return;
                isSubmitting = true;
                const actionObj = undoStack.pop();
                try {
                    if (actionObj.action === 'add') {
                        await fetchJson(URL_ADD, actionObj.payload);
                        addRowToTable(actionObj.payload);
                    } else if (actionObj.action === 'edit') {
                        // For edit undo
                        if (actionObj.payload.newPassword === '') {
                            actionObj.payload.newPassword = null;
                        }
                        await fetchJson(URL_EDIT, actionObj.payload);
                        
                        const newPayload = { 
                            loginName: actionObj.payload.newLoginName || actionObj.payload.oldLoginName,
                            userName: actionObj.payload.newUserName,
                            role: actionObj.payload.newRole 
                        };
                        updateRowInTable(newPayload, actionObj.payload.oldLoginName);
                    } else if (actionObj.action === 'delete') {
                        await fetchJson(URL_DELETE, actionObj.payload);
                        removeRowFromTable(actionObj.payload.loginName);
                    }
                } catch(err) {
                    window.showToast("Lỗi hoàn tác: " + err.message, "danger");
                } finally {
                    isSubmitting = false;
                }
            }

            // ── DOM helpers ──

            function updateRowInTable(p, oldLogin) {
                const gvName = getGvNameFromCombo(p.userName);
                const main = document.querySelector(`#accountTableBody tr[data-login="${CSS.escape(oldLogin)}"]`);
                if (main) main.outerHTML = mainRowHtml(p, gvName);
                const mini = document.querySelector(`#miniAccountBody tr[data-login="${CSS.escape(oldLogin)}"]`);
                if (mini) mini.outerHTML = miniRowHtml(p, gvName);
            }

            function addRowToTable(p) {
                const tbody = document.getElementById('accountTableBody');
                const empty = tbody.querySelector('td[colspan]');
                if (empty) empty.closest('tr').remove();

                const gvName = getGvNameFromCombo(p.userName);
                tbody.insertAdjacentHTML('beforeend', mainRowHtml(p, gvName));
                document.getElementById('miniAccountBody')?.insertAdjacentHTML('beforeend', miniRowHtml(p, gvName));
                updateCount(1);
            }

            function removeRowFromTable(login) {
                document.querySelector(`#accountTableBody tr[data-login="${CSS.escape(login)}"]`)?.remove();
                document.querySelector(`#miniAccountBody tr[data-login="${CSS.escape(login)}"]`)?.remove();
                updateCount(-1);
            }

            function updateCount(delta) {
                const el = document.getElementById('visibleCount');
                if (el) el.textContent = String(parseInt(el.textContent || '0', 10) + delta);
            }

            function getGvNameFromCombo(userId) {
                if (!fldLecturer) return '';
                const opt = fldLecturer.querySelector(`option[value="${userId}"]`);
                return opt ? opt.textContent : '';
            }

            function mainRowHtml(p, gvName) {
                const group = p.role || '';
                const badgeClass = group === 'PGV' ? 'bg-info-subtle text-info border-info-subtle'
                    : group === 'KHOA' ? 'bg-primary-subtle text-primary border-primary-subtle'
                    : 'bg-secondary-subtle text-secondary border-secondary-subtle';
                const isPGVUser = CURRENT_GROUP === 'PGV';

                return `<tr data-login="${escapeHtml(p.loginName)}" data-user="${escapeHtml(p.userName)}" data-group="${escapeHtml(group)}"
                            data-gv-id="${escapeHtml(p.userName)}" data-gv-name="${escapeHtml(gvName)}"
                            class="hover-row transition-base animate__animated animate__fadeIn">
                        <td class="ps-4">
                            <span class="fw-bold font-monospace text-primary bg-primary bg-opacity-10 px-2 py-1 rounded small border border-primary border-opacity-10 shadow-sm">
                                ${escapeHtml(p.loginName)}
                            </span>
                        </td>
                        <td class="fw-medium text-dark">${escapeHtml(p.userName)}</td>
                        <td><span class="badge ${badgeClass} border px-3 py-1 rounded-pill shadow-xs small">${escapeHtml(group)}</span></td>
                        <td class="fw-medium font-monospace text-muted">${escapeHtml(p.userName)}</td>
                        <td>
                            ${gvName ? `<div class="d-flex align-items-center gap-2">
                                <div class="avatar-xs bg-light rounded-circle d-flex align-items-center justify-content-center border" style="width: 24px; height: 24px;">
                                    <i class="bi bi-person-fill text-muted" style="font-size: 0.75rem;"></i>
                                </div>
                                <span class="fw-medium">${escapeHtml(gvName)}</span>
                            </div>` : '<span class="text-muted fst-italic small">Không liên kết</span>'}
                        </td>
                        <td class="text-end pe-4">
                            <div class="d-flex justify-content-end gap-1">
                                <button class="btn btn-sm btn-outline-primary shadow-none hover-scale rounded-3 btn-edit-row" title="Sửa"
                                        data-login="${escapeHtml(p.loginName)}" data-user="${escapeHtml(p.userName)}" data-group="${escapeHtml(group)}"
                                        data-gv-id="${escapeHtml(p.userName)}" data-gv-name="${escapeHtml(gvName)}">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                ${isPGVUser ? `<button class="btn btn-sm btn-outline-danger shadow-none hover-scale rounded-3 btn-delete-row" title="Xóa"
                                        data-login="${escapeHtml(p.loginName)}" data-user="${escapeHtml(p.userName)}">
                                    <i class="bi bi-trash"></i>
                                </button>` : ''}
                            </div>
                        </td>
                    </tr>`;
            }

            function miniRowHtml(p, gvName) {
                const group = p.role || '';
                const badgeClass = group === 'PGV' ? 'bg-info-subtle text-info border-info-subtle'
                    : 'bg-primary-subtle text-primary border-primary-subtle';

                return `<tr class="mini-row transition-base" role="button"
                            data-login="${escapeHtml(p.loginName)}" data-user="${escapeHtml(p.userName)}" data-group="${escapeHtml(group)}"
                            data-gv-id="${escapeHtml(p.userName)}" data-gv-name="${escapeHtml(gvName)}">
                        <td class="fw-bold font-monospace text-primary small">${escapeHtml(p.loginName)}</td>
                        <td class="small fw-medium">${escapeHtml(p.userName)}</td>
                        <td><span class="badge ${badgeClass} border small px-2">${escapeHtml(group)}</span></td>
                    </tr>`;
            }

            async function fetchJson(url, body) {
                const res = await fetch(url, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(body),
                });
                const json = await res.json();
                if (!res.ok && json.success !== false)
                    throw new Error(json.message ?? 'Lỗi máy chủ');
                return json;
            }

            function escapeHtml(text) {
                if (!text) return '';
                const div = document.createElement('div');
                div.textContent = text;
                return div.innerHTML;
            }

            // ── Client-side search + nhóm filter ──
            ['accountSearch', 'groupFilter'].forEach(id => {
                document.getElementById(id)?.addEventListener('input', applyFilters);
                document.getElementById(id)?.addEventListener('change', applyFilters);
            });

            function applyFilters() {
                const q = (document.getElementById('accountSearch')?.value ?? '').toLowerCase();
                const group = document.getElementById('groupFilter')?.value ?? '';
                let vis = 0;
                document.querySelectorAll('#accountTableBody tr[data-login]').forEach(row => {
                    const match =
                        (!q || row.dataset.login.toLowerCase().includes(q)
                            || row.dataset.user.toLowerCase().includes(q)
                            || (row.dataset.gvName || '').toLowerCase().includes(q)) &&
                        (!group || row.dataset.group === group);
                    row.style.display = match ? '' : 'none';
                    if (match) vis++;
                });
                const vc = document.getElementById('visibleCount');
                if (vc) vc.textContent = String(vis);
            }

            // Clear search
            const clearBtn = document.getElementById('clearAccountSearch');
            const searchInput = document.getElementById('accountSearch');
            if (searchInput && clearBtn) {
                searchInput.addEventListener('input', () => {
                    clearBtn.classList.toggle('d-none', !searchInput.value);
                });
                clearBtn.addEventListener('click', () => {
                    searchInput.value = '';
                    clearBtn.classList.add('d-none');
                    applyFilters();
                    searchInput.focus();
                });
            }

        })();
    </script>
}
