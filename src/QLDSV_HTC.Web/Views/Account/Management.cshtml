@{
    ViewData["Title"] = "Quản lý Tài khoản & Phân quyền";
}

<div class="dashboard-container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0 text-gray-800">Tài khoản & Phân quyền</h1>
        <button class="btn btn-primary shadow-sm">
            <i class="bi bi-person-plus me-2"></i> Tạo tài khoản
        </button>
    </div>

    <div class="qldsv-card border-0 shadow-sm">
        <div class="table-responsive p-3">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th scope="col">Tên đăng nhập</th>
                        <th scope="col">Họ tên người dùng</th>
                        <th scope="col">Nhóm quyền</th>
                        <th scope="col">Trạng thái</th>
                        <th scope="col" class="text-end">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td class="fw-medium">AD</td>
                        <td>Admin N1</td>
                        <td><span class="badge badge-info text-bg-info">PGV</span></td>
                        <td><span class="badge text-bg-success">Hoạt động</span></td>
                        <td class="text-end">
                            <button class="btn btn-sm btn-outline-warning me-1" title="Đặt lại mật khẩu"><i class="bi bi-key"></i></button>
                            <button class="btn btn-sm btn-outline-primary me-1"><i class="bi bi-pencil"></i></button>
                            <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                        </td>
                    </tr>
                    <tr>
                        <td class="fw-medium">khoaCNTT</td>
                        <td>Ban chủ nhiệm khoa CNTT</td>
                        <td><span class="badge badge-primary text-bg-primary">KHOA</span></td>
                        <td><span class="badge text-bg-success">Hoạt động</span></td>
                        <td class="text-end">
                            <button class="btn btn-sm btn-outline-warning me-1" title="Đặt lại mật khẩu"><i class="bi bi-key"></i></button>
                            <button class="btn btn-sm btn-outline-primary me-1"><i class="bi bi-pencil"></i></button>
                            <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
