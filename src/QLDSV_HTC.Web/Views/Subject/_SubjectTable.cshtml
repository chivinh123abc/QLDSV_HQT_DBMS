@model QLDSV_HTC.Web.Models.SubjectManagementViewModel
@using QLDSV_HTC.Web.Models

@{
    var isPGV = (bool)(ViewData["isPGV"] ?? false);

    // ── Prepare Title Section ──
    ViewData["TitleSection"] = (Func<object, Microsoft.AspNetCore.Html.IHtmlContent>)(@<text>
        <div class="d-flex align-items-center gap-2">
            <div class="bg-primary bg-opacity-10 text-primary rounded-2 p-2 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                <i class="bi bi-journal-bookmark-fill fs-5"></i>
            </div>
            <div>
                <h5 class="mb-0 fw-bold text-dark">Quản lý Môn học</h5>
                <div class="text-muted small">Cập nhật danh mục môn học toàn hệ thống</div>
            </div>
        </div>
        <div class="ms-auto d-flex gap-2">
            @if (isPGV)
            {
                <button class="btn btn-primary shadow-sm d-flex align-items-center gap-2 rounded-3 hover-scale px-3" 
                        id="btnOpenSubjectForm" type="button" data-bs-toggle="modal" data-bs-target="#subjectFormModal">
                    <i class="bi bi-plus-circle-fill"></i>
                    <span class="fw-semibold">Cập nhật Danh mục</span>
                </button>
            }
        </div>
    </text>);
    
    var tableModel = new GenericTableViewModel
    {
        FiltersSection = @<text>
            <div class="d-flex flex-wrap align-items-center gap-3 w-100">
                <div class="glass-search flex-grow-1" style="max-width: 450px;">
                    <i class="bi bi-search search-icon"></i>
                    <input type="text" id="subjectSearch" class="search-input" 
                           placeholder="Tìm mã hoặc tên môn học..." value="@Model.SearchTerm">
                    <button class="clear-btn d-none" type="button" id="btnClearSearch" title="Xóa tìm kiếm">
                        <i class="bi bi-x-circle-fill"></i>
                    </button>
                </div>

                <div class="ms-auto text-muted small d-none d-md-flex align-items-center gap-2 bg-white px-3 py-2 rounded-pill shadow-sm border">
                    <i class="bi bi-info-circle text-primary"></i>
                    <span>
                        Hiển thị <strong id="visibleCount" class="text-primary tabular-nums">@Model.Subjects.Count()</strong> môn học
                    </span>
                </div>
            </div>
        </text>,
        
        HeadSection = @<text>
            <tr class="text-uppercase small fw-bold text-muted border-bottom-0">
                <th scope="col" class="ps-4" style="width: 150px;">
                    <div class="d-flex align-items-center">
                        <i class="bi bi-hash me-2 text-primary"></i>Mã MH
                    </div>
                </th>
                <th scope="col">
                    <div class="d-flex align-items-center">
                        <i class="bi bi-journal-text me-2 text-primary"></i>Tên môn học
                    </div>
                </th>
                <th scope="col" class="text-center" style="width: 140px;">
                    <div class="d-flex align-items-center justify-content-center">
                        <i class="bi bi-person-video3 me-2 text-primary"></i>Lý thuyết
                    </div>
                </th>
                <th scope="col" class="text-center" style="width: 140px;">
                    <div class="d-flex align-items-center justify-content-center">
                        <i class="bi bi-laptop me-2 text-primary"></i>Thực hành
                    </div>
                </th>
                @if (isPGV)
                {
                    <th scope="col" class="text-end pe-4" style="width: 120px;">
                        <div class="d-flex align-items-center justify-content-end">
                            <i class="bi bi-lightning-charge me-2 text-primary"></i>Thao tác
                        </div>
                    </th>
                }
            </tr>
        </text>,
        
        BodySection = @<text>
            @if (!Model.Subjects.Any())
            {
                <tr>
                    <td colspan="@(isPGV ? 5 : 4)" class="text-center py-5 border-0">
                        <div class="animate__animated animate__fadeIn py-5">
                            <div class="icon-box-lg bg-light rounded-circle d-inline-flex align-items-center justify-content-center mb-3">
                                <i class="bi bi-book text-body-tertiary fs-1"></i>
                            </div>
                            <h5 class="text-dark fw-bold mb-2">Không tìm thấy môn học nào</h5>
                            <p class="text-muted small mx-auto" style="max-width: 300px;">
                                Thử thay đổi từ khóa tìm kiếm hoặc kiểm tra lại bộ lọc.
                            </p>
                        </div>
                    </td>
                </tr>
            }
            else
            {
                @foreach (var s in Model.Subjects)
                {
                    <tr class="hover-row animate__animated animate__fadeIn transition-base" 
                        data-id="@s.Id" data-name="@s.Name" data-theory="@s.TheoryHours" data-practice="@s.PracticeHours">
                        <td class="ps-4">
                            <span class="badge bg-primary-subtle text-primary border border-primary-subtle px-2 py-1 rounded-pill shadow-sm font-monospace tabular-nums">
                                @s.Id
                            </span>
                        </td>
                        <td>
                            <div class="fw-bold text-dark mb-1">@s.Name</div>
                            <div class="small text-muted d-flex align-items-center gap-2 opacity-75">
                                <i class="bi bi-clock-history"></i>
                                <span>Tổng: <strong class="text-dark">@(s.TheoryHours + s.PracticeHours)</strong> tiết</span>
                            </div>
                        </td>
                        <td class="text-center">
                            <span class="badge bg-info-subtle text-info border border-info-subtle tabular-nums rounded-pill px-3 py-1 shadow-sm">@s.TheoryHours</span>
                        </td>
                        <td class="text-center">
                            <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle tabular-nums rounded-pill px-3 py-1 shadow-sm">@s.PracticeHours</span>
                        </td>
                        @if (isPGV)
                        {
                            <td class="text-end pe-4">
                                <div class="d-flex justify-content-end gap-1">
                                    <button class="btn btn-sm btn-outline-primary btn-edit-row shadow-none hover-scale rounded-3" 
                                            title="Sửa môn học"
                                            data-id="@s.Id" data-name="@s.Name" data-theory="@s.TheoryHours" data-practice="@s.PracticeHours">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                    <button class="btn btn-sm btn-outline-danger btn-delete-row shadow-none hover-scale rounded-3" 
                                            title="Xóa môn học"
                                            data-id="@s.Id" data-name="@s.Name">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            </td>
                        }
                    </tr>
                }
            }
        </text>,
        
        FooterSection = @<text>
            <div class="d-flex align-items-center justify-content-between w-100 px-3 py-1">
                <div class="text-muted small d-flex align-items-center gap-2">
                    <i class="bi bi-info-circle-fill text-primary opacity-75"></i>
                    <span>
                        Hiển thị <strong id="visibleCount" class="text-primary tabular-nums">@Model.Subjects.Count()</strong>
                        / <span class="tabular-nums">@Model.Pagination.TotalCount</span> môn học
                    </span>
                </div>
                
                @await Html.PartialAsync("_PaginationControls", Model.Pagination)
            </div>
        </text>
    };

    ViewData["TableId"] = "subjectTable";
    ViewData["TableBodyId"] = "subjectTableBody";
}

@await Html.PartialAsync("_CardTableWrapper", tableModel, ViewData)

