@using QLDSV_HTC.Domain.Constants

@{
    var currentPath = Context.Request.Path.Value?.TrimEnd('/') ?? "";
    var group = User.FindFirst(AppConstants.SessionKeys.Group)?.Value ?? "";
    var isStudent = group == "SV";
}

<aside class="app-sidebar" id="appSidebar">
    <!-- Brand -->
    <div class="sidebar-brand">
        <h2>QLDSV_HTC</h2>
        <p>@(isStudent ? "Cổng thông tin sinh viên" : "Quản lý điểm sinh viên")</p>
    </div>

    <!-- Navigation -->
    <nav class="sidebar-nav" aria-label="Main Navigation">
        <ul>
            @if (isStudent)
            {
                <li>
                    <a class="nav-link @(currentPath == "" || currentPath == "/" ? "active" : "")" href="@RouteConstants.Home.HomePath">
                        <i class="bi bi-speedometer2"></i> Dashboard
                    </a>
                </li>
                <li>
                    <a class="nav-link @(currentPath.Contains("/student/schedule") ? "active" : "")" href="@RouteConstants.Student.SchedulePath">
                        <i class="bi bi-calendar-week"></i> Lịch học
                    </a>
                </li>
                <li>
                    <a class="nav-link @(currentPath.Contains("/student/grades") ? "active" : "")" href="@RouteConstants.Student.GradesPath">
                        <i class="bi bi-award"></i> Xem điểm
                    </a>
                </li>
                <li>
                    <a class="nav-link @(currentPath.Contains("/registration") ? "active" : "")" href="@RouteConstants.Registration.RegistrationPath">
                        <i class="bi bi-file-earmark-text"></i> Đăng ký học phần
                    </a>
                </li>
            }
            else
            {
                <li>
                    <a class="nav-link @(currentPath == "" || currentPath == "/" ? "active" : "")" href="@RouteConstants.Home.HomePath">
                        <i class="bi bi-speedometer2"></i> Dashboard
                    </a>
                </li>
                @if (group == "PGV")
                {
                    <li>
                        <a class="nav-link @(currentPath.Contains("/class") ? "active" : "")" href="@RouteConstants.Class.ClassPath">
                            <i class="bi bi-people"></i> Lớp
                        </a>
                    </li>
                }
                <li>
                    <a class="nav-link @(currentPath.Contains("/student") ? "active" : "")" href="@RouteConstants.Student.StudentPath">
                        <i class="bi bi-mortarboard"></i> Sinh viên
                    </a>
                </li>
                <li>
                    <a class="nav-link @(currentPath.Contains("/subject") ? "active" : "")" href="@RouteConstants.Subject.SubjectPath">
                        <i class="bi bi-book"></i> Môn học
                    </a>
                </li>
                <li>
                    <a class="nav-link @(currentPath.Contains("/lecturer") ? "active" : "")" href="@RouteConstants.Lecturer.LecturerPath">
                        <i class="bi bi-person-badge"></i> Giảng viên
                    </a>
                </li>
                <li>
                    <a class="nav-link @(currentPath.Contains("/credit-class") ? "active" : "")" href="@RouteConstants.CreditClass.CreditClassPath">
                        <i class="bi bi-clipboard-check"></i> Lớp tín chỉ
                    </a>
                </li>
                @if (group == "PGV")
                {
                    <li>
                        <a class="nav-link @(currentPath.Contains("/registration") ? "active" : "")" href="@RouteConstants.Registration.RegistrationPath">
                            <i class="bi bi-file-earmark-text"></i> Đăng ký tín chỉ
                        </a>
                    </li>
                }
                <li>
                    <a class="nav-link @(currentPath.Contains("/grade") && !currentPath.Contains("grades") ? "active" : "")" href="@RouteConstants.Grade.GradePath">
                        <i class="bi bi-bar-chart-line"></i> Nhập điểm
                    </a>
                </li>
                <li>
                    <a class="nav-link @(currentPath.Contains("/report") ? "active" : "")" href="@RouteConstants.Report.ReportPath">
                        <i class="bi bi-bar-chart-line"></i> Báo cáo / In ấn
                    </a>
                </li>
                @if (group == "PGV")
                {
                    <li>
                        <a class="nav-link @(currentPath.Contains("/account/management") ? "active" : "")" href="@RouteConstants.Account.ManagementPath">
                            <i class="bi bi-gear"></i> Tài khoản / Phân quyền
                        </a>
                    </li>
                }
            }
        </ul>
    </nav>

    <!-- Footer -->
    <div class="sidebar-footer">
        <div class="sidebar-roles">
            <span class="role-badge role-pgv @(group == "PGV" ? "active" : "")">PGV</span>
            <span class="role-badge role-khoa @(group == "KHOA" ? "active" : "")">KHOA</span>
            <span class="role-badge role-sv @(group == "SV" ? "active" : "")">SV</span>
        </div>
        <form asp-controller="Account" asp-action="Logout" method="post">
            <button type="submit" class="sidebar-logout" aria-label="Đăng xuất khỏi hệ thống">
                <i class="bi bi-box-arrow-left" aria-hidden="true"></i> Đăng xuất
            </button>
        </form>
    </div>
</aside>
