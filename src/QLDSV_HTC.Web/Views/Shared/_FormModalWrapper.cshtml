@* _FormModalWrapper.cshtml *@
@model QLDSV_HTC.Web.Models.GenericFormModalViewModel

@{
    var modalId = ViewData["ModalId"] ?? "formModal";
    var labelId = ViewData["ModalLabelId"] ?? "formModalLabel";
}

<div class="modal fade" id="@modalId" tabindex="-1" aria-labelledby="@labelId" aria-hidden="true"
    data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-dialog-centered modal-lg modal-dialog-scrollable animate__animated animate__zoomIn">
        <div class="modal-content border-0 shadow-lg overflow-hidden glass-morphism">

            @* Modal Header *@
            <div class="modal-header bg-primary text-white py-3 border-0 shadow-sm">
                <div class="d-flex align-items-center gap-2">
                    <i class="bi @(ViewData["ModalIcon"] ?? "bi-pencil-square") fs-5"></i>
                    <h5 class="modal-title fw-bold mb-0" id="@labelId">
                        @ViewData["ModalTitle"]
                    </h5>
                    @if (Model.ModeBadgeSection != null)
                    {
                        @Model.ModeBadgeSection(null)
                    }
                </div>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"
                    aria-label="Close"></button>
            </div>

            @* Modal Body *@
            <div class="modal-body p-4 bg-white">
                @* CRUD Toolbar area - "Docked" style like the reference *@
                @if (Model.ToolbarSection != null)
                {
                    <div class="d-flex flex-wrap gap-2 mb-4 p-3 bg-white rounded-3 border shadow-sm hover-elevate">
                        @Model.ToolbarSection(null)
                    </div>
                }

                @* Alert Banner area *@
                <div id="@(ViewData["AlertId"] ?? "formAlert")"
                    class="alert d-none align-items-center gap-2 animate__animated animate__fadeIn mb-4" role="alert"></div>

                @* The actual Form fields *@
                <form id="@(ViewData["FormId"] ?? "form")" novalidate autocomplete="off">
                    @if (Model.BodySection != null)
                    {
                        @Model.BodySection(null)
                    }
                </form>

                @* Optional extra content (like a list/table inside the modal) *@
                @if (Model.ExtraBodySection != null)
                {
                    <div class="modal-list-container mt-5">
                        @Model.ExtraBodySection(null)
                    </div>
                }
            </div>

            @* Modal Footer *@
            <div class="modal-footer bg-light py-3 border-top d-flex justify-content-end gap-2">
                <button type="button" class="btn btn-danger px-4 btn-cancel-modal"
                    title="Hoàn tác mọi thay đổi trong phiên và đóng">
                    Hoàn tác tất cả
                </button>
                <button type="button" class="btn btn-primary px-4 btn-save-modal"
                    title="Đóng cửa sổ (dữ liệu đã được Ghi vào hệ thống)">
                    Thoát
                </button>
            </div>

        </div>
    </div>
</div>
