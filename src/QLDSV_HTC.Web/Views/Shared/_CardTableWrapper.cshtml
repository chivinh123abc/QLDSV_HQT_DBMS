@* _CardTableWrapper.cshtml *@
@model QLDSV_HTC.Web.Models.GenericTableViewModel

@{
    var tableId = ViewData["TableId"] ?? "genericTable";
    var bodyId = ViewData["TableBodyId"] ?? "genericTableBody";
}

<div class="qldsv-card border-0 shadow-sm overflow-hidden animate__animated animate__fadeIn">
    @* --- Header Title & Actions --- *@
    @if (ViewData["TitleSection"] != null || ViewData["Title"] != null)
    {
        <div class="card-header bg-white py-3 d-flex flex-wrap justify-content-between align-items-center gap-3 border-bottom">
            @if (ViewData["TitleSection"] is Func<object?, Microsoft.AspNetCore.Html.IHtmlContent> titleSectionDelegate)
            {
                @titleSectionDelegate(null)
            }
            else if (ViewData["TitleSection"] is Microsoft.AspNetCore.Html.IHtmlContent htmlContent)
            {
                @htmlContent
            }
            else
            {
                <h5 class="mb-0 fw-bold text-primary">
                    @ViewData["Title"]
                </h5>
            }
        </div>
    }

    @* --- Search & Filters area --- *@
    @if (Model.FiltersSection != null)
    {
        <div class="p-3 border-bottom d-flex align-items-center gap-3 bg-light-subtle">
            @Model.FiltersSection(null)
        </div>
    }

    @* --- Data Table --- *@
    <div class="table-responsive p-3">
        <table class="table table-hover align-middle mb-0" id="@tableId">
            <thead class="table-light">
                @if (Model.HeadSection != null)
                {
                    @Model.HeadSection(null)
                }
            </thead>
            <tbody id="@bodyId">
                @if (Model.BodySection != null)
                {
                    @Model.BodySection(null)
                }
            </tbody>
        </table>
    </div>

    @* --- Footer area --- *@
    @if (Model.FooterSection != null)
    {
        <div class="p-3 border-top d-flex justify-content-between align-items-center bg-light-subtle">
            @Model.FooterSection(null)
        </div>
    }
</div>
