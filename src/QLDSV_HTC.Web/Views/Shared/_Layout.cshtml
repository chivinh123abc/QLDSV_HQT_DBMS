<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#2563eb" />
    <title>@ViewData["Title"] - QLDSV_HTC</title>
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet" />
    <!-- Chart.js (for Dashboard) -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @* <link rel="stylesheet" href="~/QLDSV_HTC.Web.styles.css" asp-append-version="true" /> *@
    @await RenderSectionAsync("Styles", required: false)
</head>
@{
    var isAuthenticated = User.Identity?.IsAuthenticated ?? false;
}

<body>
    <a href="#main-content" class="skip-to-main-content">Bỏ qua để đến nội dung chính</a>
    <div class="app-layout @(isAuthenticated ? "" : "is-unauthenticated")">
        @if (isAuthenticated)
        {
            <!-- SIDEBAR PARTIAL -->
            <partial name="_Sidebar" />
        }

        <div class="app-main">
            @if (isAuthenticated)
            {
                <!-- HEADER PARTIAL -->
                <partial name="_Header" />
            }

            <main id="main-content" class="app-content" tabindex="-1">
                @RenderBody()
            </main>
        </div>
    </div>

    <!-- MODAL PARTIAL -->
    <partial name="_Modal" />
    <partial name="_GlobalConfirmModal" />

    <!-- TOAST PARTIAL -->
    <partial name="_Toast" />

    <!-- Bootstrap JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <!-- Custom JS -->
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        // Sidebar toggle logic for mobile
        document.addEventListener('DOMContentLoaded', function () {
            var toggleBtn = document.getElementById('sidebarToggle');
            var sidebar = document.getElementById('appSidebar');

            if (toggleBtn && sidebar) {
                toggleBtn.addEventListener('click', function () {
                    sidebar.classList.toggle('show');
                });
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>
