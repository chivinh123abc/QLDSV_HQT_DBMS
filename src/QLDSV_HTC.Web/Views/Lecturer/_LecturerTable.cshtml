@model QLDSV_HTC.Web.Models.LecturerManagementViewModel
@using QLDSV_HTC.Web.Models

@{
    var isPGV = (bool)(ViewData["isPGV"] ?? false);
    var hasFaculty = (bool)(ViewData["hasFaculty"] ?? false);
    
    var tableModel = new GenericTableViewModel
    {
        FiltersSection = @<text>
            <div class="input-group" style="max-width:340px">
                <span class="input-group-text bg-white border-end-0">
                    <i class="bi bi-search text-muted"></i>
                </span>
                <input type="text" id="lecturerSearch" class="form-control border-start-0"
                       placeholder="Tìm mã hoặc tên giảng viên…">
            </div>
            @if (!hasFaculty && Model.Faculties.Any())
            {
                <select id="facultyFilter" class="form-select" style="max-width:300px">
                    <option value="">— Tất cả khoa —</option>
                    @foreach (var f in Model.Faculties)
                    {
                        <option value="@f.Id?.Trim()">@f.Name (@f.Id?.Trim())</option>
                    }
                </select>
            }
        </text>,
        
        HeadSection = @<text>
            <tr>
                <th scope="col" style="width:130px">Mã GV</th>
                <th scope="col">Họ và Tên</th>
                <th scope="col" style="width:120px">Học Vị</th>
                <th scope="col" style="width:120px">Học Hàm</th>
                <th scope="col" style="width:150px">Chuyên Môn</th>
                <th scope="col" style="width:100px">Khoa</th>
                @if (isPGV)
                {
                    <th scope="col" class="text-end" style="width:120px">Hành động</th>
                }
            </tr>
        </text>,
        
        BodySection = @<text>
            @if (!Model.Lecturers.Any())
            {
                <tr>
                    <td colspan="7" class="text-center text-muted py-5">
                        <i class="bi bi-person-x fs-2 d-block mb-2"></i>
                        Chưa có giảng viên nào.
                    </td>
                </tr>
            }
            else
            {
                @foreach (var l in Model.Lecturers)
                {
                    <tr data-id="@l.Id?.Trim()" data-first="@l.FirstName" data-last="@l.LastName"
                        data-degree="@l.Degree" data-rank="@l.Rank" data-spec="@l.Specialty"
                        data-faculty="@l.FacultyId?.Trim()" data-faculty-filter="@l.FacultyId?.Trim()">
                        <td class="fw-semibold font-monospace text-primary">@l.Id?.Trim()</td>
                        <td class="fw-medium">@l.FirstName @l.LastName</td>
                        <td>@l.Degree</td>
                        <td>@l.Rank</td>
                        <td class="text-truncate" style="max-width: 150px;" title="@l.Specialty">@l.Specialty</td>
                        <td>
                            <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle px-2">
                                @l.FacultyId?.Trim()
                            </span>
                        </td>
                        @if (isPGV)
                        {
                            <td class="text-end">
                                <button class="btn btn-sm btn-outline-primary me-1 btn-edit-row shadow-sm hover-scale"
                                        title="Sửa giảng viên"
                                        data-id="@l.Id?.Trim()" data-first="@l.FirstName" data-last="@l.LastName"
                                        data-degree="@l.Degree" data-rank="@l.Rank" data-spec="@l.Specialty"
                                        data-faculty="@l.FacultyId?.Trim()">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-danger btn-delete-row shadow-sm hover-scale"
                                        title="Xóa giảng viên"
                                        data-id="@l.Id?.Trim()" data-first="@l.FirstName" data-last="@l.LastName">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </td>
                        }
                    </tr>
                }
            }
        </text>,
        
        FooterSection = @<text>
            <div class="d-flex align-items-center w-100">
                <span class="text-muted small me-auto">
                    Hiển thị <strong id="visibleCount">@Model.Lecturers.Count()</strong>
                    / @Model.Pagination.TotalCount giảng viên
                </span>
                
                @await Html.PartialAsync("_PaginationControls", Model.Pagination)
            </div>
        </text>
    };

    ViewData["TableId"] = "lecturerTable";
    ViewData["TableBodyId"] = "lecturerTableBody";
}

@await Html.PartialAsync("_CardTableWrapper", tableModel, ViewData)
