@{
    ViewData["Title"] = "Quản lý Giảng viên";
}

<div class="dashboard-container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0 text-gray-800">Danh sách Giảng viên</h1>
        <button class="btn btn-primary shadow-sm">
            <i class="bi bi-person-plus-fill me-2"></i> Thêm Giảng viên
        </button>
    </div>

    <!-- Filter/Search -->
    <div class="qldsv-card border-0 shadow-sm mb-4 p-3">
        <form class="row g-3">
            <div class="col-md-4">
                <label class="form-label text-sm fw-medium">Khoa</label>
                <select class="form-select form-select-sm">
                    <option selected>Tất cả khoa</option>
                    <option>Công nghệ thông tin</option>
                    <option>Viễn thông</option>
                </select>
            </div>
            <div class="col-md-5">
                <label class="form-label text-sm fw-medium">Tìm kiếm</label>
                <div class="input-group input-group-sm">
                    <input type="text" class="form-control" placeholder="Mã GV hoặc Tên GV">
                    <button class="btn btn-outline-secondary" type="button"><i class="bi bi-search"></i></button>
                </div>
            </div>
        </form>
    </div>

    <div class="qldsv-card border-0 shadow-sm">
        <div class="table-responsive p-3">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th scope="col">Mã GV</th>
                        <th scope="col">Họ và Tên</th>
                        <th scope="col">Học vị / Học hàm</th>
                        <th scope="col">Mã Khoa</th>
                        <th scope="col" class="text-end">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td class="fw-medium text-success">GV01</td>
                        <td>TS. Nguyễn Thanh Tuấn</td>
                        <td>Tiến sĩ</td>
                        <td>CNTT</td>
                        <td class="text-end">
                            <button class="btn btn-sm btn-outline-primary me-1"><i class="bi bi-pencil"></i></button>
                            <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                        </td>
                    </tr>
                    <tr>
                        <td class="fw-medium text-success">GV02</td>
                        <td>ThS. Lê Thị Ái</td>
                        <td>Thạc sĩ</td>
                        <td>CNTT</td>
                        <td class="text-end">
                            <button class="btn btn-sm btn-outline-primary me-1"><i class="bi bi-pencil"></i></button>
                            <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
