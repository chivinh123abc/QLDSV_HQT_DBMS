@model QLDSV_HTC.Web.Models.CourseRegistrationViewModel
@{
    ViewData["Title"] = "Đăng ký lớp tín chỉ";
    var initials = Model.StudentFullName.Length > 1
        ? string.Concat(Model.StudentFullName.Split(' ', StringSplitOptions.RemoveEmptyEntries)
            .Select(w => char.ToUpper(w[0])).Take(2))
        : "SV";
}

<div class="dashboard-container fade-in-up">

    @* ── Tiêu đề ── *@
    <div class="mb-4">
        <h1 class="h3 fw-bold mb-1 text-gray-800">Đăng ký lớp tín chỉ</h1>
        <p class="text-muted mb-0 small">
            <i class="bi bi-clipboard-check me-1"></i>
            Chọn Niên khóa và Học kỳ để xem các lớp đang mở, sau đó nhấn <strong>Đăng ký</strong> hoặc <strong>Rời lớp</strong>.
        </p>
    </div>

    @* ── Thông tin Sinh viên ── *@
    <div class="card border-0 shadow-sm mb-4 rounded-3"
         style="background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);">
        <div class="card-body p-4 text-white">
            <div class="row align-items-center g-3">
                <div class="col-auto">
                    <div class="d-flex align-items-center justify-content-center rounded-circle bg-white bg-opacity-25 fw-bold fs-4 shadow"
                         style="width: 3.5rem; height: 3.5rem; color: #fff; letter-spacing: 1px;">
                        @initials
                    </div>
                </div>
                <div class="col">
                    <div class="row g-3">
                        <div class="col-6 col-md-4">
                            <div class="opacity-75 small mb-1">Mã sinh viên</div>
                            <div class="fw-bold font-monospace">@Model.StudentId</div>
                        </div>
                        <div class="col-6 col-md-4">
                            <div class="opacity-75 small mb-1">Họ và tên</div>
                            <div class="fw-bold">@(string.IsNullOrWhiteSpace(Model.StudentFullName) ? "—" : Model.StudentFullName)</div>
                        </div>
                        <div class="col-6 col-md-4">
                            <div class="opacity-75 small mb-1">Mã lớp học</div>
                            <div class="fw-bold font-monospace">@(string.IsNullOrWhiteSpace(Model.StudentClass) ? "—" : Model.StudentClass)</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* ── Bộ lọc ── *@
    <div class="card border-0 shadow-sm mb-4 rounded-3">
        <div class="card-body p-4">
            <h6 class="fw-bold mb-3 text-body">
                <i class="bi bi-funnel me-2 text-primary"></i>Lọc lớp tín chỉ
            </h6>
            <div class="row g-3 align-items-end">
                <div class="col-sm-4 col-md-3">
                    <label for="selYear" class="form-label small fw-semibold">Niên khóa</label>
                    <select id="selYear" class="form-select shadow-none">
                        <option value="">-- Chọn niên khóa --</option>
                        @foreach (var y in Model.Years)
                        {
                            <option value="@y">@y</option>
                        }
                    </select>
                </div>
                <div class="col-sm-4 col-md-2">
                    <label for="selSemester" class="form-label small fw-semibold">Học kỳ</label>
                    <select id="selSemester" class="form-select shadow-none">
                        <option value="0">-- Học kỳ --</option>
                        @foreach (var s in Model.Semesters)
                        {
                            <option value="@s">Học kỳ @s</option>
                        }
                    </select>
                </div>
                <div class="col-sm-4 col-md-3">
                    <label for="searchInput" class="form-label small fw-semibold">Tìm kiếm</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0 shadow-none">
                            <i class="bi bi-search text-muted"></i>
                        </span>
                        <input type="text" id="searchInput" class="form-control border-start-0 bg-light shadow-none"
                               placeholder="Mã, tên môn học..." />
                    </div>
                </div>
                <div class="col-sm-12 col-md-auto">
                    <button id="btnFilter" class="btn btn-primary shadow-sm px-4 w-100">
                        <i class="bi bi-search me-1"></i>Lọc
                    </button>
                </div>
            </div>
        </div>
    </div>

    @* ── Bảng kết quả ── *@
    <div class="card border-0 shadow-sm rounded-3">
        <div class="card-header bg-transparent border-bottom d-flex align-items-center justify-content-between py-3 px-4">
            <h6 class="fw-bold mb-0">
                <i class="bi bi-table me-2 text-primary"></i>Danh sách lớp tín chỉ đang mở
            </h6>
            <span class="badge bg-primary-subtle text-primary border border-primary-subtle px-3" id="resultCount">
                Chưa lọc
            </span>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4 py-3 border-0 text-muted small text-uppercase fw-bold">Mã MH</th>
                            <th class="py-3 border-0 text-muted small text-uppercase fw-bold">Tên môn học</th>
                            <th class="py-3 text-center border-0 text-muted small text-uppercase fw-bold">Nhóm</th>
                            <th class="py-3 border-0 text-muted small text-uppercase fw-bold">Họ tên GV giảng</th>
                            <th class="py-3 text-center border-0 text-muted small text-uppercase fw-bold">SV đã ĐK</th>
                            <th class="pe-4 py-3 text-center border-0 text-muted small text-uppercase fw-bold">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody id="classTableBody">
                        <tr id="emptyRow">
                            <td colspan="6" class="text-center text-muted py-6">
                                <i class="bi bi-filter-circle fs-2 d-block mb-2 opacity-25"></i>
                                Vui lòng chọn <strong>Niên khóa</strong> và <strong>Học kỳ</strong> rồi nhấn <strong>Lọc</strong>.
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>

<partial name="_DeleteConfirmModal" />

@section Scripts {
<script>
(function () {
    'use strict';

    const URL_FILTER      = '@Url.Action("Filter",      "Registration")';
    const URL_REGISTER    = '@Url.Action("Register",    "Registration")';
    const URL_UNREGISTER  = '@Url.Action("Unregister",  "Registration")';

    const selYear     = document.getElementById('selYear');
    const selSemester = document.getElementById('selSemester');
    const searchInput = document.getElementById('searchInput');
    const btnFilter   = document.getElementById('btnFilter');
    const tbody       = document.getElementById('classTableBody');
    const resultCount = document.getElementById('resultCount');

    let allData = []; // cache data from server

    // ── Nút Lọc ──────────────────────────────────────────────────────
    btnFilter.addEventListener('click', () => doFilter());
    selYear.addEventListener('change', () => { if (selYear.value && selSemester.value !== '0') doFilter(); });
    selSemester.addEventListener('change', () => { if (selYear.value && selSemester.value !== '0') doFilter(); });

    async function doFilter() {
        const year     = selYear.value;
        const semester = parseInt(selSemester.value);
        if (!year || semester <= 0) {
            showMessage('Vui lòng chọn đầy đủ Niên khóa và Học kỳ.', 'filter-circle');
            return;
        }

        btnFilter.disabled = true;
        btnFilter.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Đang tải...';

        try {
            const res  = await fetch(`${URL_FILTER}?year=${encodeURIComponent(year)}&semester=${semester}`);
            const json = await res.json();

            if (!json.success) { showMessage(json.message || 'Lỗi tải dữ liệu.', 'exclamation-triangle'); return; }

            allData = json.data;
            renderRows(filterBySearch(allData));
        } catch (err) {
            showMessage('Lỗi kết nối: ' + err.message, 'wifi-off');
        } finally {
            btnFilter.disabled = false;
            btnFilter.innerHTML = '<i class="bi bi-search me-1"></i>Lọc';
        }
    }

    // ── Tìm kiếm client-side ─────────────────────────────────────────
    searchInput.addEventListener('input', () => {
        if (allData.length > 0) renderRows(filterBySearch(allData));
    });

    function filterBySearch(data) {
        const q = searchInput.value.toLowerCase().trim();
        if (!q) return data;
        return data.filter(r =>
            r.subjectCode.toLowerCase().includes(q) ||
            r.subjectName.toLowerCase().includes(q) ||
            r.lecturer.toLowerCase().includes(q)
        );
    }

    // ── Render bảng ──────────────────────────────────────────────────
    function renderRows(data) {
        if (data.length === 0) {
            showMessage('Không tìm thấy lớp tín chỉ phù hợp.', 'inbox');
            return;
        }

        tbody.innerHTML = data.map(c => {
            const countClass = c.registered >= c.minStudents ? 'text-danger fw-bold' : 'text-success fw-bold';
            const btn = c.isRegistered
                ? `<button class="btn btn-sm btn-outline-danger px-3 rounded-pill action-btn"
                           data-id="${c.id}" data-action="unregister">
                       <i class="bi bi-dash-circle me-1"></i>Rời lớp
                   </button>`
                : `<button class="btn btn-sm btn-outline-primary px-3 rounded-pill action-btn"
                           data-id="${c.id}" data-action="register">
                       <i class="bi bi-plus-circle me-1"></i>Đăng ký
                   </button>`;

            const regBadge = c.isRegistered
                ? `<span class="badge bg-success-subtle text-success border border-success-subtle ms-2 small">Đã ĐK</span>`
                : '';

            return `<tr data-id="${c.id}">
                <td class="ps-4">
                    <span class="font-monospace fw-semibold text-primary small">${esc(c.subjectCode)}</span>
                </td>
                <td class="fw-semibold">${esc(c.subjectName)}${regBadge}</td>
                <td class="text-center">
                    <span class="badge bg-info-subtle text-info border border-info-subtle px-2">${c.group}</span>
                </td>
                <td class="text-muted small">${esc(c.lecturer)}</td>
                <td class="text-center">
                    <span class="${countClass}">${c.registered}</span>
                    <span class="text-muted small"> / ${c.minStudents}</span>
                </td>
                <td class="pe-4 text-center">${btn}</td>
            </tr>`;
        }).join('');

        resultCount.textContent = data.length + ' lớp';

        // Gắn sự kiện cho các nút Đăng ký / Rời lớp
        tbody.querySelectorAll('.action-btn').forEach(btn => {
            btn.addEventListener('click', () => handleAction(btn));
        });
    }

    // ── Xử lý Đăng ký / Rời lớp ─────────────────────────────────────
    async function handleAction(btn) {
        const id     = parseInt(btn.dataset.id);
        const action = btn.dataset.action;
        const url    = action === 'register' ? URL_REGISTER : URL_UNREGISTER;
        const label  = action === 'register' ? 'Đăng ký' : 'Hủy đăng ký';

        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';

        try {
            const res  = await fetch(url, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ creditClassId: id })
            });
            const json = await res.json();

            if (json.success) {
                window.showToast(json.message, 'success');
                // Cập nhật trạng thái trong cache và re-render
                const item = allData.find(c => c.id === id);
                if (item) {
                    if (action === 'register') {
                        item.isRegistered = true;
                        item.registered++;
                    } else {
                        item.isRegistered = false;
                        item.registered = Math.max(0, item.registered - 1);
                    }
                }
                renderRows(filterBySearch(allData));
            } else {
                window.showToast(json.message, 'danger');
                btn.disabled = false;
                btn.innerHTML = action === 'register'
                    ? '<i class="bi bi-plus-circle me-1"></i>Đăng ký'
                    : '<i class="bi bi-dash-circle me-1"></i>Rời lớp';
            }
        } catch (err) {
            window.showToast('Lỗi: ' + err.message, 'danger');
            btn.disabled = false;
        }
    }

    function showMessage(msg, icon) {
        tbody.innerHTML = `<tr><td colspan="6" class="text-center text-muted py-5">
            <i class="bi bi-${icon} fs-2 d-block mb-2 opacity-25"></i>${msg}</td></tr>`;
        resultCount.textContent = '0 lớp';
    }

    function esc(str) {
        return String(str)
            .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    }
})();
</script>
}
