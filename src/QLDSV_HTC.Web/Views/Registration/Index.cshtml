@model QLDSV_HTC.Web.Models.CourseRegistrationViewModel
@{
    ViewData["Title"] = "Đăng ký lớp tín chỉ";
    var initials = Model.StudentFullName.Length > 1
        ? string.Concat(Model.StudentFullName.Split(' ', StringSplitOptions.RemoveEmptyEntries)
            .Select(w => char.ToUpper(w[0])).Take(2))
        : "SV";
}

<div class="dashboard-container fade-in-up">
    @* Registration header/title handled by TitleSection in _RegistrationTable *@

    @* ── Thông tin Sinh viên ── *@
    <div class="card border-0 shadow-lg mb-4 rounded-4 overflow-hidden animate__animated animate__fadeIn">
        <div class="card-body p-0">
            <div class="row g-0">
                <div class="col-md-auto bg-primary bg-gradient d-flex flex-column align-items-center justify-content-center p-4 text-white" style="min-width: 180px;">
                    <div class="d-flex align-items-center justify-content-center rounded-circle bg-white bg-opacity-25 fw-bold fs-2 mb-2 shadow-sm"
                         style="width: 5rem; height: 5rem; letter-spacing: 2px; border: 3px solid rgba(255,255,255,0.3);">
                        @initials
                    </div>
                    <div class="fw-bold text-uppercase small" style="letter-spacing: 1px;">Sinh viên</div>
                </div>
                <div class="col p-4 bg-white">
                    <div class="row g-4">
                        <div class="col-6 col-md-4">
                            <div class="text-xs fw-bold text-uppercase text-muted mb-1">Mã sinh viên</div>
                            <div class="fw-bold font-monospace text-primary fs-5">@Model.StudentId</div>
                        </div>
                        <div class="col-6 col-md-4">
                            <div class="text-xs fw-bold text-uppercase text-muted mb-1">Họ và tên</div>
                            <div class="fw-bold text-dark fs-5">@(string.IsNullOrWhiteSpace(Model.StudentFullName) ? "—" : Model.StudentFullName)</div>
                        </div>
                        <div class="col-6 col-md-4">
                            <div class="text-xs fw-bold text-uppercase text-muted mb-1">Lớp học</div>
                            <div class="fw-bold font-monospace text-dark fs-5">@(string.IsNullOrWhiteSpace(Model.StudentClass) ? "—" : Model.StudentClass)</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* ── Bộ lọc (auto-filter, no button) ── *@
    <div class="card border-0 shadow-sm mb-4 rounded-4 bg-white overflow-hidden">
        <div class="card-body p-4">
            <div class="d-flex align-items-center gap-2 mb-3">
                <div class="icon-box-sm bg-primary-subtle text-primary rounded-circle">
                    <i class="bi bi-funnel-fill"></i>
                </div>
                <h6 class="fw-bold mb-0 text-dark">Lọc lớp tín chỉ</h6>
            </div>
            
            <div class="row g-3 align-items-end">
                <div class="col-sm-6 col-md-4 col-lg-3">
                    <label for="selYear" class="form-label small fw-bold text-muted">Niên khóa</label>
                    <div class="input-group input-group-merge shadow-none border rounded-3 overflow-hidden">
                        <span class="input-group-text bg-light border-0"><i class="bi bi-calendar3 text-primary"></i></span>
                        <select id="selYear" class="form-select border-0 bg-white shadow-none ps-0">
                            @foreach (var y in Model.Years)
                            {
                                <option value="@y" selected="@(y == Model.CurrentYear)">@y</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="col-sm-6 col-md-4 col-lg-2">
                    <label for="selSemester" class="form-label small fw-bold text-muted">Học kỳ</label>
                    <div class="input-group input-group-merge shadow-none border rounded-3 overflow-hidden">
                        <span class="input-group-text bg-light border-0"><i class="bi bi-clock-history text-primary"></i></span>
                        <select id="selSemester" class="form-select border-0 bg-white shadow-none ps-0">
                            @foreach (var s in Model.Semesters)
                            {
                                <option value="@s" selected="@(s == Model.CurrentSemester)">Học kỳ @s</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="col-sm-12 col-md-4 col-lg-4">
                    <div id="filterStatus" class="d-flex align-items-center gap-2 py-2">
                        <div class="spinner-border spinner-border-sm text-primary d-none" id="filterSpinner" role="status"></div>
                        <span class="small text-muted" id="filterMessage">Sẵn sàng lọc</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* ── Bảng kết quả (partial) ── *@
    <partial name="_RegistrationTable" />
</div>

<partial name="_DeleteConfirmModal" />

@section Scripts {
<script>
(function () {
    'use strict';

    const URL_FILTER      = '@RouteConstants.Registration.FilterPath';
    const URL_REGISTER    = '@RouteConstants.Registration.RegisterPath';
    const URL_UNREGISTER  = '@RouteConstants.Registration.UnregisterPath';

    const CURRENT_YEAR     = '@Model.CurrentYear';
    const CURRENT_SEMESTER = @Model.CurrentSemester;

    const selYear       = document.getElementById('selYear');
    const selSemester   = document.getElementById('selSemester');
    const searchInput   = document.getElementById('searchInput');
    const tbody         = document.getElementById('classTableBody');
    const resultCount   = document.getElementById('resultCount');
    const footerInfo    = document.getElementById('footerInfo');
    const filterSpinner = document.getElementById('filterSpinner');
    const filterMessage = document.getElementById('filterMessage');

    let allData = [];
    let debounceTimer = null;

    disablePastOptions();
    selYear.addEventListener('change', () => { disablePastSemesters(); doFilter(); });
    selSemester.addEventListener('change', () => doFilter());

    doFilter();

    function disablePastOptions() {
        Array.from(selYear.options).forEach(opt => {
            if (opt.value && opt.value < CURRENT_YEAR) {
                opt.disabled = true;
                opt.textContent = opt.value + ' (Quá khứ)';
            }
        });
        disablePastSemesters();
    }

    function disablePastSemesters() {
        const selectedYear = selYear.value;
        Array.from(selSemester.options).forEach(opt => {
            const sem = parseInt(opt.value);
            if (selectedYear === CURRENT_YEAR && sem < CURRENT_SEMESTER) {
                opt.disabled = true;
            } else {
                opt.disabled = false;
            }
        });

        const currentOpt = selSemester.options[selSemester.selectedIndex];
        if (currentOpt && currentOpt.disabled) {
            selSemester.value = CURRENT_SEMESTER.toString();
        }
    }

    async function doFilter() {
        const year     = selYear.value;
        const semester = parseInt(selSemester.value);
        if (!year || isNaN(semester)) {
            showMessage('Vui lòng chọn đầy đủ Niên khóa và Học kỳ.', 'filter-circle');
            return;
        }

        setLoading(true);

        try {
            const res  = await fetch(`${URL_FILTER}?year=${encodeURIComponent(year)}&semester=${semester}`);
            const json = await res.json();

            if (!json.success) {
                showMessage(json.message || 'Lỗi tải dữ liệu.', 'exclamation-triangle');
                return;
            }

            allData = json.data;
            renderRows(filterBySearch(allData));
            setFilterStatus(`Đã tải ${allData.length} lớp`, 'text-success fw-bold');
        } catch (err) {
            showMessage('Lỗi kết nối: ' + err.message, 'wifi-off');
            setFilterStatus('Lỗi kết nối', 'text-danger');
        } finally {
            setLoading(false);
        }
    }

    function setLoading(loading) {
        filterSpinner.classList.toggle('d-none', !loading);
        if (loading) filterMessage.textContent = 'Đang tải dữ liệu…';
    }

    function setFilterStatus(msg, cls) {
        filterMessage.textContent = msg;
        filterMessage.className = `small ${cls}`;
    }

    const btnClearSearch = document.getElementById('btnClearSearch');
    
    searchInput.addEventListener('input', () => {
        btnClearSearch.classList.toggle('d-none', !searchInput.value);
        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(() => {
            if (allData.length > 0) renderRows(filterBySearch(allData));
        }, 200);
    });

    btnClearSearch.addEventListener('click', () => {
        searchInput.value = '';
        btnClearSearch.classList.add('d-none');
        searchInput.focus();
        if (allData.length > 0) renderRows(filterBySearch(allData));
    });

    function filterBySearch(data) {
        const q = searchInput.value.toLowerCase().trim();
        if (!q) return data;
        return data.filter(r =>
            r.subjectCode.toLowerCase().includes(q) ||
            r.subjectName.toLowerCase().includes(q) ||
            r.lecturer.toLowerCase().includes(q)
        );
    }

    function renderRows(data) {
        if (data.length === 0) {
            showMessage('Không tìm thấy lớp tín chỉ phù hợp.', 'search');
            return;
        }

        const registeredSubjectCodes = new Set(
            data.filter(x => x.isRegistered).map(x => x.subjectCode)
        );

        tbody.innerHTML = data.map(c => {
            let statusBadge = '';
            if (c.registered >= c.minStudents) {
                statusBadge = '<span class="badge-status badge-success px-2 py-1 rounded-pill shadow-sm"><i class="bi bi-check-circle me-1"></i>Đủ SV</span>';
            } else if (c.registered >= c.minStudents * 0.7) {
                statusBadge = '<span class="badge-status badge-warning px-2 py-1 rounded-pill shadow-sm"><i class="bi bi-info-circle me-1"></i>Sắp đủ</span>';
            } else {
                statusBadge = '<span class="badge-status bg-light text-muted border px-2 py-1 rounded-pill shadow-sm">Đang mở</span>';
            }

            let btn = '';
            if (c.isRegistered) {
                btn = `<button class="btn btn-sm btn-outline-danger px-3 rounded-pill action-btn hover-scale shadow-none"
                               data-id="${c.id}" data-action="unregister">
                           <i class="bi bi-dash-circle me-1"></i>Hủy ĐK
                       </button>`;
            } else {
                const isDuplicateSubject = registeredSubjectCodes.has(c.subjectCode);
                const disabledAttr = isDuplicateSubject ? 'disabled' : '';
                const styleAttr = isDuplicateSubject ? 'style="opacity: 0.5; cursor: not-allowed;"' : '';
                const titleAttr = isDuplicateSubject ? 'title="Bạn đã đăng ký môn học này ở nhóm khác"' : 'title="Đăng ký lớp học này"';

                btn = `<button class="btn btn-sm btn-primary px-3 rounded-pill action-btn hover-scale shadow-sm ${disabledAttr}"
                               data-id="${c.id}" data-action="register" ${disabledAttr} ${styleAttr} ${titleAttr}>
                           <i class="bi bi-plus-circle me-1"></i>Đăng ký
                       </button>`;
            }

            const regBadge = c.isRegistered
                ? `<span class="badge bg-success bg-opacity-10 text-success border border-success-subtle ms-2 small px-2 py-1" style="font-size: 0.65rem;">ĐÃ ĐK</span>`
                : '';

            return `<tr class="hover-row transition-base animate__animated animate__fadeIn" data-id="${c.id}">
                <td class="ps-4">
                    <span class="badge bg-primary-subtle text-primary border border-primary-subtle px-2 py-1 rounded-pill shadow-sm font-monospace tabular-nums">
                        ${esc(c.subjectCode)}
                    </span>
                </td>
                <td>
                    <div class="fw-bold text-dark d-flex align-items-center">
                        ${esc(c.subjectName)}${regBadge}
                    </div>
                </td>
                <td class="text-center">
                    <span class="badge bg-info-subtle text-info border border-info-subtle px-3 py-1 rounded-pill shadow-sm tabular-nums">${c.group}</span>
                </td>
                <td>
                    <div class="text-dark fw-semibold small d-flex align-items-center">
                        <i class="bi bi-person text-muted me-2"></i>${esc(c.lecturer)}
                    </div>
                </td>
                <td class="text-center">
                    <div class="d-flex flex-column align-items-center gap-1">
                        <div class="fw-bold text-dark tabular-nums">${c.registered} / ${c.minStudents}</div>
                        ${statusBadge}
                    </div>
                </td>
                <td class="pe-4 text-center">${btn}</td>
            </tr>`;
        }).join('');

        resultCount.innerHTML = `<i class="bi bi-list-stars me-1"></i> ${data.length} lớp`;
        footerInfo.innerHTML = `<i class="bi bi-collection-play me-1"></i>Hiển thị <strong class="text-primary">${data.length}</strong> / ${allData.length} lớp tín chỉ phù hợp`;

        tbody.querySelectorAll('.action-btn').forEach(btn => {
            btn.addEventListener('click', () => handleAction(btn));
        });
    }

    async function handleAction(btn) {
        const id     = parseInt(btn.dataset.id);
        const action = btn.dataset.action;
        const url    = action === 'register' ? URL_REGISTER : URL_UNREGISTER;

        btn.disabled = true;
        const originalContent = btn.innerHTML;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>';

        try {
            const res  = await fetch(url, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ creditClassId: id })
            });
            const json = await res.json();

            if (json.success) {
                window.showToast(json.message, 'success');
                const item = allData.find(c => c.id === id);
                if (item) {
                    if (action === 'register') {
                        item.isRegistered = true;
                        item.registered++;
                    } else {
                        item.isRegistered = false;
                        item.registered = Math.max(0, item.registered - 1);
                    }
                }
                renderRows(filterBySearch(allData));
            } else {
                window.showToast(json.message, 'danger');
                btn.disabled = false;
                btn.innerHTML = originalContent;
            }
        } catch (err) {
            window.showToast('Lỗi: ' + err.message, 'danger');
            btn.disabled = false;
            btn.innerHTML = originalContent;
        }
    }

    function showMessage(msg, icon) {
        tbody.innerHTML = `<tr><td colspan="6" class="text-center text-muted py-5 border-0">
            <div class="animate__animated animate__fadeIn py-4">
                <div class="icon-box-lg bg-light rounded-circle mx-auto mb-3 d-flex align-items-center justify-content-center">
                    <i class="bi bi-${icon} fs-2 text-body-tertiary"></i>
                </div>
                <h6 class="text-dark fw-bold mb-1">${msg}</h6>
                <p class="text-muted small">Hãy thử điều chỉnh bộ lọc hoặc tìm kiếm.</p>
            </div>
        </td></tr>`;
        resultCount.textContent = '0 lớp';
        footerInfo.innerHTML = `<i class="bi bi-info-circle me-1 text-warning"></i> ${msg}`;
    }

    function esc(str) {
        if (!str) return '';
        return String(str)
            .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    }
})();
</script>
}

