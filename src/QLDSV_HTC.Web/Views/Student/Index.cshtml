@using QLDSV_HTC.Domain.Constants
@model QLDSV_HTC.Web.Models.StudentManagementViewModel
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@{
    ViewData["Title"] = "Quản lý Sinh viên - Theo Lớp";
    bool isPGV = string.IsNullOrEmpty(Model.CurrentFacultyId);
    var requestToken = Antiforgery.GetAndStoreTokens(Context).RequestToken;
}

    <div class="header-modern mb-4">
        <div class="header-title-box">
            <div class="header-icon">
                <i class="bi bi-mortarboard-fill"></i>
            </div>
            <div>
                <h1 class="h3 mb-1 fw-bold text-gray-800">Quản lý Sinh viên</h1>
                <p class="text-muted mb-0 small">
                    <i class="bi bi-info-circle me-1"></i>
                    Quản lý thông tin cá nhân và học tập của sinh viên theo từng lớp.
                </p>
            </div>
        </div>
    </div>

    <!-- Master: Lớp -->
    @{
        ViewData["isPGV"] = isPGV;
        ViewData["Faculties"] = Model.Faculties;
    }
    @await Html.PartialAsync("_StudentClassTable", Model.Classes, ViewData)

    <!-- Detail: Danh sách Sinh viên -->
    @await Html.PartialAsync("_StudentTable", null, ViewData)
</div>

<!-- Modal Thêm/Sửa Sinh Viên -->
@await Html.PartialAsync("_StudentFormModal", Model, ViewData)

@section Scripts {
    <script src="~/js/form-helpers.js" asp-append-version="true"></script>
    <script>
        const token = '@requestToken';
        const isPGV = @(isPGV.ToString().ToLower());
        let currentSelectedClassId = '';
        let studentModalInstance;

        // Modal Form variables
        let mode = 'view';
        let snapshotData = null;
        let selectedStudentId = null;
        let originalStudentId = null;

        // -- UNDO STACK STATE --
        let undoStack = [];
        let forceClose = false;

        let allStudentsForClass = []; // Store full students of current class for modal list sync

        const fldStudentId = document.getElementById('fldStudentId');
        const fldPassword = document.getElementById('fldPassword');
        const fldFirstName = document.getElementById('fldFirstName');
        const fldLastName = document.getElementById('fldLastName');
        const fldGender = document.getElementById('fldGender');
        const fldDob = document.getElementById('fldDob');
        const fldAddress = document.getElementById('fldAddress');
        const fldOnLeave = document.getElementById('fldOnLeave');
        const fldClassId = document.getElementById('fldStudentClassId');

        const btnThem = document.getElementById('btnStudentFormThem');
        const btnXoa = document.getElementById('btnStudentFormXoa');
        const btnGhi = document.getElementById('btnStudentFormGhi');
        const btnPhucHoi = document.getElementById('btnStudentFormPhucHoi');
        const btnHuy = document.getElementById('btnStudentFormHuy');

        // Shared form helpers
        const helpers = createFormHelpers({
            alertEl: document.getElementById('studentFormAlert'),
            modeLabelEl: document.getElementById('studentFormModeLabel'),
            buttons: { them: btnThem, xoa: btnXoa, ghi: btnGhi, phucHoi: btnPhucHoi, huy: btnHuy },
            allFields: [fldStudentId, fldPassword, fldFirstName, fldLastName, fldGender, fldDob, fldAddress, fldOnLeave],
            requiredFields: [fldStudentId, fldFirstName, fldLastName],
            getSelectedId: () => selectedStudentId,
        });

        document.addEventListener("DOMContentLoaded", function () {
            const modalEl = document.getElementById('studentFormModal');
            if (modalEl) {
                studentModalInstance = new bootstrap.Modal(modalEl);
                modalEl.addEventListener('hidden.bs.modal', resetToView);

                const btnCancelModal = modalEl.querySelector('.btn-cancel-modal');
                const btnSaveModal = modalEl.querySelector('.btn-save-modal');

                modalEl.addEventListener('show.bs.modal', () => {
                    undoStack = [];
                    forceClose = false;
                });

                modalEl.addEventListener('hide.bs.modal', async (e) => {
                    if (undoStack.length > 0 && !forceClose) {
                        e.preventDefault();
                        const isConfirmed = await window.showConfirmDialog(
                            "Xác nhận Thoát",
                            "Dữ liệu đã được <b>Ghi</b> vào hệ thống. Nếu đóng cửa sổ, bạn sẽ không thể dùng chức năng 'Phục hồi' (Undo) cho các thao tác vừa rồi.<br><br>Bạn có chắc chắn muốn thoát?",
                            { confirmText: "Xác nhận Thoát", cancelText: "Trở lại", isDanger: true }
                        );
                        if (isConfirmed) {
                            forceClose = true;
                            studentModalInstance.hide();
                        }
                    }
                });

                btnSaveModal?.addEventListener('click', async () => {
                    if (undoStack.length === 0) {
                        forceClose = true;
                        studentModalInstance.hide();
                        return;
                    }

                    const message = "Dữ liệu đã được <b>Ghi</b> vào hệ thống. Nếu đóng cửa sổ, bạn sẽ không thể dùng chức năng 'Phục hồi' (Undo) cho các thao tác vừa rồi.<br><br>Bạn có chắc chắn muốn thoát?";

                    const isConfirmed = await window.showConfirmDialog(
                        "Xác nhận Thoát", message,
                        { confirmText: "Xác nhận", cancelText: "Trở lại" }
                    );

                    if (isConfirmed) {
                        undoStack = [];
                        forceClose = true;
                        studentModalInstance.hide();
                    }
                });

                btnCancelModal?.addEventListener('click', async () => {
                    if (undoStack.length === 0) {
                        forceClose = true;
                        studentModalInstance.hide();
                        return;
                    }

                    const message = "Hành động này sẽ <b>Hoàn Tác toàn bộ</b> các thay đổi bạn vừa thực hiện trong phiên này.<br>Bạn có chắc chắn muốn xóa bỏ công sức vừa làm?";

                    const isConfirmed = await window.showConfirmDialog(
                        "Hoàn Tác & Đóng", message,
                        { confirmText: "Xác nhận Hoàn tác", cancelText: "Giữ lại", isDanger: true }
                    );

                    if (isConfirmed) {
                        btnCancelModal.disabled = true;
                        while (undoStack.length > 0) {
                            await executeUndo();
                        }
                        undoStack = [];
                        forceClose = true;
                        btnCancelModal.disabled = false;
                        studentModalInstance.hide();
                    }
                });

                // Modal Quick Search
                const modalSearchInput = document.getElementById('modalStudentSearch');
                modalSearchInput?.addEventListener('input', function () {
                    const q = this.value.toLowerCase();
                    const filtered = allStudentsForClass.filter(s =>
                        s.studentId.toLowerCase().includes(q) ||
                        `${s.firstName} ${s.lastName}`.toLowerCase().includes(q)
                    );
                    renderModalStudentList(filtered);
                });
            }

            btnThem?.addEventListener('click', () => {
                selectedStudentId = null;
                snapshotData = null;
                clearFields();
                helpers.clearValidation();
                helpers.setMode('add');

                // Update placeholder for adding new student
                fldPassword.placeholder = "Nhập mật khẩu cho sinh viên mới";

                fldStudentId.focus();
                helpers.showAlert('Nhập thông tin sinh viên mới rồi nhấn <b>Ghi</b> để lưu.', 'info');
            });

            btnXoa?.addEventListener('click', () => {
                if (!selectedStudentId) return;
                deleteStudent(selectedStudentId);
            });

            btnGhi?.addEventListener('click', submitStudentForm);

            btnPhucHoi?.addEventListener('click', async () => {
                if (undoStack.length === 0) {
                    helpers.showAlert('Không có hành động nào để phục hồi.', 'info');
                    return;
                }
                await executeUndo();
                resetToView();
                helpers.showAlert('Đã hoàn tác 1 hành động.', 'warning');
            });

            btnHuy?.addEventListener('click', resetToView);

            // Local search for loaded students
            const studentSearchInput = document.getElementById('studentSearch');
            const btnClearStudentSearch = document.getElementById('btnClearStudentSearch');
            
            if (studentSearchInput) {
                studentSearchInput.addEventListener('input', function() {
                    const q = this.value.toLowerCase().trim();
                    if (btnClearStudentSearch) {
                        btnClearStudentSearch.classList.toggle('d-none', !q);
                    }
                    
                    const rows = document.querySelectorAll('#studentTable tbody tr.student-row');
                    rows.forEach(row => {
                        const msv = row.querySelector('.student-id').innerText.toLowerCase();
                        const name = row.querySelector('.student-name').innerText.toLowerCase();
                        if (msv.includes(q) || name.includes(q)) {
                            row.style.display = '';
                        } else {
                            row.style.display = 'none';
                        }
                    });
                });
                
                studentSearchInput.addEventListener('keydown', function(e) {
                    if (e.key === 'Escape') {
                        this.value = '';
                        this.dispatchEvent(new Event('input'));
                    }
                });
            }
            
            if (btnClearStudentSearch) {
                btnClearStudentSearch.addEventListener('click', function() {
                    if (studentSearchInput) {
                        studentSearchInput.value = '';
                        studentSearchInput.dispatchEvent(new Event('input'));
                        studentSearchInput.focus();
                    }
                });
            }
        });

        // Exposed to global for _StudentClassTable.cshtml
        window.loadStudentsForClass = function (classId, className, page = 1) {
            currentSelectedClassId = classId;
            document.getElementById('lblSelectedClass').innerText = `- Lớp: ${className} (${classId})`;
            
            const studentsSection = document.getElementById('studentsSection');
            if (studentsSection) {
                studentsSection.style.display = 'block';
                studentsSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }

            const btnAction = document.getElementById('btnActionStudent');
            if (btnAction) btnAction.disabled = false;

            const container = document.getElementById('studentsSection');
            if (container) {
                container.classList.add('container-loading');

                // Add overlay if it doesn't exist
                if (!container.querySelector('.loading-overlay')) {
                const overlay = document.createElement('div');
                overlay.className = 'loading-overlay';
                overlay.innerHTML = '<div class="loading-spinner-premium"></div><div class="mt-2 fw-medium text-primary">Đang nạp dữ liệu...</div>';
                container.appendChild(overlay);
            }

            const pageSize = 10;
            fetch(`@RouteConstants.Student.ListPath?classId=${encodeURIComponent(classId)}&page=${page}&pageSize=${pageSize}`)
                .then(res => res.json())
                .then(res => {
                    container.classList.remove('container-loading');
                    const overlay = container.querySelector('.loading-overlay');
                    if (overlay) overlay.remove();

                    if (res.success) {
                        allStudentsForClass = res.data; // Store for modal use
                        renderStudents(res.data);
                        renderModalStudentList(res.data);
                        renderStudentPagination(res.pagination, className);
                    } else {
                        window.showToast("Lỗi tải danh sách sinh viên: " + res.message, 'danger');
                    }
                })
                .catch(err => {
                    container.classList.remove('container-loading');
                    const overlay = container.querySelector('.loading-overlay');
                    if (overlay) overlay.remove();

                    console.error("AJAX Error: ", err);
                    window.showToast("Có lỗi xảy ra khi gọi API.", 'danger');
                });
        };

        window.goToStudentPage = function (page, pageSize) {
            if (!currentSelectedClassId) return;
            const className = document.getElementById('lblSelectedClass').innerText.replace('- Lớp: ', '').split(' (')[0];
            window.loadStudentsForClass(currentSelectedClassId, className, page);
        };

        function renderStudentPagination(pagination, className) {
            const container = document.getElementById('studentPaginationContainer');
            const controls = document.getElementById('studentPaginationControls');
            const displayCount = document.getElementById('studentDisplayCount');

            if (pagination.totalCount === 0) {
                container.style.setProperty('display', 'none', 'important');
                return;
            }

            container.style.setProperty('display', 'flex', 'important');

            const startItem = (pagination.pageNumber - 1) * pagination.pageSize + 1;
            const endItem = Math.min(pagination.pageNumber * pagination.pageSize, pagination.totalCount);
            displayCount.innerHTML = `Hiển thị <strong>${endItem - startItem + 1}</strong> / ${pagination.totalCount} sinh viên`;

            if (pagination.totalPages <= 0) {
                controls.innerHTML = '';
                return;
            }

            const maxPagesToShow = 5;
            let startPage = Math.max(1, pagination.pageNumber - Math.floor(maxPagesToShow / 2));
            let endPage = Math.min(pagination.totalPages, startPage + maxPagesToShow - 1);

            if (endPage - startPage + 1 < maxPagesToShow) {
                startPage = Math.max(1, endPage - maxPagesToShow + 1);
            }

            let html = '<nav aria-label="Pagination"><ul class="pagination pagination-sm mb-0">';

            // Prev
            if (pagination.hasPreviousPage) {
                html += `<li class="page-item"><button class="page-link" onclick="goToStudentPage(${pagination.pageNumber - 1}, ${pagination.pageSize})"><i class="bi bi-chevron-left"></i></button></li>`;
            } else {
                html += `<li class="page-item disabled"><button class="page-link" disabled><i class="bi bi-chevron-left"></i></button></li>`;
            }

            // First & Ellipsis
            if (startPage > 1) {
                html += `<li class="page-item"><button class="page-link" onclick="goToStudentPage(1, ${pagination.pageSize})">1</button></li>`;
                if (startPage > 2) {
                    html += `<li class="page-item disabled"><span class="page-link">...</span></li>`;
                }
            }

            // Pages
            for (let i = startPage; i <= endPage; i++) {
                if (i === pagination.pageNumber) {
                    html += `<li class="page-item active"><button class="page-link" onclick="goToStudentPage(${i}, ${pagination.pageSize})">${i}</button></li>`;
                } else {
                    html += `<li class="page-item"><button class="page-link" onclick="goToStudentPage(${i}, ${pagination.pageSize})">${i}</button></li>`;
                }
            }

            // Last & Ellipsis
            if (endPage < pagination.totalPages) {
                if (endPage < pagination.totalPages - 1) {
                    html += `<li class="page-item disabled"><span class="page-link">...</span></li>`;
                }
                html += `<li class="page-item"><button class="page-link" onclick="goToStudentPage(${pagination.totalPages}, ${pagination.pageSize})">${pagination.totalPages}</button></li>`;
            }

            // Next
            if (pagination.hasNextPage) {
                html += `<li class="page-item"><button class="page-link" onclick="goToStudentPage(${pagination.pageNumber + 1}, ${pagination.pageSize})"><i class="bi bi-chevron-right"></i></button></li>`;
            } else {
                html += `<li class="page-item disabled"><button class="page-link" disabled><i class="bi bi-chevron-right"></i></button></li>`;
            }

            html += '</ul></nav>';
            controls.innerHTML = html;
        }

        function renderStudents(data) {
            const tbody = document.querySelector('#studentTable tbody');
            tbody.innerHTML = '';

            if (data.length === 0) {
                const colSpan = isPGV ? 7 : 6;
                tbody.innerHTML = `<tr><td colspan="${colSpan}" class="text-center text-muted py-5 border-0">
                    <div class="animate__animated animate__fadeIn py-5">
                        <div class="icon-box-xl bg-light text-warning opacity-25 mx-auto mb-3">
                            <i class="bi bi-person-exclamation fs-1"></i>
                        </div>
                        <h6 class="fw-semibold text-dark">Không có sinh viên nào</h6>
                        <p class="small text-muted mb-0">Lớp học này hiện chưa có sinh viên chính thức.</p>
                    </div>
                </td></tr>`;
                return;
            }

            data.forEach(s => {
                tbody.insertAdjacentHTML('beforeend', studentRowHtml(s));
            });
        }

        function studentRowHtml(s) {
            const statusBadge = s.onLeave 
                ? '<span class="badge bg-danger bg-opacity-10 text-danger border border-danger-subtle px-2 py-1 rounded-pill"><i class="bi bi-x-circle me-1"></i>Nghỉ học</span>'
                : '<span class="badge bg-success bg-opacity-10 text-success border border-success-subtle px-2 py-1 rounded-pill"><i class="bi bi-check-circle me-1"></i>Đang học</span>';

            const genderBadge = s.gender
                ? '<span class="badge bg-info bg-opacity-10 text-info border border-info-subtle px-2 py-1 rounded-pill"><i class="bi bi-gender-female me-1"></i>Nữ</span>'
                : '<span class="badge bg-primary bg-opacity-10 text-primary border border-primary-subtle px-2 py-1 rounded-pill"><i class="bi bi-gender-male me-1"></i>Nam</span>';

            return `
                <tr class="student-row hover-row animate__animated animate__fadeIn">
                    <td class="ps-4">
                        <span class="student-id fw-bold font-monospace text-primary bg-primary-subtle px-2 py-1 rounded small border border-primary-subtle">
                            ${s.studentId}
                        </span>
                    </td>
                    <td>
                        <div class="d-flex align-items-center gap-2">
                            <div class="icon-box-xs bg-light text-primary rounded-circle">
                                <i class="bi bi-person-fill" style="font-size: 0.8rem;"></i>
                            </div>
                            <div class="student-name fw-semibold text-dark">${s.firstName} ${s.lastName}</div>
                        </div>
                    </td>
                    <td class="text-center">${genderBadge}</td>
                    <td>
                        <div class="small text-muted d-flex align-items-center gap-2">
                            <i class="bi bi-calendar-event text-primary opacity-50"></i>
                            <span>${s.dob ? formatDateDisplay(s.dob) : 'N/A'}</span>
                        </div>
                    </td>
                    <td>
                        <div class="text-truncate small d-flex align-items-center gap-2" style="max-width: 200px;" title="${s.address || ''}">
                            <i class="bi bi-geo-alt text-primary opacity-50"></i>
                            <span class="text-dark">${s.address || '<span class="text-muted italic">Chưa cập nhật</span>'}</span>
                        </div>
                    </td>
                    <td class="text-center">${statusBadge}</td>
                    ${isPGV ? `
                    <td class="text-end pe-4">
                        <div class="d-flex justify-content-end gap-1">
                            <button class="btn btn-sm btn-outline-primary hover-scale shadow-none border-0" title="Sửa sinh viên" onclick='editStudent(${JSON.stringify(s).replace(/'/g, "&apos;")})'>
                                <i class="bi bi-pencil-square"></i>
                            </button>
                            <button class="btn btn-sm btn-outline-danger ${s.hasDependencies ? 'opacity-25' : 'hover-scale'} shadow-none border-0" 
                                    title="${s.hasDependencies ? 'Không thể xóa sinh viên đã có dữ liệu liên quan' : 'Xóa sinh viên'}" 
                                    ${s.hasDependencies ? 'disabled' : `onclick="deleteStudent('${s.studentId}')"`}>
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                    </td>` : ''}
                </tr>
            `;
        }

        function renderModalStudentList(data) {
            const tbody = document.querySelector('#modalStudentTable tbody');
            if (!tbody) return;
            tbody.innerHTML = '';

            if (data.length === 0) {
                tbody.innerHTML = '<tr><td colspan="4" class="text-center py-5 text-muted small">Không tìm thấy sinh viên nào.</td></tr>';
                return;
            }

            data.forEach(s => {
                const tr = document.createElement('tr');
                tr.className = 'modal-selectable-row';
                if (selectedStudentId === s.studentId) tr.classList.add('selected');

                tr.innerHTML = `
                                <td class="ps-3"><a href="javascript:void(0)" class="text-primary fw-bold text-decoration-none font-monospace">${s.studentId}</a></td>
                                <td class="fw-medium text-dark">${s.firstName} ${s.lastName}</td>
                                <td class="text-center text-muted small">${s.gender ? 'Nữ' : 'Nam'}</td>
                                <td class="pe-3 text-end">
                                    ${s.onLeave
                        ? '<span class="badge bg-danger bg-opacity-10 text-danger border border-danger-subtle px-2 py-1" style="font-size: 0.7rem; font-weight: 500;">NGHỈ</span>'
                        : '<span class="badge bg-success bg-opacity-10 text-success border border-success-subtle px-2 py-1" style="font-size: 0.7rem; font-weight: 500;">HỌC</span>'}
                                </td>
                            `;

                tr.addEventListener('click', () => {
                    document.querySelectorAll('.modal-selectable-row').forEach(r => r.classList.remove('selected'));
                    tr.classList.add('selected');
                    editStudent(s);
                });

                tbody.appendChild(tr);
            });
        }

        function formatDateDisplay(dateString) {
            if (!dateString) return '';
            const d = new Date(dateString);
            return d.toLocaleDateString('vi-VN');
        }

        // TOOLBAR AND MODAL LOGIC
        function openStudentModalView() {
            if (!currentSelectedClassId) return;
            resetToView();
            studentModalInstance.show();
        }

        function editStudent(s) {
            resetToView();
            populateFieldsFromSnapshot(s);
            helpers.setMode('edit');

            // Update placeholder for editing student
            fldPassword.placeholder = "Bỏ qua nếu không thay đổi mật khẩu";

            if (s.hasDependencies) {
                btnXoa.disabled = true;
                btnXoa.title = "Không thể xóa sinh viên đã có dữ liệu liên quan";
            } else {
                btnXoa.title = "Xóa (Phím tắt: Del)";
            }

            studentModalInstance.show();
            helpers.hideAlert();
        }

        function clearFields() {
            fldClassId.value = currentSelectedClassId;
            fldStudentId.value = fldPassword.value = fldFirstName.value = fldLastName.value = '';
            fldDob.value = fldAddress.value = '';
            fldGender.value = 'false';
            fldOnLeave.checked = false;
        }

        function populateFieldsFromSnapshot(s) {
            fldClassId.value = currentSelectedClassId;
            fldStudentId.value = s.studentId;
            fldFirstName.value = s.firstName;
            fldLastName.value = s.lastName;
            fldGender.value = s.gender ? 'true' : 'false';
            fldDob.value = s.dob ? s.dob : '';
            fldAddress.value = s.address || '';
            fldOnLeave.checked = s.onLeave;
            fldPassword.value = ''; // không nạp password cũ

            selectedStudentId = s.studentId;
            originalStudentId = s.studentId;
            snapshotData = { ...s };
        }

        function resetToView() {
            selectedStudentId = null;
            snapshotData = null;
            originalStudentId = null;
            clearFields();
            helpers.clearValidation();
            helpers.hideAlert();
            helpers.setMode('view');
            fldPassword.placeholder = "Password";
        }

        // SUBMIT
        function submitStudentForm() {
            if (!helpers.validateForm()) return;

            const url = helpers.getMode() === 'add' ? '@RouteConstants.Student.AddPath' : '@RouteConstants.Student.EditPath';

            const dataObj = {
                oldStudentId: originalStudentId,
                studentId: fldStudentId.value.trim(),
                firstName: fldFirstName.value.trim(),
                lastName: fldLastName.value.trim(),
                gender: fldGender.value === 'true',
                dob: fldDob.value,
                address: fldAddress.value.trim(),
                classId: fldClassId.value,
                onLeave: fldOnLeave.checked,
                password: fldPassword.value
            };

            fetch(url, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': token
                },
                body: JSON.stringify(dataObj)
            })
                .then(res => res.json())
                .then(res => {
                    if (res.success) {
                        window.showToast(res.message, 'success');

                        // UNDO LOGIC
                        if (helpers.getMode() === 'add') {
                            undoStack.push({ action: 'delete', payload: { studentId: dataObj.StudentId } });
                        } else {
                            if (snapshotData) {
                                undoStack.push({
                                    action: 'edit', payload: {
                                        OldStudentId: dataObj.StudentId,
                                        StudentId: snapshotData.studentId || snapshotData.StudentId,
                                        FirstName: snapshotData.firstName || snapshotData.FirstName,
                                        LastName: snapshotData.lastName || snapshotData.LastName,
                                        Gender: snapshotData.gender !== undefined ? snapshotData.gender : snapshotData.Gender,
                                        Dob: snapshotData.dob || snapshotData.Dob || '',
                                        Address: snapshotData.address || snapshotData.Address || '',
                                        ClassId: snapshotData.classId || snapshotData.ClassId,
                                        OnLeave: snapshotData.onLeave !== undefined ? snapshotData.onLeave : snapshotData.OnLeave,
                                        Password: snapshotData.password || snapshotData.Password || ''
                                    }
                                });
                            }
                        }

                        // Reload table
                        const className = document.getElementById('lblSelectedClass').innerText.replace('- Lớp: ', '').split(' (')[0];
                        window.loadStudentsForClass(currentSelectedClassId, className);

                        // Update snapshot
                        snapshotData = { ...dataObj };
                        selectedStudentId = dataObj.StudentId;
                        originalStudentId = dataObj.StudentId;
                        helpers.setMode('edit');
                        helpers.showAlert('Ghi dữ liệu thành công', 'success');
                    } else {
                        helpers.showAlert('Lỗi: ' + res.message, 'danger');
                    }
                })
                .catch(err => {
                    console.error(err);
                    helpers.showAlert("Lỗi kết nối.", 'danger');
                });
        }

        // DELETE
        async function deleteStudent(studentId) {
            const isConfirmed = await window.showConfirmDialog(
                "Xác nhận xóa sinh viên",
                `Bạn có chắc chắn muốn xóa sinh viên <b>${studentId}</b>?<br>Hành động này sẽ không thể phục hồi (kể cả khi Undo).`,
                { confirmText: "Xóa", cancelText: "Hủy", isDanger: true }
            );

            if (!isConfirmed) return;

            fetch('@RouteConstants.Student.DeletePath', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': token
                },
                body: JSON.stringify({ studentId: studentId })
            })
                .then(res => res.json())
                .then(res => {
                    if (res.success) {
                        window.showToast(res.message, 'success');

                        const modalEl = document.getElementById('studentFormModal');
                        let currentStudentId = snapshotData ? (snapshotData.studentId || snapshotData.StudentId) : null;
                        if (modalEl && modalEl.classList.contains('show') && snapshotData && currentStudentId === studentId) {
                            undoStack.push({
                                action: 'add', payload: {
                                    StudentId: currentStudentId,
                                    FirstName: snapshotData.firstName || snapshotData.FirstName,
                                    LastName: snapshotData.lastName || snapshotData.LastName,
                                    Gender: snapshotData.gender !== undefined ? snapshotData.gender : snapshotData.Gender,
                                    Dob: snapshotData.dob || snapshotData.Dob || '',
                                    Address: snapshotData.address || snapshotData.Address || '',
                                    ClassId: snapshotData.classId || snapshotData.ClassId,
                                    OnLeave: snapshotData.onLeave !== undefined ? snapshotData.onLeave : snapshotData.OnLeave,
                                    Password: ''
                                }
                            });
                        }

                        const className = document.getElementById('lblSelectedClass').innerText.replace('- Lớp: ', '').split(' (')[0];
                        window.loadStudentsForClass(currentSelectedClassId, className);

                        // If deleted from within modal
                        if (selectedStudentId === studentId) {
                            resetToView();
                        }
                    } else {
                        window.showToast('Lỗi: ' + res.message, 'danger');
                    }
                })
                .catch(err => {
                    console.error(err);
                    window.showToast("Lỗi kết nối.", 'danger');
                });
        }

        async function executeUndo() {
            if (undoStack.length === 0) return;
            const actionObj = undoStack.pop();
            try {
                let url = '';
                let bodyObj = {};

                if (actionObj.action === 'add') {
                    url = '@RouteConstants.Student.AddPath';
                    bodyObj = actionObj.payload;
                } else if (actionObj.action === 'edit') {
                    url = '@RouteConstants.Student.EditPath';
                    bodyObj = actionObj.payload;
                } else if (actionObj.action === 'delete') {
                    url = '@RouteConstants.Student.DeletePath';
                    bodyObj = { studentId: actionObj.payload.studentId };
                }

                const res = await fetch(url, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': token
                    },
                    body: JSON.stringify(bodyObj)
                }).then(r => r.json());

                if (!res.success) {
                    window.showToast("Lỗi hoàn tác: " + res.message, "danger");
                } else {
                    const className = document.getElementById('lblSelectedClass').innerText.replace('- Lớp: ', '').split(' (')[0];
                    window.loadStudentsForClass(currentSelectedClassId, className);
                }
            } catch (err) {
                window.showToast("Lỗi hoàn tác: " + err.message, "danger");
            }
        }
    </script>
}
