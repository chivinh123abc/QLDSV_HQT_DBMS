<form id="studentForm" onsubmit="submitStudentForm(event)">
    <input type="hidden" id="oldStudentId" name="OldStudentId" />
    <input type="hidden" id="studentFormMode" value="add" />
    <input type="hidden" id="formClassId" name="ClassId" />

    <div class="row g-3">
        <div class="col-md-6">
            <label for="studentId" class="form-label">Mã Sinh Viên <span class="text-danger">*</span></label>
            <input type="text" class="form-control" id="studentId" name="StudentId" required maxlength="10">
        </div>
        <div class="col-md-6">
            <label for="password" class="form-label">Mật khẩu</label>
            <input type="password" class="form-control" id="password" name="Password" placeholder="Khoảng trắng hoặc bỏ qua nếu không thay đổi">
            <small class="text-muted" id="passwordHint" style="display:none;">Để trống để giữ mật khẩu cũ.</small>
        </div>
        
        <div class="col-md-4">
            <label for="firstName" class="form-label">Họ <span class="text-danger">*</span></label>
            <input type="text" class="form-control" id="firstName" name="FirstName" required maxlength="50">
        </div>
        <div class="col-md-4">
            <label for="lastName" class="form-label">Tên <span class="text-danger">*</span></label>
            <input type="text" class="form-control" id="lastName" name="LastName" required maxlength="10">
        </div>
        <div class="col-md-4">
            <label for="gender" class="form-label">Phái <span class="text-danger">*</span></label>
            <select class="form-select" id="gender" name="Gender" required>
                <option value="false">Nam</option>
                <option value="true">Nữ</option>
            </select>
        </div>

        <div class="col-md-4">
            <label for="dob" class="form-label">Ngày Sinh</label>
            <input type="date" class="form-control" id="dob" name="Dob">
        </div>
        <div class="col-md-8">
            <label for="address" class="form-label">Địa Chỉ</label>
            <input type="text" class="form-control" id="address" name="Address" maxlength="100">
        </div>

        <div class="col-12" id="onLeaveContainer" style="display: none;">
            <div class="form-check">
                <input class="form-check-input" type="checkbox" id="onLeave" name="OnLeave" value="true">
                <input type="hidden" name="OnLeave" value="false" /> <!-- Fallback for unchecked checkbox -->
                <label class="form-check-label" for="onLeave">Đã nghỉ học</label>
            </div>
        </div>
    </div>
    
    <div class="mt-4 text-end">
        <button type="button" class="btn btn-secondary" onclick="hideStudentModal()">Hủy</button>
        <button type="submit" class="btn btn-primary" id="btnSaveStudent">Lưu Sinh Viên</button>
    </div>
</form>
