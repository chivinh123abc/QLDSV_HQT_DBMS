@{
    ViewData["Title"] = "Nhập điểm môn học";
    var currentYear = DateTime.Now.Year;
    var defaultYear = $"{currentYear}-{currentYear + 1}";
}

<div class="dashboard-container animate__animated animate__fadeIn">
    @* ── Page Header ── *@
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
        <div>
            <h1 class="h3 fw-bold mb-1 text-gray-800">Quản lý & Nhập điểm</h1>
            <p class="text-muted mb-0 small">
                <i class="bi bi-info-circle me-1"></i>
                Chọn lớp tín chỉ để nhập điểm chuyên cần, giữa kỳ và cuối kỳ cho sinh viên.
            </p>
        </div>
        <div class="d-flex gap-2">
            <button type="button" class="btn btn-primary shadow-sm hover-scale d-flex align-items-center gap-2" id="btnSaveGrades">
                <i class="bi bi-save"></i>
                <span>Ghi Bảng Điểm</span>
            </button>
        </div>
    </div>

    @* ── Filter Section ── *@
    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-4">
            <form id="filterForm" class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label fw-semibold text-dark small">Niên Khóa</label>
                    <select class="form-select border-0 bg-light" id="filterYear">
                        <option value="">-- Tất cả Niên khóa --</option>
                        @if (ViewBag.SchoolYears != null)
                        {
                            foreach (var year in ViewBag.SchoolYears)
                            {
                                <option value="@year">@year</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold text-dark small">Học Kỳ</label>
                    <select class="form-select border-0 bg-light" id="filterSemester">
                        <option value="0">-- Tất cả Học kỳ --</option>
                        <option value="1">1</option>
                        <option value="2">2</option>
                        <option value="3">3</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold text-dark small">Môn Học</label>
                    <select class="form-select border-0 bg-light" id="filterSubject">
                        <option value="">-- Tất cả Môn học --</option>
                        @if (ViewBag.Subjects != null)
                        {
                            foreach (var subject in ViewBag.Subjects)
                            {
                                <option value="@subject.SubjectId">@subject.SubjectName</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label fw-semibold text-dark small">Nhóm</label>
                    <input type="number" class="form-control border-0 bg-light" id="filterGroup" value="0" min="0" placeholder="Tất cả nhóm" />
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold text-dark small">Mã Sinh Viên</label>
                    <input type="text" class="form-control border-0 bg-light" id="filterStudentId" placeholder="VD: N20DCCN..." />
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold text-dark small">Tên Sinh Viên</label>
                    <input type="text" class="form-control border-0 bg-light" id="filterStudentName" placeholder="VD: Nguyễn Văn A..." />
                </div>
                <div class="col-12 mt-3">
                    <button type="button" class="btn btn-outline-primary" id="btnLoadStudents">
                        <i class="bi bi-search me-1"></i> Tải danh sách
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" id="gradesTable">
                <thead class="bg-light bg-opacity-50">
                    <tr>
                        <th class="ps-4" style="width: 80px;">
                            <div class="d-flex align-items-center gap-2">
                                <i class="bi bi-hash text-primary"></i>
                                <span>STT</span>
                            </div>
                        </th>
                        <th style="width: 150px;">
                            <div class="d-flex align-items-center gap-2">
                                <i class="bi bi-person-badge text-primary"></i>
                                <span>Mã SV</span>
                            </div>
                        </th>
                        <th>
                            <div class="d-flex align-items-center gap-2">
                                <i class="bi bi-person text-primary"></i>
                                <span>Họ và Tên</span>
                            </div>
                        </th>
                        <th class="text-center" style="width: 140px;">
                            <div class="d-flex align-items-center gap-2 justify-content-center">
                                <i class="bi bi-check-circle text-primary"></i>
                                <span>Chuyên cần</span>
                            </div>
                        </th>
                        <th class="text-center" style="width: 140px;">
                            <div class="d-flex align-items-center gap-2 justify-content-center">
                                <i class="bi bi-pencil-square text-primary"></i>
                                <span>Giữa kỳ</span>
                            </div>
                        </th>
                        <th class="text-center" style="width: 140px;">
                            <div class="d-flex align-items-center gap-2 justify-content-center">
                                <i class="bi bi-award text-primary"></i>
                                <span>Cuối kỳ</span>
                            </div>
                        </th>
                        <th class="text-center pe-4" style="width: 140px;">
                            <div class="d-flex align-items-center gap-2 justify-content-center">
                                <i class="bi bi-calculator text-primary"></i>
                                <span>Điểm TB</span>
                            </div>
                        </th>
                    </tr>
                </thead>
                <tbody id="gradesTbody">
                    <!-- Data will be loaded here via JS -->
                </tbody>
            </table>
        </div>
        <div class="card-footer bg-white py-3 border-top-0">
            <div class="d-flex justify-content-between align-items-center">
                <div class="text-muted small" id="statusMessage">
                    <i class="bi bi-info-circle me-1"></i>
                    Vui lòng chọn bộ lọc và nhấn Tải danh sách.
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .border-dashed {
        border-style: dashed !important;
        border-color: #dee2e6 !important;
    }

    .border-dashed:focus {
        border-style: solid !important;
        border-color: #86b7fe !important;
    }

    .custom-input-group {
        border-radius: 8px;
        overflow: hidden;
        border: 1px solid #e0e0e0;
        transition: all 0.2s ease;
    }

    .custom-input-group:focus-within {
        border-color: var(--bs-primary);
        box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.15);
    }

    .custom-input-group .input-group-text,
    .custom-input-group .form-select {
        border: none;
    }

    .text-xs {
        font-size: 0.7rem;
    }

    .icon-box {
        width: 42px;
        height: 42px;
        display: flex;
        align-items: center;
        justify-content: center;
    }
</style>

@section Scripts {
    <script src="~/js/pages/grade/index.js"></script>
}
