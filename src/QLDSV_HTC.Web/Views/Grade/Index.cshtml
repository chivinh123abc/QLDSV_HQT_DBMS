@{
    ViewData["Title"] = "Nhập điểm môn học";
}

<div class="dashboard-container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0 text-gray-800">Nhập điểm - Cập nhật kết quả thi</h1>
    </div>

    <!-- Filter/Search -->
    <div class="qldsv-card border-0 shadow-sm mb-4 p-3 bg-light">
        <h6 class="fw-bold mb-3 text-primary"><i class="bi bi-search me-2"></i>Chọn thông tin Lớp tín chỉ</h6>
        <form class="row g-3 align-items-end">
            <div class="col-md-2">
                <label class="form-label text-sm fw-medium">Niên khóa</label>
                <select class="form-select form-select-sm">
                    <option selected>2021-2022</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label text-sm fw-medium">Học kỳ</label>
                <select class="form-select form-select-sm">
                    <option selected>1</option>
                    <option>2</option>
                </select>
            </div>
            @* <div class="col-md-3">
            <label class="form-label text-sm fw-medium">Lớp</label>
            <select class="form-select form-select-sm">
            <option selected>D15CQCN01-N</option>
            </select>
            </div> *@
            <div class="col-md-3">
                <label class="form-label text-sm fw-medium">Môn học</label>
                <select class="form-select form-select-sm">
                    <option selected>Cấu trúc dữ liệu và giải thuật</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label text-sm fw-medium">Nhóm</label>
                <div class="d-flex gap-2">
                    <select class="form-select form-select-sm">
                        <option selected>1</option>
                        <option>2</option>
                    </select>
                </div>
            </div>
            <div class="col-md-3">
                <button type="button" class="btn btn-sm btn-primary px-3 py-2">Tải dữ liệu</button>
            </div>
        </form>
    </div>

    <div class="qldsv-card border-0 shadow-sm">
        <div class="p-3 border-bottom d-flex justify-content-between align-items-center">
            <h6 class="m-0 fw-bold">Danh sách sinh viên nhóm 1 - Môn Cấu trúc dữ liệu và giải thuật</h6>
            <div class="d-flex gap-2">
                <button type="button" class="btn btn-sm btn-info text-white"><i class="bi bi-printer me-1"></i> In Bảng
                    Điểm Môn Học</button>
                <button type="button" class="btn btn-sm btn-success"><i class="bi bi-save me-1"></i> Ghi Bảng
                    Điểm</button>
            </div>
        </div>
        <div class="table-responsive p-3">
            <table class="table table-hover table-bordered align-middle mb-0 text-center">
                <thead class="table-light">
                    <tr>
                        <th scope="col" width="60">STT</th>
                        <th scope="col" width="120">Mã SV</th>
                        <th scope="col" class="text-start">Họ và Tên</th>
                        <th scope="col" width="100">Điểm CC (10%)</th>
                        <th scope="col" width="100">Điểm GK (30%)</th>
                        <th scope="col" width="100">Điểm CK (60%)</th>
                        <th scope="col" width="100">Trung bình</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>1</td>
                        <td class="fw-medium">N15DCCN001</td>
                        <td class="text-start">Nguyễn Văn A</td>
                        <td><input type="number" class="form-control form-control-sm text-center" value="10" min="0"
                                max="10" step="0.5"></td>
                        <td><input type="number" class="form-control form-control-sm text-center" value="8" min="0"
                                max="10" step="0.5"></td>
                        <td><input type="number" class="form-control form-control-sm text-center" value="7.5" min="0"
                                max="10" step="0.5"></td>
                        <td><span class="fw-bold text-success">7.9</span></td>
                    </tr>
                    <tr>
                        <td>2</td>
                        <td class="fw-medium">N15DCCN002</td>
                        <td class="text-start">Trần Thị B</td>
                        <td><input type="number" class="form-control form-control-sm text-center" value="9" min="0"
                                max="10" step="0.5"></td>
                        <td><input type="number" class="form-control form-control-sm text-center" value="9" min="0"
                                max="10" step="0.5"></td>
                        <td><input type="number" class="form-control form-control-sm text-center" value="8.5" min="0"
                                max="10" step="0.5"></td>
                        <td><span class="fw-bold text-success">8.7</span></td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
