@using QLDSV_HTC.Domain.Enums
@{
    ViewData["Title"] = "Báo cáo động";
}

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="card-title mb-0">Cấu hình báo cáo</h5>
                </div>
                <div class="card-body">
                    <form id="dynamicReportForm">
                        <!-- Table Selection -->
                        <div class="mb-3">
                            <label class="form-label fw-bold">1. Chọn bảng chính</label>
                            <select id="tableNameSelect" class="form-select" required>
                                <option value="">-- Đang tải danh sách bảng... --</option>
                            </select>
                        </div>

                        <!-- Joins -->
                        <div class="mb-3" id="joinSelectionGroup" style="display: none;">
                            <label class="form-label fw-bold d-flex justify-content-between align-items-center">
                                2. Kết hợp bảng (JOIN)
                                <button type="button" class="btn btn-sm btn-outline-info" id="addJoinBtn">
                                    <i class="bi bi-plus"></i> Thêm bảng
                                </button>
                            </label>
                            <div id="joinsContainer">
                                <!-- Join rows will be appended here -->
                            </div>
                        </div>

                        <!-- Column Selection -->
                        <div class="mb-3">
                            <label class="form-label fw-bold">3. Chọn cột hiển thị</label>
                            <div id="columnSelectionContainer" class="border rounded p-2 mb-2"
                                style="max-height: 200px; overflow-y: auto;">
                                <p class="text-muted small mb-0">Vui lòng chọn bảng trước.</p>
                            </div>
                            <div class="text-end">
                                <button type="button" class="btn btn-sm btn-outline-secondary" id="toggleAggregationBtn" disabled>
                                    <i class="bi bi-calculator"></i> Chế độ Thống kê (Group By)
                                </button>
                            </div>
                        </div>

                        <!-- Aggregation Section -->
                        <div class="mb-3" id="aggregationGroup" style="display: none;">
                            <label class="form-label fw-bold">4. Cấu hình Thống kê</label>
                            <div id="aggregationContainer" class="border rounded p-2 bg-light" style="max-height: 350px; overflow-y: auto;">
                                <!-- Aggregation items will be rendered here -->
                            </div>
                        </div>

                        <!-- Filters -->
                        <div class="mb-3">
                            <label class="form-label fw-bold d-flex justify-content-between align-items-center">
                                5. Điều kiện lọc (WHERE)
                                <button type="button" class="btn btn-sm btn-outline-primary" id="addFilterBtn" disabled>
                                    <i class="bi bi-plus"></i> Thêm điều kiện
                                </button>
                            </label>
                            <div id="filtersContainer">
                                <!-- Filter rows will be appended here -->
                            </div>
                        </div>

                        <hr />
                        <div class="d-grid gap-2">
                            <button type="button" class="btn btn-primary" id="previewBtn" disabled>
                                <i class="bi bi-table"></i> Xem trước dữ liệu
                            </button>
                            <button type="button" class="btn btn-success" id="generatePdfBtn" disabled>
                                <i class="bi bi-file-pdf"></i> Xuất PDF
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-light d-flex justify-content-between align-items-center">
                    <h5 class="card-title mb-0">Xem trước kết quả</h5>
                    <span id="recordCountBadge" class="badge bg-secondary">0 dòng</span>
                </div>
                <div class="card-body p-0 overflow-auto" style="max-height: 800px;">
                    <div id="previewResult" class="table-responsive">
                        <table class="table table-hover table-striped table-bordered mb-0">
                            <thead class="table-dark" id="previewTableHead">
                                <tr>
                                    <th class="text-center text-muted small py-4">Kết quả sẽ hiển thị tại đây</th>
                                </tr>
                            </thead>
                            <tbody id="previewTableBody">
                                <!-- Data will be rendered here -->
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Template for a join row (hidden) -->
<template id="joinRowTemplate">
    <div class="join-row border rounded p-2 mb-2 bg-light position-relative">
        <button type="button" class="btn-close position-absolute top-0 end-0 m-1 remove-join-btn"
            aria-label="Xóa"></button>
        <div class="mb-2">
            <select class="form-select form-select-sm join-table-select" required>
                <option value="">-- Chọn bảng --</option>
            </select>
        </div>
        <div class="pe-3">
            <select class="form-select form-select-sm join-type-select">
                <option value="INNER JOIN">INNER JOIN (Lấy phần giao)</option>
                <option value="LEFT JOIN">LEFT JOIN (Lấy hết bảng trái)</option>
            </select>
        </div>
    </div>
</template>

<!-- Template for a filter row (hidden) -->
<template id="filterRowTemplate">
    <div class="filter-row border rounded p-2 mb-2 bg-light position-relative">
        <button type="button" class="btn-close position-absolute top-0 end-0 m-1 remove-filter-btn"
            aria-label="Xóa"></button>
        <div class="mb-2 pe-3">
            <select class="form-select form-select-sm filter-column-select" required>
                <option value="">-- Chọn cột --</option>
            </select>
        </div>
        <div class="mb-2 pe-3">
            <select class="form-select form-select-sm filter-operator-select" required>
                <option value="0">Bằng (=)</option>
                <option value="1">Không bằng (!=)</option>
                <option value="2">Chứa</option>
                <option value="3">Bắt đầu bằng</option>
                <option value="4">Kết thúc bằng</option>
                <option value="5">Lớn hơn (&gt;)</option>
                <option value="6">Lớn hơn hoặc bằng (&gt;=)</option>
                <option value="7">Nhỏ hơn (&lt;)</option>
                <option value="8">Nhỏ hơn hoặc bằng (&lt;=)</option>
            </select>
        </div>
        <div class="pe-3">
            <input type="text" class="form-control form-control-sm filter-value-input" placeholder="Giá trị..."
                required />
        </div>
    </div>
</template>

@section Scripts {
    <script src="~/js/dynamic-report.js" asp-append-version="true"></script>
}
