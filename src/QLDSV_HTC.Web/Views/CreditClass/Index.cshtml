@model QLDSV_HTC.Web.Models.CreditClassManagementViewModel
@using QLDSV_HTC.Domain.Constants

@{
    ViewData["Title"] = "Quản lý Lớp tín chỉ";
    var isPGV = User.IsInRole("PGV");
    var hasFaculty = !string.IsNullOrEmpty(Model.CurrentFacultyId);

    ViewData["isPGV"] = isPGV;
    ViewData["hasFaculty"] = hasFaculty;
}

<div class="dashboard-container fade-in-up">
    @* ── Bảng danh sách LTC ── *@
    @await Html.PartialAsync("_CreditClassTable", Model, ViewData)
</div>


@* ══════════════════════════════════════════════════════════
MODAL: Nhập danh mục LTC / Xác nhận xóa
══════════════════════════════════════════════════════════ *@
@await Html.PartialAsync("_CreditClassFormModal", Model, ViewData)
<partial name="_DeleteConfirmModal" />

@section Scripts {
    <script src="~/js/form-helpers.js" asp-append-version="true"></script>
    <script>
        (function () {
            'use strict';

            const URL_ADD = '@Url.Action("Add", "CreditClass")';
            const URL_EDIT = '@Url.Action("Edit", "CreditClass")';
            const URL_DELETE = '@Url.Action("Delete", "CreditClass")';

            let snapshotData = null;
            let selectedId = null;
            let originalId = null;
            
            // -- UNDO STACK STATE --
            let undoStack = [];
            let forceClose = false;

            const modal = document.getElementById('creditClassFormModal');
            const deleteModal = document.getElementById('deleteConfirmModal');
            
            // Fields
            const fldId = document.getElementById('fldCreditClassId');
            const fldYear = document.getElementById('fldYear');
            const fldSemester = document.getElementById('fldSemester');
            const fldSubjectId = document.getElementById('fldSubjectId');
            const fldGroup = document.getElementById('fldGroup');
            const fldLecturerId = document.getElementById('fldLecturerId');
            const fldFacultyId = document.getElementById('fldFacultyId');
            const fldMinStudents = document.getElementById('fldMinStudents');
            const fldIsCancelled = document.getElementById('fldIsCancelled');

            // Buttons
            const btnThem = document.getElementById('btnFormThem');
            const btnXoa = document.getElementById('btnFormXoa');
            const btnGhi = document.getElementById('btnFormGhi');
            const btnPhucHoi = document.getElementById('btnFormPhucHoi');
            const btnHuy = document.getElementById('btnFormHuy');

            // ── Shared form helpers
            const helpers = createFormHelpers({
                alertEl: document.getElementById('formAlert'),
                modeLabelEl: document.getElementById('formModeLabel'),
                buttons: { them: btnThem, xoa: btnXoa, ghi: btnGhi, phucHoi: btnPhucHoi, huy: btnHuy },
                allFields: [fldYear, fldSemester, fldSubjectId, fldGroup, fldLecturerId, fldFacultyId, fldMinStudents, fldIsCancelled],
                requiredFields: [fldYear, fldSemester, fldSubjectId, fldGroup, fldFacultyId, fldMinStudents],
                getSelectedId: () => selectedId,
            });

            // Delete Modal Logic
            let pendingDeleteId = null;
            if (deleteModal) {
                document.getElementById('btnConfirmDelete').addEventListener('click', async () => {
                    bootstrap.Modal.getInstance(deleteModal)?.hide();
                    if (pendingDeleteId) await doDelete(pendingDeleteId);
                });
            }

            function showDeleteModal(id, title) {
                pendingDeleteId = id;
                document.getElementById('deleteTargetId').textContent = "LTC " + id;
                document.getElementById('deleteTargetName').textContent = title;
                bootstrap.Modal.getOrCreateInstance(deleteModal).show();
            }

            if (!modal) return;

            const btnCancelModal = modal.querySelector('.btn-cancel-modal');
            const btnSaveModal = modal.querySelector('.btn-save-modal');

            // Mở modal qua nút Thêm Mới → reset về view
            document.getElementById('btnOpenCreditClassForm')?.addEventListener('click', resetToView);

            // Mở modal → clear stack
            modal.addEventListener('show.bs.modal', () => {
                undoStack = [];
                forceClose = false;
            });

            // Chặn đóng modal nếu còn stack
            modal.addEventListener('hide.bs.modal', async (e) => {
                if (undoStack.length > 0 && !forceClose) {
                    e.preventDefault();
                    const isConfirmed = await window.showConfirmDialog(
                        "Dữ liệu chưa đóng",
                        "Ghi nhận có thay đổi chưa lưu (bạn sẽ mất các trạng thái có thể Phục hồi).<br><br>Nhấn <b>Tiếp tục đóng</b> nếu bạn không cần Phục hồi nữa.<br>Nhấn <b>Hủy bỏ</b> để ở lại form và chọn nút dưới cùng.",
                        { confirmText: "Tiếp tục đóng", cancelText: "Hủy bỏ", isDanger: true }
                    );
                    if (isConfirmed) {
                        forceClose = true;
                        bootstrap.Modal.getInstance(modal).hide();
                    }
                }
            });

            btnSaveModal?.addEventListener('click', async () => {
                if (undoStack.length === 0) {
                    forceClose = true;
                    bootstrap.Modal.getInstance(modal).hide();
                    return;
                }

                const message = "Dữ liệu đã được <b>Ghi</b> vào hệ thống. Nếu đóng cửa sổ, bạn sẽ không thể dùng chức năng 'Phục hồi' (Undo) cho các thao tác vừa rồi.<br><br>Bạn có chắc chắn muốn thoát?";
                
                const isConfirmed = await window.showConfirmDialog(
                    "Xác nhận Thoát", message,
                    { confirmText: "Xác nhận", cancelText: "Trở lại" }
                );
                
                if (isConfirmed) {
                    undoStack = [];
                    forceClose = true;
                    bootstrap.Modal.getInstance(modal).hide();
                }
            });

            btnCancelModal?.addEventListener('click', async () => {
                if (undoStack.length === 0) {
                    forceClose = true;
                    bootstrap.Modal.getInstance(modal).hide();
                    return;
                }

                const message = "Hành động này sẽ <b>Hoàn Tác toàn bộ</b> các thay đổi bạn vừa thực hiện trong bảng vừa rồi.<br>Bạn có chắc chắn muốn xóa bỏ công sức vừa làm?";
                
                const isConfirmed = await window.showConfirmDialog(
                    "Hoàn Tác & Đóng", message,
                    { confirmText: "Xác nhận Hoàn tác", cancelText: "Giữ lại", isDanger: true }
                );

                if (isConfirmed) {
                    btnCancelModal.disabled = true;
                    while(undoStack.length > 0) {
                        await executeUndo();
                    }
                    undoStack = [];
                    forceClose = true;
                    btnCancelModal.disabled = false;
                    bootstrap.Modal.getInstance(modal).hide();
                }
            });

            // Reset khi đóng modal toàn phần
            modal.addEventListener('hidden.bs.modal', resetToView);

            // Mini table row selection
            document.getElementById('miniCreditClassBody')?.addEventListener('click', e => {
                if (helpers.getMode() === 'add') return;
                const row = e.target.closest('tr.mini-row');
                if (!row) return;
                selectMiniRow(row);
            });

            // ── Nút Thêm
            btnThem.addEventListener('click', () => {
                deselectMiniRow();
                selectedId = null;
                snapshotData = null;
                clearFields();
                helpers.clearValidation();
                helpers.setMode('add');

                // Tự động gán niên khóa + học kỳ hiện tại
                const now = new Date();
                const curY = now.getFullYear();
                const curM = now.getMonth() + 1;
                
                // Niên khóa
                fldYear.value = (curM < 8) ? `${curY - 1}-${curY}` : `${curY}-${curY + 1}`;
                
                // Học kỳ: 9-1: HK1, 2-6: HK2, 7-8: HK3
                if (curM >= 9 || curM === 1) fldSemester.value = "1";
                else if (curM >= 2 && curM <= 6) fldSemester.value = "2";
                else fldSemester.value = "3";

                fldYear.disabled = false;
                fldYear.focus();
                
                // Mới tạo → có thể xóa (nhưng thường dùng Undo)
                btnXoa.disabled = false;
                btnXoa.title = "Xóa lớp tín chỉ này";
                
                // Trạng thái huỷ luôn tắt khi tạo mới
                fldIsCancelled.checked = false;
                
                helpers.showAlert('Nhập thông tin Lớp Tín Chỉ mới rồi nhấn <b>Ghi</b> để lưu.', 'info');
            });

            // ── Nút Xóa
            btnXoa.addEventListener('click', () => {
                if (!selectedId) return;
                showDeleteModal(selectedId, `Môn ${fldSubjectId.options[fldSubjectId.selectedIndex]?.text} - Nhóm ${fldGroup.value}`);
            });

            // ── Nút Ghi
            btnGhi.addEventListener('click', async () => {
                if (!helpers.validateForm()) return;

                const payload = {
                    oldCreditClassId: originalId,
                    creditClassId: parseInt(fldId.value) || 0,
                    year: fldYear.value.trim(),
                    semester: parseInt(fldSemester.value),
                    subjectId: fldSubjectId.value.trim(),
                    group: parseInt(fldGroup.value),
                    lecturerId: fldLecturerId.value.trim(),
                    facultyId: fldFacultyId.value.trim(),
                    minStudents: parseInt(fldMinStudents.value),
                    isCancelled: fldIsCancelled.checked
                };

                try {
                    const res = await fetchJson(helpers.getMode() === 'add' ? URL_ADD : URL_EDIT, payload);
                    if (res.success) {
                        window.showToast(res.message, 'success');
                        
                        // Lưu vào stack trước khi cập nhật
                        if (helpers.getMode() === 'add') {
                            const newId = res.newId || 0; 
                            payload.id = newId;
                            payload.creditClassId = newId;
                            fldId.value = newId;
                            addRowToTables(payload, newId);
                            undoStack.push({ action: 'delete', payload: { creditClassId: newId } });
                        } else {
                            updateRowInTables(payload, originalId);
                            if (snapshotData) {
                                undoStack.push({
                                    action: 'edit',
                                    payload: {
                                        oldCreditClassId: payload.creditClassId,
                                        creditClassId: snapshotData.id,
                                        year: snapshotData.year,
                                        semester: snapshotData.semester,
                                        subjectId: snapshotData.subId,
                                        group: snapshotData.group,
                                        lecturerId: snapshotData.lecId,
                                        facultyId: snapshotData.facId,
                                        minStudents: snapshotData.min,
                                        isCancelled: snapshotData.cancelled === 'true' || snapshotData.cancelled === true
                                    }
                                });
                            }
                        }
                        
                        originalId = parseInt(fldId.value);
                        selectedId = parseInt(fldId.value);
                        snapshotData = { ...payload, id: selectedId, 
                            subId: payload.subjectId, lecId: payload.lecturerId, facId: payload.facultyId, min: payload.minStudents, cancelled: payload.isCancelled === true  };
                        
                        highlightMiniRow(selectedId);
                        helpers.setMode('edit');
                    } else {
                        window.showToast(res.message, 'danger');
                    }
                } catch (err) {
                    window.showToast('Lỗi: ' + err.message, 'danger');
                }
            });

            // ── Nút Phục hồi
            btnPhucHoi.addEventListener('click', async () => {
                if (undoStack.length === 0) {
                    helpers.showAlert('Không có hành động nào để phục hồi.', 'info');
                    return;
                }
                await executeUndo();
                resetToView();
                helpers.showAlert('Đã hoàn tác 1 hành động trên hệ thống.', 'warning');
            });

            // ── Nút Hủy
            btnHuy?.addEventListener('click', resetToView);

            // ── Edit/Delete on Main Table
            document.getElementById('creditClassTableBody')?.addEventListener('click', e => {
                const editBtn = e.target.closest('.btn-edit-row');
                const delBtn = e.target.closest('.btn-delete-row');

                if (editBtn) {
                    const ds = editBtn.dataset;
                    bootstrap.Modal.getOrCreateInstance(modal).show();
                    setTimeout(() => {
                        const data = {
                            id: ds.id, year: ds.year, semester: ds.semester,
                            subId: ds.subId, group: ds.group, lecId: ds.lecId,
                            facId: ds.facId, min: ds.min, cancelled: ds.cancelled === 'true',
                            regCount: parseInt(ds.regCount || '0', 10)
                        };
                        populateFields(data);
                        originalId = data.id;
                        selectedId = data.id;
                        snapshotData = { ...data };
                        undoStack = []; 
                        helpers.setMode('edit');

                        // Disable Xóa nếu đã có SV đăng ký
                        if (data.regCount > 0) {
                            btnXoa.disabled = true;
                            btnXoa.title = `Không thể xóa LTC đã có ${data.regCount} SV đăng ký`;
                        } else {
                            btnXoa.disabled = false;
                            btnXoa.title = "Xóa lớp tín chỉ này";
                        }

                        highlightMiniRow(ds.id);
                        helpers.hideAlert();
                    }, 200);
                }

                if (delBtn) {
                    const id = delBtn.dataset.id;
                    const tr = delBtn.closest('tr');
                    const regCount = parseInt(tr.dataset.regCount || '0', 10);
                    
                    if (regCount > 0) {
                        window.showToast(`Không thể xóa LTC đã có ${regCount} SV đăng ký`, 'warning');
                        return;
                    }

                    const subName = tr.querySelector('td:nth-child(3)').textContent;
                    showDeleteModal(id, subName);
                }
            });

            // ── Filter (Client-side)
            const searchInput = document.getElementById('creditClassSearch');
            const btnClearSearch = document.getElementById('btnClearSearch');

            searchInput?.addEventListener('input', e => {
                const q = e.target.value.toLowerCase();
                
                if (btnClearSearch) {
                    btnClearSearch.style.display = q.length > 0 ? 'block' : 'none';
                }

                let vis = 0;
                document.querySelectorAll('#creditClassTableBody table tr[data-id]').forEach(row => {
                    const txt = (row.dataset.id + ' ' + row.dataset.search).toLowerCase();
                    const match = txt.includes(q);
                    row.style.display = match ? '' : 'none';
                    if (match) vis++;
                });
                const vc = document.getElementById('visibleCount');
                if (vc) vc.textContent = String(vis);
            });

            // Clear search button
            btnClearSearch?.addEventListener('click', () => {
                searchInput.value = '';
                searchInput.dispatchEvent(new Event('input'));
                searchInput.focus();
            });

            // ESC key to clear search
            searchInput?.addEventListener('keydown', e => {
                if (e.key === 'Escape') {
                    searchInput.value = '';
                    searchInput.dispatchEvent(new Event('input'));
                }
            });

            // ── Helpers
            function resetToView() {
                selectedId = null; snapshotData = null; originalId = null; undoStack = [];
                clearFields(); helpers.clearValidation(); helpers.hideAlert(); deselectMiniRow();
                helpers.setMode('view');
            }

            function clearFields() {
                fldId.value = '';
                fldYear.value = '';
                fldSemester.value = '';
                fldSubjectId.value = '';
                fldGroup.value = '1';
                fldLecturerId.value = '';
                fldFacultyId.value = '';
                fldMinStudents.value = '30';
                fldIsCancelled.checked = false;
            }

            function populateFields(d) {
                fldId.value = d.id || '';
                fldYear.value = d.year || '';
                fldSemester.value = d.semester || '';
                fldSubjectId.value = d.subId || '';
                fldGroup.value = d.group || '1';
                fldLecturerId.value = d.lecId || '';
                fldFacultyId.value = d.facId || '';
                fldMinStudents.value = d.min || '30';
                fldIsCancelled.checked = d.cancelled === true || d.cancelled === 'true';
            }

            function selectMiniRow(row) {
                deselectMiniRow();
                row.classList.add('table-active', 'fw-semibold');
                const ds = row.dataset;
                const data = {
                    id: ds.id, year: ds.year, semester: ds.semester,
                    subId: ds.subId, group: ds.group, lecId: ds.lecId,
                    facId: ds.facId, min: ds.min, cancelled: ds.cancelled === 'true',
                    regCount: parseInt(ds.regCount || '0', 10)
                };
                populateFields(data);
                originalId = data.id;
                selectedId = data.id;
                snapshotData = { ...data };
                undoStack = [];
                helpers.setMode('edit');

                if (data.regCount > 0) {
                    btnXoa.disabled = true;
                    btnXoa.title = `Không thể xóa LTC đã có ${data.regCount} SV đăng ký`;
                } else {
                    btnXoa.disabled = false;
                    btnXoa.title = "Xóa lớp tín chỉ này";
                }

                helpers.hideAlert();
            }

            function highlightMiniRow(id) {
                deselectMiniRow();
                const row = document.querySelector(`#miniCreditClassBody tr[data-id="${CSS.escape(id)}"]`);
                if (row) row.classList.add('table-active', 'fw-semibold');
            }

            function deselectMiniRow() {
                document.querySelectorAll('#miniCreditClassBody tr.table-active')
                    .forEach(r => r.classList.remove('table-active', 'fw-semibold'));
            }

            function mainRowHtml(p) {
                const isPGV = @(isPGV.ToString().ToLower());
                const subName = fldSubjectId.options[fldSubjectId.selectedIndex]?.text.split(' (')[0] || p.subjectId;
                const lecName = fldLecturerId.options[fldLecturerId.selectedIndex]?.text.split(' (')[0] || '';
                const registeredCount = p.registeredCount || 0;
                
                let statusHtml = '';
                if (p.isCancelled) {
                    statusHtml = '<span class="badge bg-danger-subtle text-danger border border-danger-subtle px-2 py-1 rounded-pill"><i class="bi bi-x-circle-fill me-1"></i>Đã hủy</span>';
                } else if (registeredCount < p.minStudents) {
                    statusHtml = '<span class="badge bg-warning-subtle text-warning border border-warning-subtle px-2 py-1 rounded-pill"><i class="bi bi-hourglass-split me-1"></i>Chưa đủ SV</span>';
                } else {
                    statusHtml = '<span class="badge bg-success-subtle text-success border border-success-subtle px-2 py-1 rounded-pill"><i class="bi bi-check-circle-fill me-1"></i>Đã mở</span>';
                }
                
                let registeredHtml = registeredCount > 0 
                    ? `<div class="badge ${registeredCount < p.minStudents ? 'bg-warning-subtle text-warning border-warning-subtle' : 'bg-success-subtle text-success border-success-subtle'} border px-2 py-1 rounded-3 shadow-sm"><span class="fw-bold fs-6">${registeredCount}</span></div>`
                    : '<span class="text-muted opacity-50">0</span>';

                let actions = isPGV ? `
                    <td class="text-end pe-3">
                        <div class="d-flex justify-content-end gap-1">
                            <button class="btn btn-sm btn-outline-info shadow-none hover-scale rounded-3"
                                    title="Xem DSSV" onclick="window.location.href='@Url.Action("Index", "Registration")?filterCreditClassId=${p.id}'">
                                <i class="bi bi-people"></i>
                            </button>
                            <button class="btn btn-sm btn-outline-primary btn-edit-row shadow-none hover-scale rounded-3"
                                    title="Sửa lớp tín chỉ"
                                    data-id="${p.id}" data-year="${p.year}" data-semester="${p.semester}"
                                    data-sub-id="${p.subjectId}" data-group="${p.group}"
                                    data-lec-id="${p.lecturerId}" data-fac-id="${p.facultyId}"
                                    data-min="${p.minStudents}" data-reg-count="${registeredCount}"
                                    data-cancelled="${p.isCancelled}">
                                <i class="bi bi-pencil"></i>
                            </button>
                            <button class="btn btn-sm btn-outline-danger shadow-none hover-scale rounded-3 ${registeredCount > 0 ? 'disabled opacity-50' : 'btn-delete-row'}"
                                    title="${registeredCount > 0 ? `Không thể xóa (đã có ${registeredCount} SV)` : 'Xóa lớp tín chỉ'}" 
                                    data-id="${p.id}">
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                    </td>` : '';

                return `
                    <td><span class="badge bg-primary-subtle text-primary border border-primary-subtle font-monospace px-2 rounded-pill shadow-sm">${p.id}</span></td>
                    <td class="small py-3">
                        <div class="fw-bold text-dark">${p.year}</div>
                        <div class="text-muted" style="font-size: 0.7rem;"><i class="bi bi-clock-history me-1"></i>Học kỳ ${p.semester}</div>
                    </td>
                    <td>
                        <div class="fw-bold text-dark mb-1">${subName}</div>
                        <div class="text-muted small font-monospace"><i class="bi bi-journal-code me-1"></i>${p.subjectId}</div>
                    </td>
                    <td class="text-center">
                        <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle px-2 py-1 rounded-3">Nhóm ${p.group}</span>
                    </td>
                    <td class="text-truncate" style="max-width:200px;">
                        <div class="fw-medium text-dark">${lecName}</div>
                        <div class="text-muted small" style="font-size: 0.75rem;"><i class="bi bi-person-badge me-1"></i>${p.lecturerId}</div>
                    </td>
                    <td class="text-center fw-medium text-muted">${p.minStudents}</td>
                    <td class="text-center">${registeredHtml}</td>
                    <td class="text-center">${statusHtml}</td>
                    ${actions}
                `;
            }

            function miniRowHtml(p) {
                const subName = fldSubjectId.options[fldSubjectId.selectedIndex]?.text.split(' (')[0] || p.subjectId;
                const statusHtml = p.isCancelled
                    ? '<span class="badge bg-danger-subtle text-danger border border-danger-subtle px-2 py-1 rounded-pill" style="font-size:0.65rem;"><i class="bi bi-x-circle me-1"></i>HỦY</span>'
                    : '<span class="badge bg-success-subtle text-success border border-success-subtle px-2 py-1 rounded-pill" style="font-size:0.65rem;"><i class="bi bi-check-circle me-1"></i>MỞ</span>';

                return `
                    <td class="fw-bold font-monospace text-primary small ps-3">#${p.id}</td>
                    <td class="text-truncate small py-2" style="max-width: 150px;" title="${subName}">${subName}</td>
                    <td class="text-center">
                        <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle px-2 py-1 rounded-2" style="font-size:0.65rem;">G${p.group}</span>
                    </td>
                    <td class="text-center text-muted small tabular-nums">${p.minStudents}</td>
                    <td class="text-center pe-3">${statusHtml}</td>
                `;
            }

            function addRowToTables(payload, newId) {
                payload.id = newId;
                payload.registeredCount = 0; // Mới tạo luôn là 0

                // Thêm vào bảng mini
                const trMini = document.createElement('tr');
                trMini.className = 'mini-row transition-base table-active fw-semibold';
                trMini.setAttribute('role', 'button');
                trMini.dataset.id = newId;
                trMini.dataset.year = payload.year;
                trMini.dataset.semester = payload.semester;
                trMini.dataset.subId = payload.subjectId;
                trMini.dataset.group = payload.group;
                trMini.dataset.lecId = payload.lecturerId;
                trMini.dataset.facId = payload.facultyId;
                trMini.dataset.min = payload.minStudents;
                trMini.dataset.cancelled = payload.isCancelled;
                trMini.dataset.regCount = payload.registeredCount;
                trMini.innerHTML = miniRowHtml(payload);
                document.getElementById('miniCreditClassBody')?.prepend(trMini);

                // Thêm vào bảng main
                const trMain = document.createElement('tr');
                trMain.dataset.id = newId;
                trMain.dataset.year = payload.year;
                trMain.dataset.semester = payload.semester;
                trMain.dataset.subId = payload.subjectId;
                trMain.dataset.group = payload.group;
                trMain.dataset.lecId = payload.lecturerId;
                trMain.dataset.facId = payload.facultyId;
                trMain.dataset.min = payload.minStudents;
                trMain.dataset.cancelled = payload.isCancelled;
                trMain.dataset.regCount = payload.registeredCount;
                
                const subName = fldSubjectId.options[fldSubjectId.selectedIndex]?.text.split(' (')[0] || '';
                const lecName = fldLecturerId.options[fldLecturerId.selectedIndex]?.text.split(' (')[0] || '';
                trMain.dataset.search = subName + ' ' + lecName;
                
                trMain.innerHTML = mainRowHtml(payload);
                const tBody = document.getElementById('creditClassTableBody')?.querySelector('tbody');
                
                // Nếu đang hiển thị no-data
                const noDataRow = tBody?.querySelector('td[colspan]');
                if (noDataRow) {
                    tBody.innerHTML = '';
                    tBody.appendChild(trMain);
                } else {
                    tBody?.prepend(trMain);
                }
            }

            function updateRowInTables(payload, id) {
                payload.id = id;
                
                // Cập nhật bảng mini
                const trMini = document.querySelector(`#miniCreditClassBody tr[data-id="${id}"]`);
                if (trMini) {
                    trMini.dataset.year = payload.year;
                    trMini.dataset.semester = payload.semester;
                    trMini.dataset.subId = payload.subjectId;
                    trMini.dataset.group = payload.group;
                    trMini.dataset.lecId = payload.lecturerId;
                    trMini.dataset.facId = payload.facultyId;
                    trMini.dataset.min = payload.minStudents;
                    trMini.dataset.cancelled = payload.isCancelled;
                    trMini.dataset.regCount = payload.registeredCount || 0;
                    trMini.innerHTML = miniRowHtml(payload);
                    trMini.classList.add('table-active', 'fw-semibold');
                }

                // Cập nhật bảng main
                const trMain = document.querySelector(`#creditClassTableBody tr[data-id="${id}"]`);
                if (trMain) {
                    trMain.dataset.year = payload.year;
                    trMain.dataset.semester = payload.semester;
                    trMain.dataset.subId = payload.subjectId;
                    trMain.dataset.group = payload.group;
                    trMain.dataset.lecId = payload.lecturerId;
                    trMain.dataset.facId = payload.facultyId;
                    trMain.dataset.min = payload.minStudents;
                    trMain.dataset.cancelled = payload.isCancelled;
                    trMain.dataset.regCount = payload.registeredCount || 0;
                    
                    const subName = fldSubjectId.options[fldSubjectId.selectedIndex]?.text.split(' (')[0] || '';
                    const lecName = fldLecturerId.options[fldLecturerId.selectedIndex]?.text.split(' (')[0] || '';
                    trMain.dataset.search = subName + ' ' + lecName;
                    
                    trMain.innerHTML = mainRowHtml(payload);
                }
            }

            function removeRowFromTables(id) {
                const trLine = document.querySelector(`#creditClassTableBody tr[data-id="${id}"]`);
                if (trLine) trLine.remove();
                
                const trMini = document.querySelector(`#miniCreditClassBody tr[data-id="${id}"]`);
                if (trMini) trMini.remove();
                
                const tBody = document.getElementById('creditClassTableBody')?.querySelector('tbody');
                if (tBody && tBody.children.length === 0) {
                    const isPGV = @(isPGV.ToString().ToLower());
                    tBody.innerHTML = `<tr><td colspan="${isPGV ? 9 : 8}" class="text-center text-muted py-5"><i class="bi bi-inbox fs-2 d-block mb-2"></i>Không có dữ liệu lớp tín chỉ.</td></tr>`;
                }
                
                if (selectedId == id) {
                    resetToView();
                }
            }

            async function executeUndo() {
                if (undoStack.length === 0) return;
                const actionObj = undoStack.pop();
                try {
                    if (actionObj.action === 'add') {
                        // Resurrect deleted item
                        const res = await fetchJson(URL_ADD, actionObj.payload);
                        addRowToTables(actionObj.payload, res.newId);
                    } else if (actionObj.action === 'edit') {
                        await fetchJson(URL_EDIT, actionObj.payload);
                        // The UI should reflect the payload after edit
                        updateRowInTables(actionObj.payload, actionObj.payload.oldCreditClassId);
                    } else if (actionObj.action === 'delete') {
                        await fetchJson(URL_DELETE, actionObj.payload);
                        removeRowFromTables(actionObj.payload.creditClassId);
                    }
                } catch(err) {
                    window.showToast("Lỗi hoàn tác: " + err.message, "danger");
                }
            }

            async function doDelete(id) {
                try {
                    const row = document.querySelector(`#creditClassTableBody tr[data-id="${id}"]`);
                    const delPayload = row ? {
                        year: row.dataset.year,
                        semester: parseInt(row.dataset.semester),
                        subjectId: row.dataset.subId,
                        group: parseInt(row.dataset.group),
                        lecturerId: row.dataset.lecId,
                        facultyId: row.dataset.facId,
                        minStudents: parseInt(row.dataset.min),
                        isCancelled: row.dataset.cancelled === 'true' || row.dataset.cancelled === true,
                        registeredCount: parseInt(row.dataset.regCount || '0', 10)
                    } : null;

                    const res = await fetchJson(URL_DELETE, { creditClassId: parseInt(id) });
                    if (res.success) {
                        window.showToast(res.message, 'success');
                        removeRowFromTables(id);
                        
                        if (delPayload && modal.classList.contains('show')) {
                            undoStack.push({ action: 'add', payload: delPayload });
                        }
                    } else {
                        window.showToast(res.message, 'danger');
                    }
                } catch (err) {
                    window.showToast('Lỗi: ' + err.message, 'danger');
                }
            }

            async function fetchJson(url, body) {
                const res = await fetch(url, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(body),
                });
                const json = await res.json();
                if (!res.ok && json.success !== false)
                    throw new Error(json.message ?? 'Lỗi máy chủ');
                return json;
            }

        })();
    </script>
}
