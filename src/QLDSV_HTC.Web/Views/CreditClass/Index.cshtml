@model QLDSV_HTC.Web.Models.CreditClassManagementViewModel
@using QLDSV_HTC.Domain.Constants

@{
    ViewData["Title"] = "Quản lý Lớp tín chỉ";
    var isPGV = User.IsInRole("PGV");
    var hasFaculty = !string.IsNullOrEmpty(Model.CurrentFacultyId);

    ViewData["isPGV"] = isPGV;
    ViewData["hasFaculty"] = hasFaculty;
}

<div class="dashboard-container fade-in-up">
    @* ── Bảng danh sách LTC ── *@
    @await Html.PartialAsync("_CreditClassTable", Model, ViewData)
</div>


@* ══════════════════════════════════════════════════════════
MODAL: Nhập danh mục LTC / Xác nhận xóa
══════════════════════════════════════════════════════════ *@
@await Html.PartialAsync("_CreditClassFormModal", Model, ViewData)
<partial name="_DeleteConfirmModal" />

@section Scripts {
    <script src="~/js/form-helpers.js" asp-append-version="true"></script>
    <script>
        (function () {
            'use strict';

            const URL_ADD = '@Url.Action("Add", "CreditClass")';
            const URL_EDIT = '@Url.Action("Edit", "CreditClass")';
            const URL_DELETE = '@Url.Action("Delete", "CreditClass")';

            let snapshotData = null;
            let selectedId = null;
            let originalId = null;
            
            // -- UNDO STACK STATE --
            let undoStack = [];
            let forceClose = false;
            let isSubmitting = false;

            const modal = document.getElementById('creditClassFormModal');
            const deleteModal = document.getElementById('deleteConfirmModal');
            
            // Fields
            const fldId = document.getElementById('fldCreditClassId');
            const fldYear = document.getElementById('fldYear');
            const fldSemester = document.getElementById('fldSemester');
            const fldSubjectId = document.getElementById('fldSubjectId');
            const fldGroup = document.getElementById('fldGroup');
            const fldLecturerId = document.getElementById('fldLecturerId');
            const fldFacultyId = document.getElementById('fldFacultyId');
            const fldMinStudents = document.getElementById('fldMinStudents');
            const fldIsCancelled = document.getElementById('fldIsCancelled');

            // Buttons
            const btnThem = document.getElementById('btnFormThem');
            const btnXoa = document.getElementById('btnFormXoa');
            const btnGhi = document.getElementById('btnFormGhi');
            const btnPhucHoi = document.getElementById('btnFormPhucHoi');
            const btnHuy = document.getElementById('btnFormHuy');

            // ── Shared form helpers
            const helpers = createFormHelpers({
                alertEl: document.getElementById('formAlert'),
                modeLabelEl: document.getElementById('formModeLabel'),
                buttons: { them: btnThem, xoa: btnXoa, ghi: btnGhi, phucHoi: btnPhucHoi, huy: btnHuy },
                allFields: [fldYear, fldSemester, fldSubjectId, fldGroup, fldLecturerId, fldFacultyId, fldMinStudents, fldIsCancelled],
                requiredFields: [fldYear, fldSemester, fldSubjectId, fldGroup, fldFacultyId, fldMinStudents],
                getSelectedId: () => selectedId,
            });

            function getFormChanges() {
                const changes = [];
                const currentMode = helpers.getMode();
                if (currentMode === 'view') return changes;

                const yearVal = fldYear.value.trim();
                const semesterVal = fldSemester.value.trim();
                const subjectIdVal = fldSubjectId.value.trim();
                const groupVal = fldGroup.value.trim();
                const lecturerIdVal = fldLecturerId.value.trim();
                const facultyIdVal = fldFacultyId.value.trim();
                const minStudentsVal = fldMinStudents.value.trim();
                const isCancelledVal = fldIsCancelled.checked;

                if (currentMode === 'add') {
                    if (yearVal) changes.push(`• <b>Niên khóa</b>: (Mới) → <span class="text-success fw-bold">"${escapeHtml(yearVal)}"</span>`);
                    if (semesterVal) changes.push(`• <b>Học kỳ</b>: (Mới) → <span class="text-success fw-bold">${escapeHtml(semesterVal)}</span>`);
                    if (subjectIdVal) {
                        const opt = fldSubjectId.options[fldSubjectId.selectedIndex];
                        changes.push(`• <b>Môn học</b>: (Mới) → <span class="text-success fw-bold">"${escapeHtml(opt ? opt.text : subjectIdVal)}"</span>`);
                    }
                    if (groupVal) changes.push(`• <b>Nhóm</b>: (Mới) → <span class="text-success fw-bold">${escapeHtml(groupVal)}</span>`);
                    if (lecturerIdVal) {
                        const opt = fldLecturerId.options[fldLecturerId.selectedIndex];
                        changes.push(`• <b>Giảng viên</b>: (Mới) → <span class="text-success fw-bold">"${escapeHtml(opt ? opt.text : lecturerIdVal)}"</span>`);
                    }
                    if (facultyIdVal) {
                        const opt = fldFacultyId.options[fldFacultyId.selectedIndex];
                        changes.push(`• <b>Khoa</b>: (Mới) → <span class="text-success fw-bold">"${escapeHtml(opt ? opt.text : facultyIdVal)}"</span>`);
                    }
                    if (minStudentsVal) changes.push(`• <b>Số SV tối thiểu</b>: (Mới) → <span class="text-success fw-bold">${escapeHtml(minStudentsVal)}</span>`);
                    changes.push(`• <b>Hủy lớp</b>: (Mới) → <span class="text-success fw-bold">${isCancelledVal ? "Có" : "Không"}</span>`);
                } else if (currentMode === 'edit' && snapshotData) {
                    const oldYear = (snapshotData.year ?? '').toString().trim();
                    const oldSemester = (snapshotData.semester ?? '').toString().trim();
                    const oldSubjectId = (snapshotData.subId ?? snapshotData.subjectId ?? '').toString().trim();
                    const oldGroup = (snapshotData.group ?? '').toString().trim();
                    const oldLecturerId = (snapshotData.lecId ?? snapshotData.lecturerId ?? '').toString().trim();
                    const oldFacultyId = (snapshotData.facId ?? snapshotData.facultyId ?? '').toString().trim();
                    const oldMinStudents = (snapshotData.min ?? snapshotData.minStudents ?? '').toString().trim();
                    const oldIsCancelled = snapshotData.cancelled !== undefined ? !!snapshotData.cancelled : !!snapshotData.isCancelled;

                    if (yearVal !== oldYear) {
                        changes.push(`• <b>Niên khóa</b>: <span class="text-muted">"${escapeHtml(oldYear)}"</span> → <span class="text-warning fw-bold">"${escapeHtml(yearVal)}"</span>`);
                    }
                    if (semesterVal !== oldSemester) {
                        changes.push(`• <b>Học kỳ</b>: <span class="text-muted">${escapeHtml(oldSemester)}</span> → <span class="text-warning fw-bold">${escapeHtml(semesterVal)}</span>`);
                    }
                    if (subjectIdVal !== oldSubjectId) {
                        const optOld = fldSubjectId.querySelector(`option[value="${oldSubjectId}"]`);
                        const optNew = fldSubjectId.options[fldSubjectId.selectedIndex];
                        changes.push(`• <b>Môn học</b>: <span class="text-muted">"${escapeHtml(optOld ? optOld.text : oldSubjectId)}"</span> → <span class="text-warning fw-bold">"${escapeHtml(optNew ? optNew.text : subjectIdVal)}"</span>`);
                    }
                    if (groupVal !== oldGroup) {
                        changes.push(`• <b>Nhóm</b>: <span class="text-muted">${escapeHtml(oldGroup)}</span> → <span class="text-warning fw-bold">${escapeHtml(groupVal)}</span>`);
                    }
                    if (lecturerIdVal !== oldLecturerId) {
                        const optOld = fldLecturerId.querySelector(`option[value="${oldLecturerId}"]`);
                        const optNew = fldLecturerId.options[fldLecturerId.selectedIndex];
                        changes.push(`• <b>Giảng viên</b>: <span class="text-muted">"${escapeHtml(optOld ? optOld.text : oldLecturerId)}"</span> → <span class="text-warning fw-bold">"${escapeHtml(optNew ? optNew.text : lecturerIdVal)}"</span>`);
                    }
                    if (facultyIdVal !== oldFacultyId) {
                        const optOld = fldFacultyId.querySelector(`option[value="${oldFacultyId}"]`);
                        const optNew = fldFacultyId.options[fldFacultyId.selectedIndex];
                        changes.push(`• <b>Khoa</b>: <span class="text-muted">"${escapeHtml(optOld ? optOld.text : oldFacultyId)}"</span> → <span class="text-warning fw-bold">"${escapeHtml(optNew ? optNew.text : facultyIdVal)}"</span>`);
                    }
                    if (minStudentsVal !== oldMinStudents) {
                        changes.push(`• <b>Số SV tối thiểu</b>: <span class="text-muted">${escapeHtml(oldMinStudents)}</span> → <span class="text-warning fw-bold">${escapeHtml(minStudentsVal)}</span>`);
                    }
                    if (isCancelledVal !== oldIsCancelled) {
                        changes.push(`• <b>Hủy lớp</b>: <span class="text-muted">${oldIsCancelled ? "Có" : "Không"}</span> → <span class="text-warning fw-bold">${isCancelledVal ? "Có" : "Không"}</span>`);
                    }
                }
                return changes;
            }

            function isFormDirty() {
                return getFormChanges().length > 0;
            }

            // Delete Modal Logic
            let pendingDeleteId = null;
            if (deleteModal) {
                document.getElementById('btnConfirmDelete').addEventListener('click', async () => {
                    bootstrap.Modal.getInstance(deleteModal)?.hide();
                    if (pendingDeleteId) await doDelete(pendingDeleteId);
                });
            }

            function showDeleteModal(id, title) {
                pendingDeleteId = id;
                document.getElementById('deleteTargetId').textContent = "LTC " + id;
                document.getElementById('deleteTargetName').textContent = title;
                bootstrap.Modal.getOrCreateInstance(deleteModal).show();
            }

            if (!modal) return;

            const btnCancelModal = modal.querySelector('.btn-cancel-modal');
            const btnSaveModal = modal.querySelector('.btn-save-modal');

            // Mở modal qua nút Thêm Mới → reset về view
            document.getElementById('btnOpenCreditClassForm')?.addEventListener('click', resetToView);

            // Mở modal → clear stack
            modal.addEventListener('show.bs.modal', () => {
                undoStack = [];
                forceClose = false;
            });

            // Đóng modal → xóa stack (giữ lại thay đổi đã ghi)
            modal.addEventListener('hide.bs.modal', (e) => {
                if (forceClose) return;
                undoStack = [];
            });

            btnSaveModal?.addEventListener('click', () => {
                undoStack = [];
                forceClose = true;
                bootstrap.Modal.getInstance(modal).hide();
            });

            // "Hoàn tác tất cả và thoát" → undo rồi đóng
            btnCancelModal?.addEventListener('click', async () => {
                if (undoStack.length > 0) {
                    while (undoStack.length > 0) {
                        await executeUndo();
                    }
                }
                forceClose = true;
                bootstrap.Modal.getInstance(modal).hide();
            });

            // Reset khi đóng modal toàn phần
            modal.addEventListener('hidden.bs.modal', resetToView);

            // Mini table row selection
            document.getElementById('miniCreditClassBody')?.addEventListener('click', e => {
                if (helpers.getMode() === 'add') return;
                const row = e.target.closest('tr.mini-row');
                if (!row) return;
                selectMiniRow(row);
            });

            // ── Nút Thêm
            btnThem.addEventListener('click', () => {
                deselectMiniRow();
                selectedId = null;
                snapshotData = null;
                clearFields();
                helpers.clearValidation();
                helpers.setMode('add');

                // Tự động gán niên khóa + học kỳ hiện tại
                const now = new Date();
                const curY = now.getFullYear();
                const curM = now.getMonth() + 1;
                
                // Niên khóa
                fldYear.value = (curM < 8) ? `${curY - 1}-${curY}` : `${curY}-${curY + 1}`;
                
                // Học kỳ: 9-1: HK1, 2-5: HK2, 6-8: HK3 (hè)
                if (curM >= 9 || curM <= 1) fldSemester.value = "1";
                else if (curM >= 2 && curM <= 5) fldSemester.value = "2";
                else fldSemester.value = "3";

                fldYear.disabled = false;
                fldYear.focus();
                
                // Mới tạo → có thể xóa (nhưng thường dùng Undo)
                btnXoa.disabled = false;
                btnXoa.title = "Xóa lớp tín chỉ này";
                
                // Trạng thái huỷ luôn tắt khi tạo mới
                fldIsCancelled.checked = false;
                
                helpers.showAlert('Nhập thông tin Lớp Tín Chỉ mới rồi nhấn <b>Ghi</b> để lưu.', 'info');
            });

            // ── Nút Xóa
            btnXoa.addEventListener('click', () => {
                if (!selectedId) return;
                showDeleteModal(selectedId, `Môn ${fldSubjectId.options[fldSubjectId.selectedIndex]?.text} - Nhóm ${fldGroup.value}`);
            });

            async function saveCreditClass() {
                if (!helpers.validateForm() || isSubmitting) return false;

                isSubmitting = true;
                if (btnGhi) btnGhi.disabled = true;

                const payload = {
                    oldCreditClassId: originalId,
                    creditClassId: parseInt(fldId.value) || 0,
                    year: fldYear.value.trim(),
                    semester: parseInt(fldSemester.value),
                    subjectId: fldSubjectId.value.trim(),
                    group: parseInt(fldGroup.value),
                    lecturerId: fldLecturerId.value.trim(),
                    facultyId: fldFacultyId.value.trim(),
                    minStudents: parseInt(fldMinStudents.value),
                    isCancelled: fldIsCancelled.checked
                };

                try {
                    const res = await fetchJson(helpers.getMode() === 'add' ? URL_ADD : URL_EDIT, payload);
                    if (res.success) {
                        window.showToast(res.message, 'success');
                        
                        // Lưu vào stack trước khi cập nhật
                        if (helpers.getMode() === 'add') {
                            const newId = res.newId || 0; 
                            payload.id = newId;
                            payload.creditClassId = newId;
                            fldId.value = newId;
                            addRowToTables(payload, newId);
                            undoStack.push({ action: 'delete', payload: { creditClassId: newId } });
                            resetToView();
                        } else {
                            updateRowInTables(payload, originalId);
                            if (snapshotData) {
                                undoStack.push({
                                    action: 'edit',
                                    payload: {
                                        oldCreditClassId: payload.creditClassId,
                                        creditClassId: snapshotData.id,
                                        year: snapshotData.year,
                                        semester: snapshotData.semester,
                                        subjectId: snapshotData.subId,
                                        group: snapshotData.group,
                                        lecturerId: snapshotData.lecId,
                                        facultyId: snapshotData.facId,
                                        minStudents: snapshotData.min,
                                        isCancelled: snapshotData.cancelled === 'true' || snapshotData.cancelled === true
                                    }
                                });
                            }
                            originalId = parseInt(fldId.value);
                            selectedId = parseInt(fldId.value);
                            snapshotData = { ...payload, id: selectedId, 
                                subId: payload.subjectId, lecId: payload.lecturerId, facId: payload.facultyId, min: payload.minStudents, cancelled: payload.isCancelled === true  };
                            
                            highlightMiniRow(selectedId);
                            helpers.setMode('view');
                        }
                        return true;
                    } else {
                        window.showToast(res.message, 'danger');
                        return false;
                    }
                } catch (err) {
                    window.showToast('Lỗi: ' + err.message, 'danger');
                    return false;
                } finally {
                    isSubmitting = false;
                    if (btnGhi) btnGhi.disabled = false;
                }
            }

            // ── Nút Ghi
            btnGhi.addEventListener('click', async () => {
                await saveCreditClass();
            });

            // ── Nút Phục hồi
            btnPhucHoi.addEventListener('click', async () => {
                if (undoStack.length === 0) {
                    helpers.showAlert('Không có hành động nào để phục hồi.', 'info');
                    return;
                }
                await executeUndo();
                resetToView();
                helpers.showAlert('Đã hoàn tác 1 hành động trên hệ thống.', 'warning');
            });

            // ── Nút Hủy
            btnHuy?.addEventListener('click', resetToView);

            // ── Edit/Delete on Main Table
            document.getElementById('creditClassTableBody')?.addEventListener('click', e => {
                const editBtn = e.target.closest('.btn-edit-row');
                const delBtn = e.target.closest('.btn-delete-row');

                if (editBtn) {
                    const ds = editBtn.dataset;
                    bootstrap.Modal.getOrCreateInstance(modal).show();
                    setTimeout(() => {
                        const data = {
                            id: ds.id, year: ds.year, semester: ds.semester,
                            subId: ds.subId, group: ds.group, lecId: ds.lecId,
                            facId: ds.facId, min: ds.min, cancelled: ds.cancelled === 'true',
                            regCount: parseInt(ds.regCount || '0', 10),
                            hasGrades: ds.hasGrades === 'true'
                        };
                        populateFields(data);
                        originalId = data.id;
                        selectedId = data.id;
                        snapshotData = { ...data };
                        undoStack = []; 
                        helpers.setMode('edit');

                        // Disable Xóa nếu đã có SV đăng ký
                        if (data.regCount > 0) {
                            btnXoa.disabled = true;
                            btnXoa.title = `Không thể xóa LTC đã có ${data.regCount} SV đăng ký`;
                        } else {
                            btnXoa.disabled = false;
                            btnXoa.title = "Xóa lớp tín chỉ này";
                        }

                        highlightMiniRow(ds.id);
                        helpers.hideAlert();
                    }, 200);
                }

                if (delBtn) {
                    const id = delBtn.dataset.id;
                    const tr = delBtn.closest('tr');
                    const regCount = parseInt(tr.dataset.regCount || '0', 10);
                    
                    if (regCount > 0) {
                        window.showToast(`Không thể xóa LTC đã có ${regCount} SV đăng ký`, 'warning');
                        return;
                    }

                    const subName = tr.querySelector('td:nth-child(3)').textContent;
                    showDeleteModal(id, subName);
                }
            });

            // ── Filter (Client-side)
            const searchInput = document.getElementById('creditClassSearch');
            const btnClearSearch = document.getElementById('btnClearSearch');

            searchInput?.addEventListener('input', e => {
                const q = e.target.value.toLowerCase();
                
                if (btnClearSearch) {
                    btnClearSearch.style.display = q.length > 0 ? 'block' : 'none';
                }

                let vis = 0;
                document.querySelectorAll('#creditClassTableBody table tr[data-id]').forEach(row => {
                    const txt = (row.dataset.id + ' ' + row.dataset.search).toLowerCase();
                    const match = txt.includes(q);
                    row.style.display = match ? '' : 'none';
                    if (match) vis++;
                });
                const vc = document.getElementById('visibleCount');
                if (vc) vc.textContent = String(vis);
            });

            // Clear search button
            btnClearSearch?.addEventListener('click', () => {
                searchInput.value = '';
                searchInput.dispatchEvent(new Event('input'));
                searchInput.focus();
            });

            // ESC key to clear search
            searchInput?.addEventListener('keydown', e => {
                if (e.key === 'Escape') {
                    searchInput.value = '';
                    searchInput.dispatchEvent(new Event('input'));
                }
            });

            // Modal Client side search
            const modalCreditClassSearch = document.getElementById('modalCreditClassSearch');
            modalCreditClassSearch?.addEventListener('input', () => {
                const q = modalCreditClassSearch.value.trim().toLowerCase();
                document.querySelectorAll('#miniCreditClassBody tr.mini-row').forEach(row => {
                    const match = row.innerText.toLowerCase().includes(q);
                    row.style.display = match ? '' : 'none';
                });
            });

            // ── Helpers
            function resetToView() {
                selectedId = null; snapshotData = null; originalId = null; undoStack = [];
                clearFields(); helpers.clearValidation(); helpers.hideAlert(); deselectMiniRow();
                helpers.setMode('view');
            }

            function clearFields() {
                fldId.value = '';
                fldYear.value = '';
                fldSemester.value = '';
                fldSubjectId.value = '';
                fldGroup.value = '1';
                fldLecturerId.value = '';
                fldFacultyId.value = '';
                fldMinStudents.value = '30';
                fldIsCancelled.checked = false;
            }

            function populateFields(d) {
                fldId.value = d.id || '';
                fldYear.value = d.year || '';
                fldSemester.value = d.semester || '';
                fldSubjectId.value = d.subId || '';
                fldGroup.value = d.group || '1';
                fldLecturerId.value = d.lecId || '';
                fldFacultyId.value = d.facId || '';
                fldMinStudents.value = d.min || '30';
                fldIsCancelled.checked = d.cancelled === true || d.cancelled === 'true';
            }

            function selectMiniRow(row) {
                deselectMiniRow();
                row.classList.add('table-active', 'fw-semibold');
                const ds = row.dataset;
                const data = {
                    id: ds.id, year: ds.year, semester: ds.semester,
                    subId: ds.subId, group: ds.group, lecId: ds.lecId,
                    facId: ds.facId, min: ds.min, cancelled: ds.cancelled === 'true',
                    regCount: parseInt(ds.regCount || '0', 10),
                    hasGrades: ds.hasGrades === 'true'
                };
                populateFields(data);
                originalId = data.id;
                selectedId = data.id;
                snapshotData = { ...data };
                undoStack = [];
                helpers.setMode('edit');

                if (data.regCount > 0) {
                    btnXoa.disabled = true;
                    btnXoa.title = `Không thể xóa LTC đã có ${data.regCount} SV đăng ký`;
                } else {
                    btnXoa.disabled = false;
                    btnXoa.title = "Xóa lớp tín chỉ này";
                }

                helpers.hideAlert();
            }

            function highlightMiniRow(id) {
                deselectMiniRow();
                const row = document.querySelector(`#miniCreditClassBody tr[data-id="${CSS.escape(id)}"]`);
                if (row) row.classList.add('table-active', 'fw-semibold');
            }

            function deselectMiniRow() {
                document.querySelectorAll('#miniCreditClassBody tr.table-active')
                    .forEach(r => r.classList.remove('table-active', 'fw-semibold'));
            }

            function mainRowHtml(p) {
                const isPGV = @(isPGV.ToString().ToLower());
                const subName = fldSubjectId.options[fldSubjectId.selectedIndex]?.text.split(' (')[0] || p.subjectId;
                const lecName = fldLecturerId.options[fldLecturerId.selectedIndex]?.text.split(' (')[0] || '';
                const registeredCount = p.registeredCount || 0;
                const idStr = String(p.id).padStart(4, '0');
                
                let statusHtml = '';
                const hasGrades = p.hasGrades === true || p.hasGrades === 'true';
                if (p.isCancelled) {
                    statusHtml = '<span class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-10 px-3 py-1 rounded-pill w-100 shadow-sm d-inline-flex align-items-center justify-content-center gap-1"><i class="bi bi-x-circle-fill"></i><span>Đã hủy</span></span>';
                } else if (hasGrades) {
                    statusHtml = '<span class="badge bg-info bg-opacity-10 text-info border border-info border-opacity-10 px-3 py-1 rounded-pill w-100 shadow-sm d-inline-flex align-items-center justify-content-center gap-1"><i class="bi bi-clipboard-check-fill"></i><span>Đã có điểm</span></span>';
                } else if (registeredCount < p.minStudents) {
                    statusHtml = '<span class="badge bg-warning bg-opacity-10 text-warning border border-warning border-opacity-10 px-3 py-1 rounded-pill w-100 shadow-sm d-inline-flex align-items-center justify-content-center gap-1"><i class="bi bi-hourglass-split"></i><span>Chờ SV</span></span>';
                } else {
                    statusHtml = '<span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-10 px-3 py-1 rounded-pill w-100 shadow-sm d-inline-flex align-items-center justify-content-center gap-1"><i class="bi bi-check-circle-fill"></i><span>Đã mở</span></span>';
                }
                
                let registeredHtml = registeredCount > 0 
                    ? `<div class="badge ${registeredCount < p.minStudents ? 'bg-warning bg-opacity-10 text-warning border-warning border-opacity-10' : 'bg-success bg-opacity-10 text-success border-success border-opacity-10'} border px-2 py-1 rounded-pill shadow-sm tabular-nums min-w-40"><span class="fw-bold">${registeredCount}</span></div>`
                    : '<span class="text-muted opacity-50 tabular-nums">0</span>';

                const canDelete = registeredCount === 0;
                let actions = isPGV ? `
                    <td class="text-end pe-4">
                        <div class="d-flex justify-content-end gap-1">
                            <button class="btn btn-sm btn-outline-info shadow-none hover-scale rounded-3"
                                    title="Xem danh sách Sinh viên đã đăng ký" onclick="window.location.href='@Url.Action("Index", "Registration")?filterCreditClassId=${p.id}'">
                                <i class="bi bi-people"></i>
                            </button>
                            <button class="btn btn-sm btn-outline-primary btn-edit-row shadow-none hover-scale rounded-3"
                                    title="Chỉnh sửa thông tin lớp tín chỉ"
                                    data-id="${p.id}" data-year="${p.year}" data-semester="${p.semester}"
                                    data-sub-id="${p.subjectId}" data-group="${p.group}"
                                    data-lec-id="${p.lecturerId}" data-fac-id="${p.facultyId}"
                                    data-min="${p.minStudents}" data-reg-count="${registeredCount}"
                                    data-cancelled="${p.isCancelled}">
                                <i class="bi bi-pencil"></i>
                            </button>
                            <button class="btn btn-sm ${canDelete ? 'btn-outline-danger btn-delete-row shadow-none hover-scale rounded-3' : 'btn-light text-muted border-0 opacity-50'}"
                                    title="${canDelete ? 'Xóa lớp tín chỉ này' : `Không thể xóa LTC đã có ${registeredCount} SV đăng ký`}" 
                                    data-id="${p.id}"
                                    ${canDelete ? '' : 'disabled'}>
                                <i class="bi ${canDelete ? 'bi-trash' : 'bi-trash-fill'}"></i>
                            </button>
                        </div>
                    </td>` : '';

                return `
                    <td class="ps-4">
                        <span class="fw-bold font-monospace text-primary bg-primary bg-opacity-10 px-2 py-1 rounded small border border-primary border-opacity-10 shadow-sm">
                            LTC-${idStr}
                        </span>
                    </td>
                    <td>
                        <div class="fw-bold text-dark tabular-nums">${p.year}</div>
                        <div class="text-muted small d-flex align-items-center gap-1">
                            <i class="bi bi-clock-history opacity-50"></i>
                            <span>Học kỳ ${p.semester}</span>
                        </div>
                    </td>
                    <td>
                        <div class="fw-bold text-dark mb-0">${subName}</div>
                        <div class="text-muted small font-monospace opacity-75">${p.subjectId}</div>
                    </td>
                    <td class="text-center">
                        <span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary border-opacity-10 px-3 py-1 rounded-pill shadow-sm">
                            Nhóm ${p.group}
                        </span>
                    </td>
                    <td>
                        <div class="fw-medium text-dark">${lecName}</div>
                        <div class="text-muted small d-flex align-items-center gap-1 opacity-75">
                            <i class="bi bi-person-badge opacity-50"></i>
                            <span class="font-monospace">${p.lecturerId}</span>
                        </div>
                    </td>
                    <td class="text-center fw-medium text-muted tabular-nums">${p.minStudents}</td>
                    <td class="text-center">${registeredHtml}</td>
                    <td class="text-center">${statusHtml}</td>
                    ${actions}
                `;
            }

            function miniRowHtml(p) {
                const subName = fldSubjectId.options[fldSubjectId.selectedIndex]?.text.split(' (')[0] || p.subjectId;
                const idStr = String(p.id).padStart(4, '0');
                const statusHtml = p.isCancelled
                    ? '<span class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-10 rounded-pill px-2">Hủy</span>'
                    : '<span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-10 rounded-pill px-2">Mở</span>';

                return `
                    <td class="ps-3 fw-bold font-monospace text-primary">${idStr}</td>
                    <td class="text-truncate fw-medium" style="max-width: 150px;" title="${subName}">${subName}</td>
                    <td class="text-center">
                        <span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary border-opacity-10 px-2">${p.group}</span>
                    </td>
                    <td class="text-center tabular-nums">${p.minStudents}</td>
                    <td class="text-center">${statusHtml}</td>
                `;
            }

            function addRowToTables(payload, newId) {
                payload.id = newId;
                payload.registeredCount = 0; // Mới tạo luôn là 0

                const subName = fldSubjectId.options[fldSubjectId.selectedIndex]?.text.split(' (')[0] || '';
                const lecName = fldLecturerId.options[fldLecturerId.selectedIndex]?.text.split(' (')[0] || '';

                // Sort key: NIENKHOA DESC, HOCKY DESC, TENMH ASC, NHOM ASC
                const sortKey = (yr, sem, name, grp) => {
                    const invertedYear = String.fromCharCode(0xFFFF - parseInt((yr || '').replace(/[^0-9]/g, '').substring(0,4) || '0'));
                    const invertedSem = String.fromCharCode(0xFFFF - parseInt(sem || '0'));
                    return invertedYear + '|' + invertedSem + '|' + (name || '').toLowerCase() + '|' + String(grp || 0).padStart(3, '0');
                };
                const newKey = sortKey(payload.year, payload.semester, subName, payload.group);

                // Thêm vào bảng mini — sorted insert
                const trMini = document.createElement('tr');
                trMini.className = 'mini-row transition-base table-active fw-semibold';
                trMini.setAttribute('role', 'button');
                trMini.dataset.id = newId;
                trMini.dataset.year = payload.year;
                trMini.dataset.semester = payload.semester;
                trMini.dataset.subId = payload.subjectId;
                trMini.dataset.group = payload.group;
                trMini.dataset.lecId = payload.lecturerId;
                trMini.dataset.facId = payload.facultyId;
                trMini.dataset.min = payload.minStudents;
                trMini.dataset.cancelled = payload.isCancelled;
                trMini.dataset.regCount = payload.registeredCount;
                trMini.dataset.hasGrades = payload.hasGrades || false;
                trMini.innerHTML = miniRowHtml(payload);

                const miniBody = document.getElementById('miniCreditClassBody');
                const miniRows = [...miniBody.querySelectorAll('tr[data-id]')];
                let miniInserted = false;
                for (const row of miniRows) {
                    const rowSubName = row.querySelector('td:nth-child(3)')?.textContent?.trim() || '';
                    const rowKey = sortKey(row.dataset.year, row.dataset.semester, rowSubName, row.dataset.group);
                    if (newKey < rowKey) {
                        row.before(trMini);
                        miniInserted = true;
                        break;
                    }
                }
                if (!miniInserted) miniBody.appendChild(trMini);

                // Thêm vào bảng main — sorted insert
                const trMain = document.createElement('tr');
                trMain.dataset.id = newId;
                trMain.dataset.year = payload.year;
                trMain.dataset.semester = payload.semester;
                trMain.dataset.subId = payload.subjectId;
                trMain.dataset.group = payload.group;
                trMain.dataset.lecId = payload.lecturerId;
                trMain.dataset.facId = payload.facultyId;
                trMain.dataset.min = payload.minStudents;
                trMain.dataset.cancelled = payload.isCancelled;
                trMain.dataset.regCount = payload.registeredCount;
                trMain.dataset.hasGrades = payload.hasGrades || false;
                trMain.dataset.search = subName + ' ' + lecName;
                trMain.innerHTML = mainRowHtml(payload);

                const tBody = document.getElementById('creditClassTableBody');
                const noDataRow = tBody?.querySelector('td[colspan]');
                if (noDataRow) {
                    tBody.innerHTML = '';
                    tBody.appendChild(trMain);
                } else {
                    const mainRows = [...tBody.querySelectorAll('tr[data-id]')];
                    let mainInserted = false;
                    for (const row of mainRows) {
                        // Get subject name from the row's 3rd column (Tên MH)
                        const rowSubEl = row.querySelector('td:nth-child(3)');
                        const rowSubName = rowSubEl?.querySelector('.fw-bold')?.textContent?.trim() || rowSubEl?.textContent?.trim() || '';
                        const rowKey = sortKey(row.dataset.year, row.dataset.semester, rowSubName, row.dataset.group);
                        if (newKey < rowKey) {
                            row.before(trMain);
                            mainInserted = true;
                            break;
                        }
                    }
                    if (!mainInserted) tBody.appendChild(trMain);
                }

                // Update counter
                const vc = document.getElementById('visibleCount');
                if (vc) vc.textContent = String(parseInt(vc.textContent || '0', 10) + 1);
                const tc = document.getElementById('totalCount');
                if (tc) tc.textContent = String(parseInt(tc.textContent || '0', 10) + 1);
            }

            function updateRowInTables(payload, id) {
                payload.id = id;
                
                // Cập nhật bảng mini
                const trMini = document.querySelector(`#miniCreditClassBody tr[data-id="${id}"]`);
                if (trMini) {
                    trMini.dataset.year = payload.year;
                    trMini.dataset.semester = payload.semester;
                    trMini.dataset.subId = payload.subjectId;
                    trMini.dataset.group = payload.group;
                    trMini.dataset.lecId = payload.lecturerId;
                    trMini.dataset.facId = payload.facultyId;
                    trMini.dataset.min = payload.minStudents;
                    trMini.dataset.cancelled = payload.isCancelled;
                    trMini.dataset.regCount = payload.registeredCount || 0;
                    trMini.dataset.hasGrades = payload.hasGrades || false;
                    trMini.innerHTML = miniRowHtml(payload);
                    trMini.classList.add('table-active', 'fw-semibold');
                }

                // Cập nhật bảng main
                const trMain = document.querySelector(`#creditClassTableBody tr[data-id="${id}"]`);
                if (trMain) {
                    trMain.dataset.year = payload.year;
                    trMain.dataset.semester = payload.semester;
                    trMain.dataset.subId = payload.subjectId;
                    trMain.dataset.group = payload.group;
                    trMain.dataset.lecId = payload.lecturerId;
                    trMain.dataset.facId = payload.facultyId;
                    trMain.dataset.min = payload.minStudents;
                    trMain.dataset.cancelled = payload.isCancelled;
                    trMain.dataset.regCount = payload.registeredCount || 0;
                    trMain.dataset.hasGrades = payload.hasGrades || false;
                    
                    const subName = fldSubjectId.options[fldSubjectId.selectedIndex]?.text.split(' (')[0] || '';
                    const lecName = fldLecturerId.options[fldLecturerId.selectedIndex]?.text.split(' (')[0] || '';
                    trMain.dataset.search = subName + ' ' + lecName;
                    
                    trMain.innerHTML = mainRowHtml(payload);
                }
            }

            function removeRowFromTables(id) {
                const trLine = document.querySelector(`#creditClassTableBody tr[data-id="${id}"]`);
                if (trLine) trLine.remove();
                
                const trMini = document.querySelector(`#miniCreditClassBody tr[data-id="${id}"]`);
                if (trMini) trMini.remove();
                
                const tBody = document.getElementById('creditClassTableBody');
                if (tBody && tBody.children.length === 0) {
                    const isPGV = @(isPGV.ToString().ToLower());
                    tBody.innerHTML = `<tr><td colspan="${isPGV ? 9 : 8}" class="text-center text-muted py-5"><i class="bi bi-inbox fs-2 d-block mb-2"></i>Không có dữ liệu lớp tín chỉ.</td></tr>`;
                }
                
                if (selectedId == id) {
                    resetToView();
                }

                // Update counter
                const vc = document.getElementById('visibleCount');
                if (vc) vc.textContent = String(Math.max(0, parseInt(vc.textContent || '0', 10) - 1));
                const tc = document.getElementById('totalCount');
                if (tc) tc.textContent = String(Math.max(0, parseInt(tc.textContent || '0', 10) - 1));
            }

            async function executeUndo() {
                if (undoStack.length === 0) return;
                const actionObj = undoStack.pop();
                try {
                    if (actionObj.action === 'add') {
                        // Resurrect deleted item
                        const res = await fetchJson(URL_ADD, actionObj.payload);
                        addRowToTables(actionObj.payload, res.newId);
                    } else if (actionObj.action === 'edit') {
                        await fetchJson(URL_EDIT, actionObj.payload);
                        // The UI should reflect the payload after edit
                        updateRowInTables(actionObj.payload, actionObj.payload.oldCreditClassId);
                    } else if (actionObj.action === 'delete') {
                        await fetchJson(URL_DELETE, actionObj.payload);
                        removeRowFromTables(actionObj.payload.creditClassId);
                    }
                } catch(err) {
                    window.showToast("Lỗi hoàn tác: " + err.message, "danger");
                }
            }

            async function doDelete(id) {
                try {
                    const row = document.querySelector(`#creditClassTableBody tr[data-id="${id}"]`);
                    const delPayload = row ? {
                        year: row.dataset.year,
                        semester: parseInt(row.dataset.semester),
                        subjectId: row.dataset.subId,
                        group: parseInt(row.dataset.group),
                        lecturerId: row.dataset.lecId,
                        facultyId: row.dataset.facId,
                        minStudents: parseInt(row.dataset.min),
                        isCancelled: row.dataset.cancelled === 'true' || row.dataset.cancelled === true,
                        registeredCount: parseInt(row.dataset.regCount || '0', 10)
                    } : null;

                    const res = await fetchJson(URL_DELETE, { creditClassId: parseInt(id) });
                    if (res.success) {
                        window.showToast(res.message, 'success');
                        removeRowFromTables(id);
                        
                        if (delPayload && modal.classList.contains('show')) {
                            undoStack.push({ action: 'add', payload: delPayload });
                        }
                    } else {
                        window.showToast(res.message, 'danger');
                    }
                } catch (err) {
                    window.showToast('Lỗi: ' + err.message, 'danger');
                }
            }

            async function fetchJson(url, body) {
                const res = await fetch(url, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(body),
                });
                const json = await res.json();
                if (!res.ok && json.success !== false)
                    throw new Error(json.message ?? 'Lỗi máy chủ');
                return json;
            }

        })();
    </script>
}
