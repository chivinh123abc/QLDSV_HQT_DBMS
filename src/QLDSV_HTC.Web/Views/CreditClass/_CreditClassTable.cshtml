@model QLDSV_HTC.Web.Models.CreditClassManagementViewModel
@using QLDSV_HTC.Web.Models

@{
    var isPGV = (bool)(ViewData["isPGV"] ?? false);
    var hasFaculty = (bool)(ViewData["hasFaculty"] ?? false);
    var pageTitle = hasFaculty
        ? $"Lớp tín chỉ — Khoa {Model.CurrentFacultyId}"
        : "Lớp tín chỉ toàn trường";

    // ── Prepare Title Section ──
    ViewData["TitleSection"] = (Func<object, Microsoft.AspNetCore.Html.IHtmlContent>)(@<text>
        <div class="d-flex align-items-center gap-2">
            <div class="bg-primary bg-opacity-10 text-primary rounded-2 p-2 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                <i class="bi bi-calendar2-range-fill fs-5"></i>
            </div>
            <div>
                <h5 class="mb-0 fw-bold text-dark">@pageTitle</h5>
                <div class="text-muted small">Quản lý mở lớp và điều phối giảng dạy</div>
            </div>
        </div>
        @if (isPGV)
        {
            <button class="btn btn-primary shadow-sm d-flex align-items-center gap-2 rounded-3 hover-scale px-3 ms-auto" 
                    id="btnOpenCreditClassForm" type="button" data-bs-toggle="modal" data-bs-target="#creditClassFormModal">
                <i class="bi bi-plus-circle-fill"></i>
                <span class="fw-semibold">Tạo Lớp tín chỉ</span>
            </button>
        }
    </text>);

    var tableModel = new GenericTableViewModel
    {
        FiltersSection = @<text>
            <div class="d-flex flex-wrap gap-3 align-items-center w-100">
                <div class="glass-search flex-grow-1" style="min-width: 300px; max-width: 400px;">
                    <i class="bi bi-search search-icon"></i>
                    <input type="text" id="creditClassSearch" class="search-input" 
                           placeholder="Tìm môn học, giảng viên…">
                    <button id="btnClearSearch" class="clear-btn d-none" type="button">
                        <i class="bi bi-x-circle-fill"></i>
                    </button>
                </div>
                
                <div class="ms-auto">
                    <form id="filterForm" method="GET" action="@Url.Action("Index", "CreditClass")" class="d-flex flex-wrap gap-2 align-items-center">
                        <div class="input-group input-group-sm" style="width: 160px;">
                            <span class="input-group-text bg-white border-end-0"><i class="bi bi-calendar3 text-primary"></i></span>
                            <select name="filterYear" class="form-select border-start-0 shadow-none" onchange="this.form.submit()">
                                <option value="">— Niên khóa —</option>
                                @foreach (var y in Model.Years)
                                {
                                    <option value="@y" selected="@(Model.FilterYear == y)">@y</option>
                                }
                            </select>
                        </div>
                        
                        <div class="input-group input-group-sm" style="width: 130px;">
                            <span class="input-group-text bg-white border-end-0"><i class="bi bi-clock-history text-info"></i></span>
                            <select name="filterSemester" class="form-select border-start-0 shadow-none" onchange="this.form.submit()">
                                <option value="">— Học kỳ —</option>
                                @foreach (var s in Model.Semesters)
                                {
                                    <option value="@s" selected="@(Model.FilterSemester == s)">HK @s</option>
                                }
                            </select>
                        </div>

                        @if (isPGV && Model.Faculties.Any())
                        {
                            <div class="input-group input-group-sm" style="width: 200px;">
                                <span class="input-group-text bg-white border-end-0"><i class="bi bi-building text-success"></i></span>
                                <select name="filterFaculty" class="form-select border-start-0 shadow-none" onchange="this.form.submit()">
                                    <option value="">— Tất cả khoa —</option>
                                    @foreach (var f in Model.Faculties)
                                    {
                                        <option value="@f.Id.Trim()" selected="@(Model.FilterFaculty == f.Id.Trim())">@f.Name</option>
                                    }
                                </select>
                            </div>
                        }
                    </form>
                </div>
            </div>
        </text>,
        
        HeadSection = @<text>
            <tr>
                <th scope="col" style="width:120px" class="ps-4">
                    <div class="d-flex align-items-center gap-2">
                        <i class="bi bi-hash text-primary"></i>
                        <span class="text-uppercase small fw-bold tracking-wider">Mã LTC</span>
                    </div>
                </th>
                <th scope="col" style="width:150px">
                    <div class="d-flex align-items-center gap-2">
                        <i class="bi bi-calendar-event text-primary"></i>
                        <span class="text-uppercase small fw-bold tracking-wider">Niên khóa</span>
                    </div>
                </th>
                <th scope="col">
                    <div class="d-flex align-items-center gap-2">
                        <i class="bi bi-journal-text text-primary"></i>
                        <span class="text-uppercase small fw-bold tracking-wider">Môn học</span>
                    </div>
                </th>
                <th scope="col" style="width:100px" class="text-center">
                    <div class="d-flex align-items-center gap-2 justify-content-center">
                        <i class="bi bi-collection text-primary"></i>
                        <span class="text-uppercase small fw-bold tracking-wider">Nhóm</span>
                    </div>
                </th>
                <th scope="col" style="width:220px">
                    <div class="d-flex align-items-center gap-2">
                        <i class="bi bi-person-badge text-primary"></i>
                        <span class="text-uppercase small fw-bold tracking-wider">Giảng viên</span>
                    </div>
                </th>
                <th scope="col" style="width:110px" class="text-center">
                    <div class="d-flex align-items-center gap-2 justify-content-center">
                        <i class="bi bi-people text-primary"></i>
                        <span class="text-uppercase small fw-bold tracking-wider">Tối thiểu</span>
                    </div>
                </th>
                <th scope="col" style="width:110px" class="text-center">
                    <div class="d-flex align-items-center gap-2 justify-content-center">
                        <i class="bi bi-person-check text-primary"></i>
                        <span class="text-uppercase small fw-bold tracking-wider">Đã ĐK</span>
                    </div>
                </th>
                <th scope="col" style="width:140px" class="text-center">
                    <div class="d-flex align-items-center gap-2 justify-content-center">
                        <i class="bi bi-info-circle text-primary"></i>
                        <span class="text-uppercase small fw-bold tracking-wider">Trạng thái</span>
                    </div>
                </th>
                @if (isPGV)
                {
                    <th scope="col" class="text-end pe-4" style="width:160px">
                        <i class="bi bi-lightning-charge-fill text-warning opacity-75"></i>
                    </th>
                }
            </tr>
        </text>,
        
        BodySection = @<text>
            @if (!Model.CreditClasses.Any())
            {
                <tr>
                    <td colspan="@(isPGV ? 9 : 8)" class="text-center py-5 border-0">
                        <div class="animate__animated animate__fadeIn py-5">
                            <div class="icon-box-lg bg-light rounded-circle d-inline-flex align-items-center justify-content-center mb-3 shadow-sm">
                                <i class="bi bi-inbox text-body-tertiary fs-1"></i>
                            </div>
                            <h5 class="text-dark fw-bold mb-2">Không có dữ liệu lớp tín chỉ</h5>
                            <p class="text-muted small mx-auto" style="max-width: 320px;">
                                Hệ thống chưa tìm thấy lớp tín chỉ nào cho tiêu chí đã chọn.
                            </p>
                        </div>
                    </td>
                </tr>
            }
            else
            {
                @foreach (var c in Model.CreditClasses)
                {
                    <tr class="hover-row animate__animated animate__fadeIn transition-base" 
                        data-id="@c.Id" data-year="@c.Year" data-semester="@c.Semester"
                        data-sub-id="@c.SubjectId.Trim()" data-sub-name="@c.SubjectName" data-group="@c.Group" 
                        data-lec-id="@c.LecturerId.Trim()" data-fac-id="@c.FacultyId.Trim()" 
                        data-min="@c.MinStudents" data-cancelled="@(c.Cancelled ? "true" : "false")"
                        data-reg-count="@c.RegisteredCount"
                        data-search="@(c.SubjectName + " " + c.LecturerName)">
                        
                        <td class="ps-4">
                            <span class="fw-bold font-monospace text-primary bg-primary bg-opacity-10 px-2 py-1 rounded small border border-primary border-opacity-10 shadow-sm">
                                LTC-@(int.TryParse(c.Id, out var idVal) ? idVal.ToString("D4") : c.Id)
                            </span>
                        </td>
                        <td>
                            <div class="fw-bold text-dark tabular-nums">@c.Year</div>
                            <div class="text-muted small d-flex align-items-center gap-1">
                                <i class="bi bi-clock-history opacity-50"></i>
                                <span>Học kỳ @c.Semester</span>
                            </div>
                        </td>
                        <td>
                            <div class="fw-bold text-dark mb-0">@c.SubjectName</div>
                            <div class="text-muted small font-monospace opacity-75">@c.SubjectId.Trim()</div>
                        </td>
                        <td class="text-center">
                            <span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary border-opacity-10 px-3 py-1 rounded-pill shadow-sm">
                                Nhóm @c.Group
                            </span>
                        </td>
                        <td>
                            <div class="fw-medium text-dark">@c.LecturerName</div>
                            <div class="text-muted small d-flex align-items-center gap-1 opacity-75">
                                <i class="bi bi-person-badge opacity-50"></i>
                                <span class="font-monospace">@c.LecturerId.Trim()</span>
                            </div>
                        </td>
                        <td class="text-center fw-medium text-muted tabular-nums">@c.MinStudents</td>
                        <td class="text-center">
                            @if (c.RegisteredCount > 0)
                            {
                                <div class="badge @(c.RegisteredCount < c.MinStudents ? "bg-warning bg-opacity-10 text-warning border-warning border-opacity-10" : "bg-success bg-opacity-10 text-success border-success border-opacity-10") border px-2 py-1 rounded-pill shadow-sm tabular-nums min-w-40">
                                    <span class="fw-bold">@c.RegisteredCount</span>
                                </div>
                            }
                            else
                            {
                                <span class="text-muted opacity-50 tabular-nums">0</span>
                            }
                        </td>
                        <td class="text-center">
                            @if (c.Cancelled)
                            {
                                <span class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-10 px-3 py-1 rounded-pill w-100 shadow-sm d-inline-flex align-items-center justify-content-center gap-1">
                                    <i class="bi bi-x-circle-fill"></i>
                                    <span>Đã hủy</span>
                                </span>
                            }
                            else if (c.RegisteredCount < c.MinStudents)
                            {
                                <span class="badge bg-warning bg-opacity-10 text-warning border border-warning border-opacity-10 px-3 py-1 rounded-pill w-100 shadow-sm d-inline-flex align-items-center justify-content-center gap-1">
                                    <i class="bi bi-hourglass-split"></i>
                                    <span>Chờ SV</span>
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-10 px-3 py-1 rounded-pill w-100 shadow-sm d-inline-flex align-items-center justify-content-center gap-1">
                                    <i class="bi bi-check-circle-fill"></i>
                                    <span>Đã mở</span>
                                </span>
                            }
                        </td>
                        @if (isPGV)
                        {
                            <td class="text-end pe-4">
                                <div class="d-flex justify-content-end gap-1">
                                    <button class="btn btn-sm btn-outline-info shadow-none hover-scale rounded-3"
                                            title="Xem danh sách Sinh viên đã đăng ký" 
                                            onclick="window.location.href='@Url.Action("Index", "Registration")?filterCreditClassId=@c.Id'">
                                        <i class="bi bi-people"></i>
                                    </button>
                                    <button class="btn btn-sm btn-outline-primary btn-edit-row shadow-none hover-scale rounded-3"
                                            title="Chỉnh sửa thông tin lớp tín chỉ"
                                            data-id="@c.Id" data-year="@c.Year" data-semester="@c.Semester"
                                            data-sub-id="@c.SubjectId.Trim()" data-group="@c.Group"
                                            data-lec-id="@c.LecturerId.Trim()" data-fac-id="@c.FacultyId.Trim()"
                                            data-min="@c.MinStudents" data-reg-count="@c.RegisteredCount"
                                            data-cancelled="@(c.Cancelled ? "true" : "false")">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                    @{
                                        var canDelete = c.RegisteredCount == 0;
                                        var deleteTooltip = canDelete ? "Xóa lớp tín chỉ này" : $"Không thể xóa LTC đã có {c.RegisteredCount} SV đăng ký";
                                    }
                                    <button class="btn btn-sm @(canDelete ? "btn-outline-danger btn-delete-row shadow-none hover-scale rounded-3" : "btn-light text-muted border-0 opacity-50")"
                                            title="@deleteTooltip"
                                            data-id="@c.Id"
                                            @(canDelete ? "" : "disabled")>
                                        <i class="bi @(canDelete ? "bi-trash" : "bi-trash-fill")"></i>
                                    </button>
                                </div>
                            </td>
                        }
                    </tr>
                }
            }
        </text>,
        
        FooterSection = @<text>
            <div class="d-flex align-items-center justify-content-between w-100 px-3 py-1">
                <div class="text-muted small d-flex align-items-center gap-2">
                    <i class="bi bi-info-circle-fill text-primary opacity-75"></i>
                    <span>
                        Hiển thị <strong id="visibleCount" class="text-primary tabular-nums">@Model.CreditClasses.Count()</strong>
                        / <span class="tabular-nums">@Model.CreditClasses.Count()</span> lớp tín chỉ
                    </span>
                </div>
                
                <div class="d-none d-md-flex align-items-center gap-2 text-muted small bg-light px-3 py-1 rounded-pill border shadow-xs">
                    <i class="bi bi-lightbulb text-warning"></i>
                    <span>Nhấn <kbd class="bg-white text-dark border px-1">Ctrl + F</kbd> để tìm nhanh trên trang hiện tại</span>
                </div>
            </div>
        </text>
    };

    ViewData["TableId"] = "creditClassTable";
    ViewData["TableBodyId"] = "creditClassTableBody";
}

@await Html.PartialAsync("_CardTableWrapper", tableModel, ViewData)
