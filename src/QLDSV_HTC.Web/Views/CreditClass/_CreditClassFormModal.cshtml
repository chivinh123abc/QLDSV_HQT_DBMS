@model QLDSV_HTC.Web.Models.CreditClassManagementViewModel
@using QLDSV_HTC.Web.Models

@{
    var hasFaculty = (bool)(ViewData["hasFaculty"] ?? false);
    
    var modalModel = new GenericFormModalViewModel
    {
        ModeBadgeSection = @<text>
            <span class="badge bg-white text-primary ms-2 animate__animated animate__fadeIn" id="formModeLabel" style="font-size:.7rem">Chế độ: Xem</span>
        </text>,
        
        ToolbarSection = @<text>
            @{ ViewData["IdPrefix"] = "Form"; }
            @await Html.PartialAsync("_CrudToolbar", null, ViewData)
        </text>,
        
        BodySection = @<text>
            <div class="row g-3">
                <input type="hidden" id="fldCreditClassId" />
                
                <div class="col-md-4">
                    <label for="fldYear" class="form-label fw-semibold">
                        Niên Khóa <span class="text-danger">*</span>
                    </label>
                    <input type="text" class="form-control font-monospace border-primary-subtle" id="fldYear"
                           maxlength="9" placeholder="VD: 2021-2022" disabled>
                    <div class="invalid-feedback">Vui lòng nhập niên khóa.</div>
                </div>
                
                <div class="col-md-2">
                    <label for="fldSemester" class="form-label fw-semibold">
                        Học Kỳ <span class="text-danger">*</span>
                    </label>
                    <select class="form-select border-primary-subtle" id="fldSemester" disabled>
                        <option value="">— Chọn —</option>
                        @foreach (var sem in Model.Semesters)
                        {
                            <option value="@sem">HK @sem</option>
                        }
                    </select>
                    <div class="invalid-feedback">Chọn học kỳ.</div>
                </div>

                <div class="col-md-6">
                    <label for="fldSubjectId" class="form-label fw-semibold">
                        Môn Học <span class="text-danger">*</span>
                    </label>
                    <select class="form-select border-primary-subtle" id="fldSubjectId" disabled>
                        <option value="">— Chọn môn học —</option>
                        @foreach (var sub in Model.Subjects)
                        {
                            <option value="@sub.Id.Trim()">@sub.Name (@sub.Id.Trim())</option>
                        }
                    </select>
                    <div class="invalid-feedback">Vui lòng chọn môn học.</div>
                </div>
                
                <div class="col-md-2">
                    <label for="fldGroup" class="form-label fw-semibold">
                        Nhóm <span class="text-danger">*</span>
                    </label>
                    <input type="number" class="form-control border-primary-subtle" id="fldGroup"
                           min="1" max="99" value="1" disabled>
                    <div class="invalid-feedback">Nhập nhóm.</div>
                </div>

                <div class="col-md-5">
                    <label for="fldLecturerId" class="form-label fw-semibold">
                        Giảng Viên
                    </label>
                    <select class="form-select" id="fldLecturerId" disabled>
                        <option value="">— Không có —</option>
                        @foreach (var lec in Model.Lecturers)
                        {
                            <option value="@lec.Id.Trim()">@lec.FirstName @lec.LastName (@lec.Id.Trim())</option>
                        }
                    </select>
                </div>
                
                <div class="col-md-5">
                    <label for="fldFacultyId" class="form-label fw-semibold">
                        Khoa <span class="text-danger">*</span>
                    </label>
                    <select class="form-select" id="fldFacultyId" disabled>
                        <option value="">— Chọn khoa —</option>
                        @foreach (var fac in Model.Faculties)
                        {
                            <option value="@fac.Id.Trim()">@fac.Name</option>
                        }
                    </select>
                    <div class="invalid-feedback">Vui lòng chọn khoa.</div>
                </div>

                <div class="col-md-4">
                    <label for="fldMinStudents" class="form-label fw-semibold">
                        SV Tối Thiểu <span class="text-danger">*</span>
                    </label>
                    <input type="number" class="form-control" id="fldMinStudents"
                           min="1" max="500" value="30" disabled>
                    <div class="invalid-feedback">Nhập số SV.</div>
                </div>

                <div class="col-md-4 d-flex align-items-end">
                    <div class="form-check form-switch mb-2">
                        <input class="form-check-input" type="checkbox" role="switch" id="fldIsCancelled" disabled>
                        <label class="form-check-label text-danger fw-bold" for="fldIsCancelled">Hủy Lớp</label>
                    </div>
                </div>
            </div>
            
            <div class="alert alert-light border shadow-sm p-3 rounded-3 mt-4 mb-0 d-flex align-items-start gap-3">
                <i class="bi bi-info-circle-fill text-primary fs-4"></i>
                <div class="small text-muted">
                    <h6 class="text-dark fw-bold mb-1">Hướng dẫn</h6>
                    Mọi thay đổi khi bấm <b class="text-dark">Lưu data</b> sẽ có hiệu lực ngay trên Hệ thống CSDL.
                </div>
            </div>
        </text>,
        
        ExtraBodySection = @<text>
            <h6 class="fw-bold mb-3 text-primary d-flex align-items-center gap-2">
                <i class="bi bi-list-ul"></i>
                <span>Danh sách lớp tín chỉ được hiển thị</span>
                @if (hasFaculty) { <span class="badge bg-primary px-2 fw-normal" style="font-size:0.7rem">Khoa @Model.CurrentFacultyId?.Trim()</span> }
            </h6>
            <div class="table-responsive rounded-3 border border-light-subtle shadow-sm" style="max-height:240px; overflow-y:auto">
                <table class="table table-sm table-hover align-middle mb-0" id="miniCreditClassTable">
                    <thead class="table-light sticky-top">
                        <tr class="small text-muted">
                            <th>Mã LTC</th>
                            <th>Môn Học</th>
                            <th class="text-center">Nhóm</th>
                            <th class="text-center">Tối thiểu</th>
                            <th class="text-center">Trạng thái</th>
                        </tr>
                    </thead>
                    <tbody id="miniCreditClassBody" class="small">
                        @foreach (var c in Model.CreditClasses)
                        {
                            <tr class="mini-row transition-base" role="button"
                                data-id="@c.Id" data-year="@c.Year" data-semester="@c.Semester"
                                data-sub-id="@c.SubjectId.Trim()" data-sub-name="@c.SubjectName" data-group="@c.Group" 
                                data-lec-id="@c.LecturerId.Trim()" data-fac-id="@c.FacultyId.Trim()" 
                                data-min="@c.MinStudents" data-cancelled="@(c.Cancelled ? "true" : "false")">
                                <td class="fw-bold font-monospace text-primary">@c.Id</td>
                                <td class="text-truncate" style="max-width: 150px;" title="@c.SubjectName">@c.SubjectName</td>
                                <td class="text-center">
                                    <span class="badge bg-info-subtle text-info border border-info-subtle px-2">@c.Group</span>
                                </td>
                                <td class="text-center">@c.MinStudents</td>
                                <td class="text-center">
                                    @if (c.Cancelled)
                                    {
                                        <span class="badge bg-danger-subtle text-danger border border-danger-subtle">Hủy</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success-subtle text-success border border-success-subtle">Mở</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </text>
    };

    ViewData["ModalId"] = "creditClassFormModal";
    ViewData["ModalLabelId"] = "creditClassFormModalLabel";
    ViewData["ModalTitle"] = "Cập nhật Lớp tín chỉ";
    ViewData["ModalIcon"] = "bi-calendar2-range";
    ViewData["FormId"] = "creditClassForm";
    ViewData["AlertId"] = "formAlert";
    ViewData["ModalSize"] = "modal-lg";
}

@await Html.PartialAsync("_FormModalWrapper", modalModel, ViewData)
