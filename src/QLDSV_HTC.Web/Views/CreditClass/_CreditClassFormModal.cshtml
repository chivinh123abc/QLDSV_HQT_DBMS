@model QLDSV_HTC.Web.Models.CreditClassManagementViewModel
@using QLDSV_HTC.Web.Models

@{
    var hasFaculty = (bool)(ViewData["hasFaculty"] ?? false);
    
    var modalModel = new GenericFormModalViewModel
    {
        ModeBadgeSection = @<text>
            <span class="badge bg-white text-primary ms-2 animate__animated animate__fadeIn" id="formModeLabel" style="font-size:.7rem">Chế độ: Xem</span>
        </text>,
        
        ToolbarSection = @<text>
            @{ ViewData["IdPrefix"] = "Form"; }
            @await Html.PartialAsync("_CrudToolbar", null, ViewData)
        </text>,
        
        BodySection = @<text>
            <div class="row g-4">
                <input type="hidden" id="fldCreditClassId" />
                
                <div class="col-md-4">
                    <label for="fldYear" class="text-uppercase small fw-bold text-muted mb-2 d-block">
                        Niên Khóa <span class="text-danger">*</span>
                    </label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-primary-subtle text-primary">
                            <i class="bi bi-calendar-event"></i>
                        </span>
                        <input type="text" class="form-control font-monospace border-primary-subtle shadow-none" id="fldYear"
                               maxlength="9" placeholder="VD: 2021-2022" disabled>
                    </div>
                    <div class="invalid-feedback">Vui lòng nhập niên khóa.</div>
                </div>
                
                <div class="col-md-3">
                    <label for="fldSemester" class="text-uppercase small fw-bold text-muted mb-2 d-block">
                        Học Kỳ <span class="text-danger">*</span>
                    </label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-primary-subtle text-info">
                            <i class="bi bi-clock-history"></i>
                        </span>
                        <select class="form-select border-primary-subtle shadow-none" id="fldSemester" disabled>
                            <option value="">— Chọn —</option>
                            @foreach (var sem in Model.Semesters)
                            {
                                <option value="@sem">HK @sem</option>
                            }
                        </select>
                    </div>
                    <div class="invalid-feedback">Chọn học kỳ.</div>
                </div>

                <div class="col-md-5">
                    <label for="fldSubjectId" class="text-uppercase small fw-bold text-muted mb-2 d-block">
                        Môn Học <span class="text-danger">*</span>
                    </label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-primary-subtle text-primary">
                            <i class="bi bi-journal-text"></i>
                        </span>
                        <select class="form-select border-primary-subtle shadow-none" id="fldSubjectId" disabled>
                            <option value="">— Chọn môn học —</option>
                            @foreach (var sub in Model.Subjects)
                            {
                                <option value="@sub.Id.Trim()">@sub.Name (@sub.Id.Trim())</option>
                            }
                        </select>
                    </div>
                    <div class="invalid-feedback">Vui lòng chọn môn học.</div>
                </div>
                
                <div class="col-md-3">
                    <label for="fldGroup" class="text-uppercase small fw-bold text-muted mb-2 d-block">
                        Nhóm <span class="text-danger">*</span>
                    </label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-primary-subtle text-secondary">
                            <i class="bi bi-collection"></i>
                        </span>
                        <input type="number" class="form-control border-primary-subtle shadow-none tabular-nums" id="fldGroup"
                               min="1" max="99" value="1" disabled>
                    </div>
                    <div class="invalid-feedback">Nhập nhóm.</div>
                </div>

                <div class="col-md-5">
                    <label for="fldLecturerId" class="text-uppercase small fw-bold text-muted mb-2 d-block">
                        Giảng Viên
                    </label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-light-subtle text-dark">
                            <i class="bi bi-person-badge"></i>
                        </span>
                        <select class="form-select shadow-none" id="fldLecturerId" disabled>
                            <option value="">— Không có —</option>
                            @foreach (var lec in Model.Lecturers)
                            {
                                <option value="@lec.Id.Trim()">@lec.FirstName @lec.LastName (@lec.Id.Trim())</option>
                            }
                        </select>
                    </div>
                </div>
                
                <div class="col-md-4">
                    <label for="fldFacultyId" class="text-uppercase small fw-bold text-muted mb-2 d-block">
                        Khoa <span class="text-danger">*</span>
                    </label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-light-subtle text-success">
                            <i class="bi bi-building"></i>
                        </span>
                        <select class="form-select shadow-none" id="fldFacultyId" disabled>
                            <option value="">— Chọn khoa —</option>
                            @foreach (var fac in Model.Faculties)
                            {
                                <option value="@fac.Id.Trim()">@fac.Name</option>
                            }
                        </select>
                    </div>
                    <div class="invalid-feedback">Vui lòng chọn khoa.</div>
                </div>

                <div class="col-md-4">
                    <label for="fldMinStudents" class="text-uppercase small fw-bold text-muted mb-2 d-block">
                        SV Tối Thiểu <span class="text-danger">*</span>
                    </label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-light-subtle text-muted">
                            <i class="bi bi-people"></i>
                        </span>
                        <input type="number" class="form-control shadow-none tabular-nums" id="fldMinStudents"
                               min="1" max="500" value="30" disabled>
                    </div>
                    <div class="invalid-feedback">Nhập số SV.</div>
                </div>

                <div class="col-md-5 d-flex align-items-end">
                    <div class="form-check form-switch mb-2 p-2 bg-danger bg-opacity-10 rounded border border-danger border-opacity-10 w-100">
                        <input class="form-check-input ms-0 me-2" type="checkbox" role="switch" id="fldIsCancelled" disabled>
                        <label class="form-check-label text-danger fw-bold small text-uppercase" for="fldIsCancelled">Hủy Lớp Tín Chỉ</label>
                    </div>
                </div>
            </div>
            
            <div class="alert alert-light border shadow-sm p-3 rounded-3 mt-4 mb-0 d-flex align-items-start gap-3">
                <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 32px; height: 32px;">
                    <i class="bi bi-info-circle-fill"></i>
                </div>
                <div class="small text-muted">
                    <h6 class="text-dark fw-bold mb-1">Hướng dẫn vận hành</h6>
                    Mọi thay đổi khi bấm <b class="text-dark">Ghi</b> sẽ được cập nhật trực tiếp vào hệ thống. Lớp đã có sinh viên đăng ký sẽ <b class="text-danger">hạn chế</b> một số quyền sửa đổi.
                </div>
            </div>
        </text>,
        
        ExtraBodySection = @<text>
            <div class="d-flex align-items-center justify-content-between mb-3 mt-2">
                <h6 class="fw-bold mb-0 text-primary d-flex align-items-center gap-2">
                    <i class="bi bi-list-ul"></i>
                    <span class="text-uppercase small">Danh sách tham chiếu</span>
                </h6>
                @if (hasFaculty) { 
                    <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-10 px-2 fw-medium" style="font-size:0.7rem">
                        KHOA: @Model.CurrentFacultyId?.Trim()
                    </span> 
                }
            </div>
            <div class="table-responsive rounded-3 border border-light-subtle shadow-sm" style="max-height:240px; overflow-y:auto">
                <table class="table table-sm table-hover align-middle mb-0" id="miniCreditClassTable">
                    <thead class="table-light sticky-top">
                        <tr>
                            <th class="ps-3 text-uppercase small fw-bold text-muted py-2">Mã LTC</th>
                            <th class="text-uppercase small fw-bold text-muted py-2">Môn Học</th>
                            <th class="text-center text-uppercase small fw-bold text-muted py-2">Nhóm</th>
                            <th class="text-center text-uppercase small fw-bold text-muted py-2">T.Thiểu</th>
                            <th class="text-center text-uppercase small fw-bold text-muted py-2">T.Thái</th>
                        </tr>
                    </thead>
                    <tbody id="miniCreditClassBody" class="small">
                        @foreach (var c in Model.CreditClasses)
                        {
                            <tr class="mini-row transition-base" role="button"
                                data-id="@c.Id" data-year="@c.Year" data-semester="@c.Semester"
                                data-sub-id="@c.SubjectId.Trim()" data-sub-name="@c.SubjectName" data-group="@c.Group" 
                                data-lec-id="@c.LecturerId.Trim()" data-fac-id="@c.FacultyId.Trim()" 
                                data-min="@c.MinStudents" data-cancelled="@(c.Cancelled ? "true" : "false")"
                                data-reg-count="@c.RegisteredCount">
                                <td class="ps-3 fw-bold font-monospace text-primary">@(int.TryParse(c.Id, out var idVal) ? idVal.ToString("D4") : c.Id)</td>
                                <td class="text-truncate fw-medium" style="max-width: 150px;" title="@c.SubjectName">@c.SubjectName</td>
                                <td class="text-center">
                                    <span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary border-opacity-10 px-2">@c.Group</span>
                                </td>
                                <td class="text-center tabular-nums">@c.MinStudents</td>
                                <td class="text-center">
                                    @if (c.Cancelled)
                                    {
                                        <span class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-10 rounded-pill px-2">Hủy</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-10 rounded-pill px-2">Mở</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </text>
    };

    ViewData["ModalId"] = "creditClassFormModal";
    ViewData["ModalLabelId"] = "creditClassFormModalLabel";
    ViewData["ModalTitle"] = "Cập nhật Lớp tín chỉ";
    ViewData["ModalIcon"] = "bi-calendar2-range";
    ViewData["FormId"] = "creditClassForm";
    ViewData["AlertId"] = "formAlert";
    ViewData["ModalSize"] = "modal-lg";
}

@await Html.PartialAsync("_FormModalWrapper", modalModel, ViewData)
